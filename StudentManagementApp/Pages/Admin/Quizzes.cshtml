@page
@model StudentManagementApp.Pages.Admin.QuizzesModel
@{
    ViewData["Title"] = "Quản lý bài kiểm tra";
    ViewData["ActivePage"] = "Quizzes";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var userName = HttpContext.Session.GetString("UserName");

    var total = Model.Quizzes.Count();
    var activeCount = Model.Quizzes.Count(q => q.IsActive);
    var totalQuestions = Model.Quizzes.Sum(q => q.QuestionCount);
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Hệ thống đánh giá</h6>
        <h2 class="fw-bold mb-0">Danh sách bài Quiz</h2>
    </div>
    <a href="/Admin/QuizEdit" class="btn btn-primary-res px-4">
        <i class="bi bi-plus-circle me-2"></i>Tạo Quiz mới
    </a>
</div>

<!-- MINI STATS -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="res-card p-3 border-0 shadow-sm bg-white d-flex align-items-center gap-3">
            <div class="bg-primary-subtle text-primary p-3 rounded-4">
                <i class="bi bi-collection fs-3"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Tổng số Quiz</div>
                <div class="fs-4 fw-bold">@total</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="res-card p-3 border-0 shadow-sm bg-white d-flex align-items-center gap-3">
            <div class="bg-success-subtle text-success p-3 rounded-4">
                <i class="bi bi-check-circle fs-3"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Đang mở</div>
                <div class="fs-4 fw-bold">@activeCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="res-card p-3 border-0 shadow-sm bg-white d-flex align-items-center gap-3">
            <div class="bg-info-subtle text-info p-3 rounded-4">
                <i class="bi bi-question-circle fs-3"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Tổng câu hỏi</div>
                <div class="fs-4 fw-bold">@totalQuestions</div>
            </div>
        </div>
    </div>
</div>

<div class="admin-card">
    @if (Model.Quizzes.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Thông tin bài thi</th>
                        <th>Khóa học</th>
                        <th class="text-center">Chi tiết</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var quiz in Model.Quizzes)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@quiz.Title</div>
                                <div class="text-muted small text-truncate" style="max-width: 250px;">@quiz.Description</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@quiz.CourseName</span>
                            </td>
                            <td class="text-center">
                                <div class="small fw-bold text-dark">@quiz.QuestionCount câu hỏi</div>
                                <div class="small text-muted">@quiz.TimeLimitMinutes phút / @quiz.TotalPoints điểm</div>
                            </td>
                            <td>
                                @if (quiz.IsActive)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success px-3">Công khai</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary-subtle text-muted px-3">Bản nháp</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/Admin/QuizEdit?id=@quiz.Id" class="btn btn-sm btn-light border fw-bold text-muted px-3">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a href="/Admin/QuizQuestions?quizId=@quiz.Id" class="btn btn-sm btn-light border fw-bold text-primary px-3">
                                        <i class="bi bi-list-check"></i> Câu hỏi
                                    </a>
                                    <a href="/Admin/QuizResults?quizId=@quiz.Id" class="btn btn-sm btn-light border fw-bold text-info px-3">
                                        <i class="bi bi-bar-chart"></i> Kết quả
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-patch-exclamation text-muted opacity-25 display-1"></i>
            <p class="mt-3 text-muted fw-bold">Hiện chưa có bài kiểm tra nào.</p>
        </div>
    }
</div>

<style>
    .bg-primary-subtle { background: #eff6ff !important; }
    .bg-success-subtle { background: #ecfdf5 !important; }
    .bg-info-subtle { background: #ecfeff !important; }
    .bg-secondary-subtle { background: #f8fafc !important; }
    .custom-table thead th {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.5px; color: #64748b; padding-top: 15px; padding-bottom: 15px;
    }
    .custom-table tbody td { padding-top: 15px; padding-bottom: 15px; }
</style>