@using StudentManagementApp.BLL.DTOs
@model IEnumerable<ClassDto>

@{
    ViewData["Title"] = "Lớp học của tôi";
    var name = Context.Session.GetString("UserName");
    var todayDow = (int)DateTime.Today.DayOfWeek;
    int todayAppDow = todayDow == 0 ? 8 : todayDow + 1;
    string[] dayNames = { "", "CN", "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "CN" };
}

<div class="container py-5">
    <h4 class="fw-bold mb-1">Xin chào, @name!</h4>
    <p class="text-muted mb-4">Danh sách lớp học được phân công</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">Bạn chưa được phân công lớp học nào.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var cls in Model)
            {
                var hasSessionToday = cls.Schedules.Any(s => s.DayOfWeek == todayAppDow);
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="fw-bold mb-1">@cls.ClassName</h6>
                                    <p class="text-muted small mb-1">@cls.CourseName</p>
                                    <p class="text-muted small mb-0">
                                        @cls.StartDate.ToString("dd/MM/yyyy") — @cls.EndDate.ToString("dd/MM/yyyy")
                                    </p>
                                </div>
                                <span class="badge @(cls.Status == "Ongoing" ? "bg-success" : cls.Status == "Upcoming" ? "bg-primary" : "bg-secondary")">
                                    @(cls.Status == "Ongoing" ? "Đang học" : cls.Status == "Upcoming" ? "Sắp khai giảng" : "Kết thúc")
                                </span>
                            </div>

                            @if (cls.Schedules.Any())
                            {
                                <p class="text-muted small mb-2">
                                    <i class="fa fa-clock me-1"></i>
                                    @string.Join(", ", cls.Schedules.Select(s => $"{dayNames[s.DayOfWeek]} {s.StartTime:HH\\:mm}-{s.EndTime:HH\\:mm}"))
                                </p>
                            }

                            @if (cls.Status == "Ongoing")
                            {
                                <div class="d-flex gap-2 flex-wrap mt-2">
                                    @if (hasSessionToday)
                                    {
                                        <a asp-action="Attendance" asp-route-classId="@cls.Id"
                                           class="btn btn-outline-primary btn-sm rounded-pill">
                                            <i class="fa fa-clipboard-check me-1"></i> Điểm danh hôm nay
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic align-self-center">Hôm nay không có tiết</span>
                                    }
                                    <a asp-action="AttendanceReport" asp-route-classId="@cls.Id"
                                       class="btn btn-outline-secondary btn-sm rounded-pill">
                                        <i class="fa fa-chart-bar me-1"></i> Báo cáo điểm danh
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-4">
            <a asp-action="Schedule" class="btn btn-primary rounded-pill px-4">
                <i class="fa fa-calendar me-1"></i> Xem lịch dạy
            </a>
        </div>
    }
</div>
