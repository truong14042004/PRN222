@using StudentManagementApp.BLL.DTOs
@model IEnumerable<EnrollmentDto>

@{
    ViewData["Title"] = "Dashboard";
    var name = Context.Session.GetString("UserName");
}

<div class="container py-5">
    <h4 class="fw-bold mb-1">Xin chào, @name!</h4>
    <p class="text-muted mb-4">Danh sách lớp học của bạn</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Bạn chưa đăng ký lớp học nào.
            <a asp-controller="Course" asp-action="Index" class="alert-link">Xem khóa học ngay</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var e in Model)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="fw-bold mb-1">@e.ClassName</h6>
                                    <p class="text-muted small mb-1">@e.CourseName</p>
                                    <p class="text-muted small mb-0">Đăng ký: @e.EnrolledAt.ToString("dd/MM/yyyy")</p>
                                </div>
                                <span class="badge @(e.Status == "Confirmed" ? "bg-success" : "bg-warning text-dark")">
                                    @(e.Status == "Confirmed" ? "Đã xác nhận" : "Chờ xác nhận")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-4 d-flex gap-3">
            <a asp-action="Schedule" class="btn btn-primary rounded-pill px-4">
                <i class="fa fa-calendar me-1"></i> Xem lịch học
            </a>
            <a asp-action="AttendanceReport" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="fa fa-chart-bar me-1"></i> Lịch sử điểm danh
            </a>
        </div>
    }
</div>
