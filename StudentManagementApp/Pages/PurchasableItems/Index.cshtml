@page
@model StudentManagementApp.Pages.PurchasableItems.IndexModel
@{
    ViewData["Title"] = "Cửa hàng giáo trình";
    var userRole = HttpContext.Session.GetString("UserRole");
    var userName = HttpContext.Session.GetString("UserName");
    var userId = HttpContext.Session.GetString("UserId");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">English Center</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Course">Khóa học</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/PurchasableItems">Cửa hàng</a></li>
                    @if (userRole == "Student" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Student">Học viên</a></li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Cart"><i class="bi bi-cart3"></i> Giỏ hàng</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                Xin chào, @userName
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Auth/Logout">Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Auth/Login">Đăng nhập</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="row">
            <div class="col-12">
                <h2 class="mb-4">Giáo trình & Vật phẩm giáo dục</h2>
            </div>
            @if (Model.Items != null && Model.Items.Any())
            {
                @foreach (var item in Model.Items)
                {
                    <div class="col-md-3 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="max-height: 100%; object-fit: contain;">
                                }
                                else
                                {
                                    <i class="bi bi-book text-secondary" style="font-size: 4rem;"></i>
                                }
                            </div>
                            <div class="card-body">
                                <h5 class="card-title text-primary">@item.Name</h5>
                                <p class="card-text text-muted small">@item.Description</p>
                                <h4 class="text-danger">@item.Price.ToString("N0") VNĐ</h4>
                            </div>
                            <div class="card-footer bg-white border-top-0">
                                <form method="post" asp-page-handler="AddToCart">
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-primary w-100">
                                        <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Tính năng đang cập nhật sản phẩm.</p>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
