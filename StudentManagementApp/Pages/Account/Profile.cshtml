@page
@model StudentManagementApp.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="res-card h-100">
                <div class="res-card-header">Thông Tin Tài Khoản</div>
                <div class="card-body p-4">
                    @if (Model.CurrentUser is null)
                    {
                        <p class="text-muted mb-0">Không tìm thấy thông tin tài khoản.</p>
                    }
                    else
                    {
                        <div class="mb-3">
                            <div class="small text-muted">Họ tên</div>
                            <div class="fw-semibold">@Model.CurrentUser.FullName</div>
                        </div>
                        <div class="mb-3">
                            <div class="small text-muted">Username</div>
                            <div class="fw-semibold">@Model.CurrentUser.Username</div>
                        </div>
                        <div class="mb-3">
                            <div class="small text-muted">Email</div>
                            <div class="fw-semibold">@Model.CurrentUser.Email</div>
                        </div>
                        <div class="mb-0">
                            <div class="small text-muted">Vai trò</div>
                            <div class="fw-semibold">@Model.CurrentUser.Role</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="res-card mb-4">
                <div class="res-card-header">Cập Nhật Hồ Sơ</div>
                <div class="card-body p-4">
                    <form method="post" asp-page-handler="Profile" class="form-res">
                        <div class="mb-3">
                            <label class="form-label">Họ tên</label>
                            <input asp-for="Input.FullName" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Số điện thoại</label>
                            <input asp-for="Input.Phone" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Avatar URL</label>
                            <input asp-for="Input.AvatarUrl" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-primary-res rounded-pill px-4">Lưu thay đổi</button>
                    </form>
                </div>
            </div>

            <div class="res-card">
                <div class="res-card-header">Đổi Mật Khẩu</div>
                <div class="card-body p-4">
                    <form method="post" asp-page-handler="Password" class="form-res">
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu hiện tại</label>
                            <input type="password" name="currentPassword" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input type="password" name="newPassword" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu mới</label>
                            <input type="password" name="confirmPassword" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-outline-res rounded-pill px-4">Cập nhật mật khẩu</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
