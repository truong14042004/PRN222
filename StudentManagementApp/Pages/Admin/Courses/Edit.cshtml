@page "{id:int}"
@model StudentManagementApp.Pages.Admin.Courses.EditModel
@{
    ViewData["Title"] = "Sửa khóa học";
    ViewData["ActivePage"] = "Courses";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var userName = HttpContext.Session.GetString("UserName");
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Chương trình đào tạo</h6>
        <h2 class="fw-bold mb-0">Sửa khóa học</h2>
    </div>
    <a href="/Admin/Courses" class="btn btn-light border fw-bold px-4">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="admin-card">
            <form method="post">
                <input asp-for="Input.Id" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm rounded-4 mb-4"></div>

                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted text-uppercase">Tên khóa học</label>
                            <input asp-for="Input.Name" class="form-control fw-bold fs-5" placeholder="Nhập tên khóa học..." />
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted text-uppercase">Mô tả khóa học</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="6" placeholder="Nhập mô tả chi tiết..."></textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Cấp độ</label>
                                <select asp-for="Input.Level" class="form-select fw-bold">
                                    <option value="A1">Cấp độ A1</option>
                                    <option value="A2">Cấp độ A2</option>
                                    <option value="B1">Cấp độ B1</option>
                                    <option value="B2">Cấp độ B2</option>
                                    <option value="C1">Cấp độ C1</option>
                                    <option value="C2">Cấp độ C2</option>
                                </select>
                                <span asp-validation-for="Input.Level" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Học phí (VNĐ)</label>
                                <input asp-for="Input.TuitionFee" type="number" min="0" class="form-control fw-bold text-res-red" />
                                <span asp-validation-for="Input.TuitionFee" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-4 h-100">
                            <label class="form-label fw-bold small text-muted text-uppercase">Hình ảnh khóa học</label>
                            <input asp-for="Input.ThumbnailUrl" class="form-control mb-3" id="thumbInput" placeholder="URL hình ảnh..." 
                                   oninput="document.getElementById('courseThumb').src = this.value || '/images/default-course.png'" />
                            
                            <img src="@(string.IsNullOrEmpty(Model.Input.ThumbnailUrl) ? "/images/default-course.png" : Model.Input.ThumbnailUrl)" 
                                 id="courseThumb" class="thumbnail-preview shadow-sm mb-4" />

                            <div class="form-check form-switch p-0 ms-4 mt-4">
                                <input asp-for="Input.IsActive" class="form-check-input" style="width: 3em; height: 1.5em; float: none; margin-left: -2.5em;" />
                                <label asp-for="Input.IsActive" class="form-check-label ms-2 fw-bold text-dark">
                                    Công khai khóa học
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-5 opacity-50">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary-res px-5 py-3 fw-bold">
                        <i class="bi bi-save me-2"></i>Lưu thay đổi
                    </button>
                    <a href="/Admin/Courses" class="btn btn-light border px-5 py-3 fw-bold">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .thumbnail-preview {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-radius: 12px;
        border: 2px solid white;
    }
    .form-control, .form-select {
        padding: 0.75rem 1rem;
        border-radius: 12px !important;
        border: 1px solid #e2e8f0;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--res-red);
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }
</style>