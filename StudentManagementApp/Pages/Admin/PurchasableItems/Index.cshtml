@page
@model StudentManagementApp.Pages.Admin.PurchasableItems.IndexModel
@{
    ViewData["Title"] = "Quản lý vật phẩm";
    ViewData["ActivePage"] = "PurchasableItems";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Cửa hàng học liệu</h6>
        <h2 class="fw-bold mb-0">Danh sách vật phẩm</h2>
    </div>
    <a asp-page="./Create" class="btn btn-primary-res px-4">
        <i class="bi bi-plus-lg me-2"></i>Thêm vật phẩm
    </a>
</div>

<div class="admin-card">
    @if (Model.Items.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Hình ảnh</th>
                        <th>Tên vật phẩm</th>
                        <th>Đơn giá</th>
                        <th>Kho hàng</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="ps-4">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://res.edu.vn/wp-content/uploads/2021/10/banner-ielts-res.jpg" : item.ImageUrl)" 
                                     alt="@item.Name" class="rounded-3 shadow-sm" style="width: 60px; height: 60px; object-fit: cover;">
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Name</div>
                                <div class="text-muted small text-truncate" style="max-width: 250px;">@item.Description</div>
                            </td>
                            <td>
                                <div class="fw-bold text-primary">@item.Price.ToString("N0") <small>đ</small></div>
                            </td>
                            <td>
                                <div class="fw-bold">@item.Quantity</div>
                                <div class="text-muted small">Đơn vị: Cái/Cuốn</div>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success px-3">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary-subtle text-muted px-3">Ngừng bán</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border fw-bold text-muted px-3">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('Xác nhận xóa vật phẩm này?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger fw-bold px-3">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-box-seam text-muted opacity-25 display-1"></i>
            <p class="mt-3 text-muted fw-bold">Hiện chưa có vật phẩm nào trong kho.</p>
        </div>
    }
</div>

<style>
    .bg-success-subtle { background: #ecfdf5 !important; }
    .bg-secondary-subtle { background: #f8fafc !important; }
    .custom-table thead th {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.5px; color: #64748b; padding-top: 15px; padding-bottom: 15px;
    }
    .custom-table tbody td { padding-top: 15px; padding-bottom: 15px; }
</style>
