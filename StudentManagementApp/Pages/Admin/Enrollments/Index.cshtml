@page
@model StudentManagementApp.Pages.Admin.Enrollments.IndexModel
@{
    ViewData["Title"] = "Quản lý đăng ký";
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/Admin">English Center - Admin</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/Admin">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Users">Người dùng</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Courses">Khóa học</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Classes">Lớp học</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Admin/Enrollments">Đăng ký</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Quizzes">Quiz</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Xin chào, @userName</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Auth/Logout">Đăng xuất</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h1>Quản lý đăng ký</h1>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <a class="nav-link @(Model.Pending ? "" : "active")" href="/Admin/Enrollments">Tất cả</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.Pending ? "active" : "")" href="/Admin/Enrollments?pending=true">Chờ xác nhận</a>
            </li>
        </ul>

        @if (Model.Enrollments.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Học viên</th>
                        <th>Lớp</th>
                        <th>Khóa học</th>
                        <th>Ngày đăng ký</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model.Enrollments)
                    {
                        <tr>
                            <td>@e.StudentName</td>
                            <td>@e.ClassName</td>
                            <td>@e.CourseName</td>
                            <td>@e.EnrolledAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="badge bg-@(e.Status == "Confirmed" ? "success" : e.Status == "Registered" ? "warning text-dark" : "secondary")">
                                    @e.Status
                                </span>
                            </td>
                            <td>
                                @if (e.Status == "Registered")
                                {
                                    <form method="post" asp-page="/Admin/Enrollments/Confirm" style="display:inline;">
                                        <input type="hidden" name="id" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm btn-success">Xác nhận</button>
                                    </form>
                                    <form method="post" asp-page="/Admin/Enrollments/Cancel" style="display:inline;">
                                        <input type="hidden" name="id" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">Hủy</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Không có đăng ký nào.</p>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
