@page "{classId:int}"
@model StudentManagementApp.Pages.Teacher.AttendanceReportModel
@{
    ViewData["Title"] = "Báo cáo điểm danh";
}

<section class="py-5 bg-light min-vh-100">
    <div class="container py-4">
        @if (Model.Class is null)
        {
            <div class="text-center py-5">
                <i class="bi bi-search display-1 text-muted opacity-25 mb-4"></i>
                <h2 class="fw-bold">Không tìm thấy dữ liệu lớp</h2>
                <a href="/Teacher" class="btn btn-primary-res px-5 mt-3">QUAY LẠI</a>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-end mb-5">
                <div>
                    <h6 class="text-res-red fw-bold text-uppercase mb-1">Báo cáo học tập</h6>
                    <h2 class="fw-bold mb-0">LỊCH SỬ ĐIỂM DANH</h2>
                    <p class="text-muted mb-0">Lớp: @Model.Class.ClassName | Khóa: @Model.Class.CourseName</p>
                </div>
                <div class="d-flex gap-3">
                    <a href="/Teacher/Attendance/@Model.Class.Id" class="btn btn-primary-res px-4">
                        <i class="bi bi-pencil-square me-2"></i>TIẾP TỤC ĐIỂM DANH
                    </a>
                    <a href="/Teacher" class="btn btn-light px-4 text-muted fw-bold">
                        <i class="bi bi-arrow-left me-2"></i>DANH SÁCH LỚP
                    </a>
                </div>
            </div>

            <div class="res-card p-4 mb-5 shadow-sm border-0">
                <form method="get" class="row g-3 align-items-end">
                    <input type="hidden" name="classId" value="@Model.Class.Id" />
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Chọn ngày xem báo cáo</label>
                        <div class="input-group">
                            <span class="input-group-text border-0 bg-light"><i class="bi bi-funnel"></i></span>
                            <input type="date" name="date" class="form-control form-control-lg border-0 bg-light" 
                                   value="@Model.Date.ToString("yyyy-MM-dd")" onchange="this.form.submit()" />
                        </div>
                    </div>
                    <div class="col-md-auto ms-auto">
                        <div class="d-flex gap-4 text-center">
                            <div>
                                <div class="h4 fw-bold mb-0 text-success">@Model.Attendances.Count(a => a.IsPresent)</div>
                                <div class="small text-muted text-uppercase" style="font-size: 0.65rem;">Có mặt</div>
                            </div>
                            <div class="vr"></div>
                            <div>
                                <div class="h4 fw-bold mb-0 text-danger">@Model.Attendances.Count(a => !a.IsPresent)</div>
                                <div class="small text-muted text-uppercase" style="font-size: 0.65rem;">Vắng mặt</div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="res-card shadow-sm border-0 overflow-hidden">
                <div class="res-card-header">
                    <i class="bi bi-clipboard-data me-2"></i>DỮ LIỆU NGÀY @Model.Date.ToString("dd/MM/yyyy")
                </div>
                <div class="card-body p-0">
                    @if (Model.Attendances.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light text-muted">
                                    <tr>
                                        <th class="ps-4">Học viên</th>
                                        <th>Thời gian</th>
                                        <th>Trạng thái</th>
                                        <th class="pe-4">Ghi chú</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Attendances)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-dark">@item.StudentName</div>
                                            </td>
                                            <td>
                                                <i class="bi bi-clock-history me-1"></i> @item.Date.ToString("dd/MM/yyyy")
                                            </td>
                                            <td>
                                                @if (item.IsPresent)
                                                {
                                                    <span class="badge rounded-pill bg-success-subtle text-success px-3 py-2">
                                                        <i class="bi bi-check-circle me-1"></i>CÓ MẶT
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill bg-danger-subtle text-danger px-3 py-2">
                                                        <i class="bi bi-x-circle me-1"></i>VẮNG MẶT
                                                    </span>
                                                }
                                            </td>
                                            <td class="pe-4">
                                                <span class="text-muted small">@(string.IsNullOrWhiteSpace(item.Note) ? "-" : item.Note)</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-folder-x text-muted opacity-25 display-4 d-block mb-3"></i>
                            <p class="text-muted">Không có dữ liệu điểm danh cho ngày này.</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>
