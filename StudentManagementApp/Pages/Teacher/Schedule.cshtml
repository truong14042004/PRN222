@page
@model StudentManagementApp.Pages.Teacher.ScheduleModel
@{
    ViewData["Title"] = "Lịch dạy";
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">English Center</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/Teacher">Lớp dạy</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Teacher/Schedule">Lịch dạy</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Quizzes">Quiz</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Xin chào, @userName</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Auth/Logout">Đăng xuất</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h1>Lịch dạy tuần</h1>
        
        <div class="mb-3">
            <a href="/Teacher/Schedule?date=@Model.PreviousWeek.ToString("yyyy-MM-dd")" class="btn btn-secondary">Tuần trước</a>
            <span class="mx-3">@Model.WeekStart.ToString("dd/MM/yyyy") - @Model.WeekEnd.ToString("dd/MM/yyyy")</span>
            <a href="/Teacher/Schedule?date=@Model.NextWeek.ToString("yyyy-MM-dd")" class="btn btn-secondary">Tuần sau</a>
        </div>

        @if (Model.Classes.Any())
        {
            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Thứ</th>
                        <th>Ca dạy</th>
                        <th>Lớp</th>
                        <th>Khóa học</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in Model.WeekDays)
                    {
                        var sessions = Model.Sessions.Where(s => s.DayOfWeek == day.DayOfWeek).ToList();
                        <tr>
                            <td>@day.DayName<br>@day.Date.ToString("dd/MM")</td>
                            <td>
                                @if (sessions.Any())
                                {
                                    @foreach (var s in sessions)
                                    {
                                        <div class="mb-2 p-2 bg-light rounded">
                                            <strong>@s.StartTime - @s.EndTime</strong>
                                            <br>@s.ClassName
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Không có lịch</span>
                                }
                            </td>
                            <td>
                                @if (sessions.Any())
                                {
                                    @string.Join(", ", sessions.Select(s => s.ClassName).Distinct())
                                }
                            </td>
                            <td>
                                @if (sessions.Any())
                                {
                                    @string.Join(", ", sessions.Select(s => s.CourseName).Distinct())
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Bạn chưa có lớp dạy nào trong tuần này.</p>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
