@page
@model StudentManagementApp.Pages.Student.IndexModel
@{
    ViewData["Title"] = "Dashboard Học viên";
}

<section class="py-5 bg-light min-vh-100">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h6 class="text-res-red fw-bold text-uppercase mb-1">Học viên</h6>
                <h2 class="fw-bold mb-0">CHÀO MỪNG QUAY TRỞ LẠI!</h2>
            </div>
            <div class="text-end">
                <div class="small text-muted mb-1 text-uppercase fw-bold">Số dư ví của bạn</div>
                <div class="h3 fw-bold text-res-red mb-0">@Model.WalletBalance.ToString("N0") VNĐ</div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="res-card bg-res-red text-white p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-white-50 text-uppercase fw-bold">Khóa học đăng ký</div>
                            <div class="display-5 fw-bold">@Model.Enrollments.Count()</div>
                        </div>
                        <i class="bi bi-journal-check h1 mb-0 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="res-card p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase fw-bold">Số buổi vắng</div>
                            <div class="display-5 fw-bold text-res-red">0</div>
                        </div>
                        <i class="bi bi-calendar-x h1 mb-0 text-res-red opacity-25"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="res-card p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase fw-bold">Kết quả Quiz gần nhất</div>
                            <div class="display-5 fw-bold text-success">N/A</div>
                        </div>
                        <i class="bi bi-trophy h1 mb-0 text-success opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="res-card overflow-hidden">
            <div class="res-card-header d-flex justify-content-between align-items-center">
                <span>📚 KHÓA HỌC CỦA TÔI</span>
                <a href="/Course" class="btn btn-outline-res btn-sm">ĐĂNG KÝ THÊM</a>
            </div>
            <div class="card-body p-0">
                @if (Model.Enrollments != null && Model.Enrollments.Any())
                {
                    <div class="table-responsive">
                        <table class="table res-table mb-0">
                            <thead>
                                <tr>
                                    <th>Tên lớp</th>
                                    <th>Khóa học</th>
                                    <th>Ngày đăng ký</th>
                                    <th>Trạng thái</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var enrollment in Model.Enrollments)
                                {
                                    <tr>
                                        <td class="fw-bold">@enrollment.ClassName</td>
                                        <td>@enrollment.CourseName</td>
                                        <td class="text-muted">@enrollment.EnrolledAt.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <span class="badge-res @(enrollment.Status == "Confirmed" ? "badge-paid" : "badge-pending")">
                                                @enrollment.Status
                                            </span>
                                        </td>
                                        <td>
                                            <div class="dropdown">
                                                <button class="btn btn-light btn-sm rounded-circle" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                                                    <li><a class="dropdown-item" href="#"><i class="bi bi-eye me-2"></i> Chi tiết</a></li>
                                                    <li><a class="dropdown-item" href="#student-schedule"><i class="bi bi-calendar-event me-2"></i> Xem lịch học</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-x-circle me-2"></i> Hủy đăng ký</a></li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-5 text-center">
                        <i class="bi bi-inbox text-muted display-4 mb-3"></i>
                        <h5 class="text-muted">Bạn chưa đăng ký khóa học nào.</h5>
                        <p class="small text-muted">Bắt đầu hành trình học tập bằng cách chọn một khóa học phù hợp!</p>
                        <a href="/Course" class="btn btn-primary-res mt-2">XEM DANH SÁCH KHÓA HỌC</a>
                    </div>
                }
            </div>
        </div>

        <div id="student-schedule" class="mt-5 mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0"><i class="bi bi-calendar3 text-res-red me-2"></i>LỊCH HỌC TRONG TUẦN</h4>
                <div class="d-flex gap-2">
                    <a href="/Student?date=@Model.PreviousWeek.ToString("yyyy-MM-dd")" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm border">
                        <i class="bi bi-chevron-left"></i> Tuần trước
                    </a>
                    <div class="bg-white border rounded-pill px-4 py-1 small fw-bold d-flex align-items-center shadow-sm">
                        @Model.WeekStart.ToString("dd/MM") — @Model.WeekEnd.ToString("dd/MM/yyyy")
                    </div>
                    <a href="/Student?date=@Model.NextWeek.ToString("yyyy-MM-dd")" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm border">
                        Tuần sau <i class="bi bi-chevron-right"></i>
                    </a>
                </div>
            </div>

            <div class="res-card overflow-hidden">
                <div class="table-responsive">
                    <table class="table mb-0 border-0">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 120px;" class="border-0 py-3 ps-4 text-muted small text-uppercase fw-bold">Ngày học</th>
                                <th class="border-0 py-3 small text-uppercase fw-bold text-muted">Ca học chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var day in Model.WeekDays)
                            {
                                var sessions = Model.Sessions.Where(s => s.DayOfWeek == day.DayOfWeek).ToList();
                                var isToday = day.Date == DateOnly.FromDateTime(DateTime.Today);
                                <tr>
                                    <td class="ps-4 py-4 border-end @(isToday ? "bg-res-red-light" : "")">
                                        <div class="small fw-bold @(isToday ? "text-res-red" : "text-muted")">@day.DayName.ToUpper()</div>
                                        <div class="h5 fw-bold mb-0 @(isToday ? "text-res-red" : "")">@day.Date.ToString("dd/MM")</div>
                                        @if (isToday)
                                        {
                                            <span class="badge bg-res-red mt-1" style="font-size: 0.6rem;">HÔM NAY</span>
                                        }
                                    </td>
                                    <td class="py-4 pe-4">
                                        <div class="d-flex flex-wrap gap-3">
                                            @if (sessions.Any())
                                            {
                                                foreach (var s in sessions)
                                                {
                                                    <div class="p-3 border rounded-4 bg-white shadow-sm" style="min-width: 220px; border-left: 4px solid var(--res-red) !important;">
                                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                                            <span class="badge bg-res-red-light text-res-red rounded-pill px-2 py-1" style="font-size: 0.7rem;">
                                                                <i class="bi bi-clock me-1"></i> @s.StartTime – @s.EndTime
                                                            </span>
                                                        </div>
                                                        <div class="fw-bold text-dark mb-1">@s.ClassName</div>
                                                        <div class="small text-muted">@s.CourseName</div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="py-2 text-muted small italic text-opacity-50">Không có lịch học</div>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .bg-res-red-light { background-color: rgba(232, 65, 42, 0.05); }
    .border-res-red { border-color: var(--res-red) !important; }
    .line-clamp-1 { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
</style>
