@page
@model StudentManagementApp.Pages.Course.IndexModel
@{
    ViewData["Title"] = "Khóa học";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">English Center</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/Auth/Login">Đăng nhập</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h1>Danh sách khóa học</h1>
        
        <div class="row">
            @if (Model.Courses != null && Model.Courses.Any())
            {
                @foreach (var course in Model.Courses)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@course.Name</h5>
                                <span class="badge bg-info">@course.Level</span>
                                <p class="card-text">@course.Description</p>
                                <p class="card-text"><strong>Học phí:</strong> @course.TuitionFee.ToString("N0") VNĐ</p>
                            </div>
                            <div class="card-footer">
                                <a href="/Course/Detail/@course.Id" class="btn btn-primary">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <p class="text-muted">Không có khóa học nào.</p>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
