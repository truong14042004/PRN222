@page
@model StudentManagementApp.Pages.Student.IndexModel
@{
    ViewData["Title"] = "Dashboard Học viên";
}

<style>
    .dashboard-nav-tabs {
        border: none;
        gap: 10px;
    }
    .dashboard-nav-tabs .nav-link {
        border: none;
        border-radius: 12px;
        padding: 12px 24px;
        font-weight: 700;
        color: #777;
        transition: all 0.3s ease;
        background: transparent;
    }
    .dashboard-nav-tabs .nav-link.active {
        background: var(--res-red) !important;
        color: white !important;
        box-shadow: 0 5px 15px rgba(220, 52, 59, 0.2);
    }
    .dashboard-nav-tabs .nav-link:hover:not(.active) {
        background: #eee;
    }
    
    /* Attendance specific styles */
    .att-day-box {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
    }
    .att-day-present { background: #ecfdf5; color: #059669; border: 1px solid #10b981; }
    .att-day-absent { background: #fef2f2; color: #ef4444; border: 1px solid #f87171; }
    .att-day-future { background: #f9fafb; color: #9ca3af; border: 1px solid #e5e7eb; }
</style>

<section class="py-5 bg-light min-vh-100">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h6 class="text-res-red fw-bold text-uppercase mb-1">Cổng thông tin học viên</h6>
                <h2 class="fw-bold mb-0">TRUNG TÂM CỦA BẠN</h2>
            </div>
            <div class="text-end">
                <div class="small text-muted mb-1 text-uppercase fw-bold">Số dư ví</div>
                <div class="h3 fw-bold text-res-red mb-0">@Model.WalletBalance.ToString("N0") VNĐ</div>
            </div>
        </div>

        <ul class="nav dashboard-nav-tabs mb-5" role="tablist">
            <li class="nav-item">
                <a class="nav-link @(Model.ActiveTab == "overview" ? "active" : "")" href="/Student?tab=overview">
                    <i class="bi bi-grid-1x2 me-2"></i>TỔNG QUAN
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.ActiveTab == "attendance" ? "active" : "")" href="/Student?tab=attendance">
                    <i class="bi bi-calendar-check me-2"></i>ĐIỂM DANH
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.ActiveTab == "quizzes" ? "active" : "")" href="/Student?tab=quizzes">
                    <i class="bi bi-pencil-square me-2"></i>BÀI KIỂM TRA
                </a>
            </li>
        </ul>

        <div class="tab-content">
            @if (Model.ActiveTab == "overview")
            {
                <div class="tab-pane fade show active">
                    <div class="row g-4 mb-5">
                        <div class="col-md-4">
                            <div class="res-card bg-res-red text-white p-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="small text-white-50 text-uppercase fw-bold">Khóa học đăng ký</div>
                                        <div class="display-5 fw-bold">@Model.Enrollments.Count()</div>
                                    </div>
                                    <i class="bi bi-journal-check h1 mb-0 opacity-50"></i>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="res-card p-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="small text-muted text-uppercase fw-bold">Trình độ</div>
                                        <div class="h3 fw-bold text-dark mt-2">@(Model.Enrollments.FirstOrDefault()?.CourseName ?? "Chưa rõ")</div>
                                    </div>
                                    <i class="bi bi-bar-chart h1 mb-0 text-res-red opacity-25"></i>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="res-card p-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="small text-muted text-uppercase fw-bold">Tiến độ tổng quát</div>
                                        <div class="h3 fw-bold text-success mt-2">75%</div>
                                    </div>
                                    <i class="bi bi-activity h1 mb-0 text-success opacity-25"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="res-card shadow-sm mb-5">
                        <div class="res-card-header d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-collection me-2"></i>KHÓA HỌC ĐANG HỌC</span>
                            <a href="/Course" class="btn btn-outline-res btn-sm px-3">ĐĂNG KÝ THÊM</a>
                        </div>
                        <div class="card-body p-0">
                            @if (Model.Enrollments.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table align-middle mb-0">
                                        <thead class="bg-light">
                                            <tr>
                                                <th class="ps-4">Tên lớp</th>
                                                <th>Khóa học</th>
                                                <th>Ngày đăng ký</th>
                                                <th>Trạng thái</th>
                                                <th class="text-end pe-4">Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var enrollment in Model.Enrollments)
                                            {
                                                <tr>
                                                    <td class="ps-4">
                                                        <div class="fw-bold">@enrollment.ClassName</div>
                                                        <div class="small text-muted">ID: #@enrollment.Id</div>
                                                    </td>
                                                    <td>@enrollment.CourseName</td>
                                                    <td class="text-muted">@enrollment.EnrolledAt.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        <span class="badge-res @(enrollment.Status == "Confirmed" ? "badge-paid" : "badge-pending")">
                                                            @(enrollment.Status == "Confirmed" ? "Đã xác nhận" : "Chờ xác nhận")
                                                        </span>
                                                    </td>
                                                    <td class="text-end pe-4">
                                                        <a href="/Student?tab=attendance&classId=@enrollment.ClassId" class="btn btn-light btn-sm px-3 fw-bold text-muted border shadow-sm">
                                                            CHI TIẾT
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mt-5">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0"><i class="bi bi-calendar3 text-res-red me-2"></i>LỊCH HỌC TUẦN NÀY</h4>
                            <div class="d-flex gap-2">
                                <a href="/Student?tab=overview&date=@Model.PreviousWeek.ToString("yyyy-MM-dd")" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm border">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                                <div class="bg-white border rounded-pill px-4 py-1 small fw-bold d-flex align-items-center">
                                    @Model.WeekStart.ToString("dd/MM") — @Model.WeekEnd.ToString("dd/MM")
                                </div>
                                <a href="/Student?tab=overview&date=@Model.NextWeek.ToString("yyyy-MM-dd")" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm border">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </div>
                        </div>

                        <div class="res-card overflow-hidden border-0 shadow-sm">
                            <div class="table-responsive">
                                <table class="table mb-0 border-0">
                                    <thead class="bg-light text-muted">
                                        <tr>
                                            <th style="width: 140px;" class="ps-4 py-3 small text-uppercase">Ngày học</th>
                                            <th class="py-3 small text-uppercase">Ca học chi tiết</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var day in Model.WeekDays)
                                        {
                                            var sessions = Model.Sessions.Where(s => s.DayOfWeek == day.DayOfWeek).ToList();
                                            var isToday = day.Date == DateOnly.FromDateTime(DateTime.Today);
                                            <tr>
                                                <td class="ps-4 py-4 @(isToday ? "bg-res-red-light" : "")">
                                                    <div class="small fw-bold @(isToday ? "text-res-red" : "text-muted")">@day.DayName</div>
                                                    <div class="h5 fw-bold mb-0">@day.Date.ToString("dd/MM")</div>
                                                </td>
                                                <td class="py-4 @(isToday ? "bg-res-red-light" : "")">
                                                    <div class="d-flex flex-wrap gap-3">
                                                        @if (sessions.Any())
                                                        {
                                                            foreach (var s in sessions)
                                                            {
                                                                <div class="p-3 border rounded-3 bg-white shadow-sm" style="min-width: 200px; border-left: 3px solid var(--res-red) !important;">
                                                                    <div class="small text-res-red fw-bold mb-1">
                                                                        <i class="bi bi-clock me-1"></i> @s.StartTime – @s.EndTime
                                                                    </div>
                                                                    <div class="fw-bold small">@s.ClassName</div>
                                                                </div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small italic opacity-50">Nghỉ</span>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (Model.ActiveTab == "attendance")
            {
                <div class="tab-pane fade show active">
                    <div class="row g-4">
                        <div class="col-lg-4">
                            <div class="res-card p-4 shadow-sm border-0 mb-4 sticky-top" style="top: 100px;">
                                <h6 class="fw-bold mb-4">CHỌN LỚP HỌC</h6>
                                <div class="list-group list-group-flush gap-2">
                                    @foreach (var e in Model.Enrollments.Where(e => e.Status == "Confirmed"))
                                    {
                                        <a href="/Student?tab=attendance&classId=@e.ClassId" 
                                           class="list-group-item list-group-item-action border rounded-3 py-3 @(Model.SelectedClassId == e.ClassId ? "bg-res-red text-white" : "")">
                                            <div class="fw-bold">@e.ClassName</div>
                                            <div class="small @(Model.SelectedClassId == e.ClassId ? "text-white-50" : "text-muted")">@e.CourseName</div>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-8">
                            @if (Model.SelectedClass != null)
                            {
                                <div class="res-card p-4 shadow-sm border-0 mb-4">
                                    <div class="row align-items-center">
                                        <div class="col-md-6 border-end">
                                            <h4 class="fw-bold mb-1">@Model.SelectedClass.ClassName</h4>
                                            <p class="text-muted mb-0">Học từ @Model.SelectedClass.StartDate.ToString("dd/MM/yyyy")</p>
                                        </div>
                                        <div class="col-md-6 ps-md-4 mt-3 mt-md-0">
                                            <div class="d-flex gap-4">
                                                <div>
                                                    <div class="h3 fw-bold text-success mb-0">@Model.PresentCount</div>
                                                    <div class="small text-muted text-uppercase">Có mặt</div>
                                                </div>
                                                <div class="vr"></div>
                                                <div>
                                                    <div class="h3 fw-bold text-res-red mb-0">@(Model.PastSessions - Model.PresentCount)</div>
                                                    <div class="small text-muted text-uppercase">Vắng</div>
                                                </div>
                                                <div class="vr"></div>
                                                <div>
                                                    <div class="h3 fw-bold text-dark mb-0">@Model.AllSessions.Count</div>
                                                    <div class="small text-muted text-uppercase">Tổng buổi</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="res-card shadow-sm border-0">
                                    <div class="res-card-header">LỊCH SỬ CHI TIẾT</div>
                                    <div class="card-body p-4">
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var date in Model.AllSessions)
                                            {
                                                var att = Model.AttByDate.ContainsKey(date) ? Model.AttByDate[date] : null;
                                                var stateClass = att != null ? (att.IsPresent ? "att-day-present" : "att-day-absent") : (date < DateOnly.FromDateTime(DateTime.Today) ? "att-day-absent" : "att-day-future");
                                                var tooltip = $"{date:dd/MM/yyyy}: {(att != null ? (att.IsPresent ? "Có mặt" : "Vắng") : (date < DateOnly.FromDateTime(DateTime.Today) ? "Vắng (không ghi nhận)" : "Chưa tới"))}";
                                                
                                                <div class="att-day-box @stateClass" title="@tooltip" data-bs-toggle="tooltip">
                                                    @date.Day
                                                </div>
                                            }
                                        </div>
                                        <div class="mt-4 pt-4 border-top">
                                            <h6 class="fw-bold mb-3 small text-muted">CHÚ THÍCH:</h6>
                                            <div class="d-flex gap-4 small">
                                                <span class="d-flex align-items-center gap-2"><div class="att-day-box att-day-present" style="width: 15px; height: 15px;"></div> Có mặt</span>
                                                <span class="d-flex align-items-center gap-2"><div class="att-day-box att-day-absent" style="width: 15px; height: 15px;"></div> Vắng</span>
                                                <span class="d-flex align-items-center gap-2"><div class="att-day-box att-day-future" style="width: 15px; height: 15px;"></div> Tương lai</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <i class="bi bi-calendar-range display-3 text-muted opacity-25"></i>
                                    <p class="text-muted mt-3">Chọn một lớp học để xem chi tiết điểm danh.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (Model.ActiveTab == "quizzes")
            {
                <div class="tab-pane fade show active">
                    <div class="row g-4 mb-5">
                        @foreach (var prog in Model.CourseQuizProgresses)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="res-card p-4 border-0 shadow-sm">
                                    <div class="d-flex justify-content-between mb-3">
                                        <h6 class="fw-bold mb-0 text-truncate">@prog.CourseName</h6>
                                        <span class="badge bg-res-red-light text-res-red">@prog.Percentage%</span>
                                    </div>
                                    <div class="progress mb-2" style="height: 6px;">
                                        <div class="progress-bar bg-res-red" style="width: @prog.Percentage%"></div>
                                    </div>
                                    <div class="small text-muted">Hoàn thành @prog.CompletedQuizCount/@prog.TotalQuizCount bài quiz</div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="res-card shadow-sm border-0">
                        <div class="res-card-header">BÀI KIỂM TRA SẴN CÓ</div>
                        <div class="card-body p-0">
                            @if (Model.Quizzes.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table align-middle mb-0">
                                        <thead class="bg-light">
                                            <tr>
                                                <th class="ps-4">Tên bài Quiz</th>
                                                <th>Môn học</th>
                                                <th>Thời gian</th>
                                                <th class="text-end pe-4">Trạng thái</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var quiz in Model.Quizzes)
                                            {
                                                var result = Model.Results.FirstOrDefault(r => r.QuizId == quiz.Id);
                                                <tr>
                                                    <td class="ps-4">
                                                        <div class="fw-bold">@quiz.Title</div>
                                                    </td>
                                                    <td>@quiz.CourseName</td>
                                                    <td>@quiz.TimeLimitMinutes phút</td>
                                                    <td class="text-end pe-4">
                                                        @if (result != null)
                                                        {
                                                            <div class="d-flex flex-column align-items-end">
                                                                <span class="badge bg-success-subtle text-success mb-1">@result.Score/@quiz.TotalPoints điểm</span>
                                                                <a href="/Student/QuizResult?resultId=@result.Id" class="small text-muted text-decoration-none">Xem lại <i class="bi bi-chevron-right"></i></a>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <a href="/Student/TakeQuiz?quizId=@quiz.Id" class="btn btn-primary-res btn-sm px-4">LÀM BÀI</a>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5 text-muted">Không có bài kiểm tra nào hiện tại.</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    .bg-res-red-light { background-color: rgba(220, 52, 59, 0.05); }
    .border-res-red { border-color: var(--res-red) !important; }
</style>

@section Scripts {
    <script>
        // Initialize tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
          return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}
