@page
@model StudentManagementApp.Pages.Auth.RegisterModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký thành viên";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/res-style.css">
    <style>
        body {
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, #fdf8f0 0%, #ffffff 100%);
            padding: 20px;
        }
        .auth-card {
            width: 100%;
            max-width: 1000px;
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0,0,0,0.1);
        }
        .auth-intro {
            background-color: var(--res-red);
            color: white;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .auth-form-side {
            background: white;
            padding: 3rem;
        }
        @@media (max-width: 992px) {
            .auth-card { grid-template-columns: 1fr; }
            .auth-intro { display: none; }
        }
    </style>
</head>
<body class="form-res">
    <div class="auth-card">
        <div class="auth-intro">
            <div>
                <img src="/images/logo.jpg" alt="Logo" class="footer-logo brightness-0 invert mb-4" style="height: 50px; width: auto;">
                <h2 class="fw-bold h1">Gia nhập cộng đồng English Center</h2>
                <p class="mt-3 opacity-75">Bắt đầu hành trình chinh phục tiếng Anh cùng hàng nghìn học viên khác tại trung tâm uy tín bậc nhất.</p>
                <ul class="list-unstyled mt-5 small">
                    <li class="mb-3 d-flex align-items-center"><i class="bi bi-check-circle-fill me-2"></i> Tiếp cận giáo trình quốc tế</li>
                    <li class="mb-3 d-flex align-items-center"><i class="bi bi-check-circle-fill me-2"></i> Lịch học linh hoạt, dễ dàng theo dõi</li>
                    <li class="mb-3 d-flex align-items-center"><i class="bi bi-check-circle-fill me-2"></i> Hệ thống hỗ trợ học tập 24/7</li>
                </ul>
            </div>
            <div class="mt-4">
                <a href="/" class="btn btn-outline-light rounded-pill px-4">
                    <i class="bi bi-house-door me-1"></i> Về trang chủ
                </a>
            </div>
        </div>
        <div class="auth-form-side">
            <div class="mb-4 text-center d-lg-none">
                <img src="/images/logo.jpg" alt="Logo" style="height: 40px;">
            </div>
            <h3 class="fw-bold mb-1">Đăng ký tài khoản</h3>
            <p class="text-muted small mb-4">Hoàn thành thông tin bên dưới để bắt đầu.</p>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success border-0 border-start border-success border-4 small">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                </div>
            }
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
            {
                <div class="alert alert-danger border-0 border-start border-danger border-4 small">
                    @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                    {
                        <div><i class="bi bi-exclamation-triangle-fill me-2"></i> @error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-bold">Họ và tên</label>
                        <input type="text" class="form-control" asp-for="FullName" placeholder="Nguyễn Văn A" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Email</label>
                        <input type="email" class="form-control" asp-for="Email" placeholder="an@example.com" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Tên đăng nhập</label>
                        <input type="text" class="form-control" asp-for="Username" placeholder="your_id" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Số điện thoại</label>
                        <input type="text" class="form-control" asp-for="Phone" placeholder="09xxxxxxxx">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Mật khẩu</label>
                        <input type="password" class="form-control" asp-for="Password" placeholder="••••••••" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">Xác nhận mật khẩu</label>
                        <input type="password" class="form-control" asp-for="ConfirmPassword" placeholder="••••••••" required>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary-res w-100 py-3 rounded-pill shadow">GỬI MÃ XÁC THỰC OTP</button>
                    <p class="text-center small text-muted mt-2">Mã OTP sẽ được gửi về Email của bạn.</p>
                </div>
            </form>

            <div class="mt-4 text-center small text-muted">
                Bạn đã có tài khoản? 
                <a href="/Auth/Login" class="text-res-red fw-bold text-decoration-none">Đăng nhập ngay</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
