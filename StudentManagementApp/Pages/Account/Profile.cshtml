@page
@model StudentManagementApp.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<style>
    .profile-sidebar {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .profile-header-bg {
        height: 100px;
        background: linear-gradient(135deg, var(--res-red) 0%, var(--res-red-dark) 100%);
    }

    .profile-avatar-wrapper {
        margin-top: -50px;
        padding: 0 20px;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        border: 4px solid white;
        border-radius: 50%;
        object-fit: cover;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .profile-nav .nav-link {
        color: #666;
        padding: 12px 20px;
        border-radius: 10px;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.2s;
    }

    .profile-nav .nav-link:hover {
        background: #f8f9fa;
        color: var(--res-red);
    }

    .profile-nav .nav-link.active {
        background: var(--res-red-light);
        color: var(--res-red);
        font-weight: 700;
    }

    .form-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #f0f0f0;
    }

    .form-group-title {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #333;
    }

    .wallet-badge {
        background: #fff8f0;
        border: 1px solid #ffe8cc;
        color: #e67e22;
        padding: 10px 20px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
</style>

<section class="py-5 bg-light min-vh-100">
    <div class="container py-4">
        <div class="row g-4">
            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="profile-sidebar mb-4">
                    <div class="profile-header-bg"></div>
                    <div class="profile-avatar-wrapper text-center">
                        <img src="@(string.IsNullOrEmpty(Model.CurrentUser?.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Model.CurrentUser?.FullName + "&background=DC343B&color=fff&size=200" : Model.CurrentUser.AvatarUrl)" 
                             class="profile-avatar" alt="Avatar">
                        <h5 class="fw-bold mt-3 mb-1">@Model.CurrentUser?.FullName</h5>
                        <p class="text-muted small">@Model.CurrentUser?.Email</p>
                    </div>

                    <div class="p-4 pt-2">
                        <div class="wallet-badge mb-4">
                            <i class="bi bi-wallet2 fs-4"></i>
                            <div>
                                <div class="small fw-bold">Số dư ví</div>
                                <div class="h5 mb-0 fw-bold">@Model.CurrentUser?.WalletBalance.ToString("N0") đ</div>
                            </div>
                        </div>

                        <div class="profile-nav">
                            <a href="#" class="nav-link active"><i class="bi bi-person-circle"></i> Thông tin cá nhân</a>
                            @if (Model.CurrentUser?.Role == "Student") {
                                <a href="/Student/Orders" class="nav-link"><i class="bi bi-bag-check"></i> Lịch sử mua hàng</a>
                            }
                            <a href="/Auth/Logout" class="nav-link text-danger"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a>
                        </div>
                    </div>
                </div>

                <div class="form-card text-center bg-white">
                    <p class="small text-muted mb-3">Tham gia từ: <strong>@Model.CurrentUser?.CreatedAt.ToString("dd/MM/yyyy")</strong></p>
                    <div class="d-grid">
                        <button class="btn btn-outline-danger btn-sm rounded-pill py-2">VÔ HIỆU HÓA TÀI KHOẢN</button>
                    </div>
                </div>
            </div>

            <!-- Content Area -->
            <div class="col-lg-8">
                @if (TempData["Success"] != null) {
                    <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center">
                        <i class="bi bi-check-circle-fill me-3 fs-4"></i> @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null) {
                    <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center">
                        <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i> @TempData["Error"]
                    </div>
                }

                <div class="form-card mb-4">
                    <div class="form-group-title">
                        <i class="bi bi-person-lines-fill text-res-red"></i> CẬP NHẬT THÔNG TIN
                    </div>
                    <form method="post" asp-page-handler="Profile" class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Họ và tên</label>
                            <input asp-for="Input.FullName" class="form-control form-control-lg border-0 bg-light" placeholder="Nhập họ tên đầy đủ">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Số điện thoại</label>
                            <input asp-for="Input.Phone" class="form-control form-control-lg border-0 bg-light" placeholder="090xxxxxxx">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase">Avatar URL</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-light text-muted"><i class="bi bi-image"></i></span>
                                <input asp-for="Input.AvatarUrl" class="form-control form-control-lg border-0 bg-light" placeholder="https://example.com/image.jpg">
                            </div>
                        </div>
                        <div class="col-12 mt-5 text-end">
                            <button type="submit" class="btn btn-primary-res px-5 py-3">CẬP NHẬT HỒ SƠ</button>
                        </div>
                    </form>
                </div>

                <div class="form-card">
                    <div class="form-group-title">
                        <i class="bi bi-shield-lock-fill text-res-red"></i> ĐỔI MẬT KHẨU
                    </div>
                    <form method="post" asp-page-handler="Password" class="row g-4">
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase">Mật khẩu hiện tại</label>
                            <input type="password" name="currentPassword" class="form-control form-control-lg border-0 bg-light" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Mật khẩu mới</label>
                            <input type="password" name="newPassword" class="form-control form-control-lg border-0 bg-light" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Xác nhận mật khẩu</label>
                            <input type="password" name="confirmPassword" class="form-control form-control-lg border-0 bg-light" required>
                        </div>
                        <div class="col-12 mt-5 text-end">
                            <button type="submit" class="btn btn-outline-res px-5 py-3">LƯU MẬT KHẨU MỚI</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

