@page
@model StudentManagementApp.Pages.Admin.QuizEditModel
@{
    ViewData["Title"] = Model.IsEdit ? "Sửa quiz" : "Tạo quiz";
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                font-family: "Be Vietnam Pro", sans-serif;
                background: #f5f7fb;
                margin: 0;
            }

            /* SIDEBAR */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                background: #0f172a;
                color: white;
                padding: 20px;
            }

                .sidebar h4 {
                    font-weight: 700;
                    margin-bottom: 30px;
                }

                .sidebar a {
                    display: block;
                    color: #cbd5f1;
                    padding: 10px 12px;
                    border-radius: 10px;
                    text-decoration: none;
                    margin-bottom: 8px;
                }

                    .sidebar a:hover,
                    .sidebar a.active {
                        background: #1e293b;
                        color: #fff;
                    }

            /* MAIN */
            .main {
                margin-left: 250px;
                padding: 20px 30px;
            }

            /* CARD */
            .card-box {
                background: #fff;
                border-radius: 16px;
                padding: 24px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            }

            .section-title {
                font-weight: 700;
                margin-bottom: 6px;
            }

            .hint {
                font-size: 0.85rem;
                color: #64748b;
            }

            .btn-green {
                background: linear-gradient(135deg, #22c55e, #16a34a);
                border: none;
                color: white;
                font-weight: 600;
            }

                .btn-green:hover {
                    filter: brightness(0.95);
                }

            /* TOP HEADER */
            .page-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 20px;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>🎓 Admin</h4>

        <a href="/Admin">Dashboard</a>
        <a href="/Admin/Users">Người dùng</a>
        <a href="/Admin/Courses">Khóa học</a>
        <a href="/Admin/Classes">Lớp học</a>
        <a href="/Admin/Enrollments">Đăng ký</a>
        <a class="active" href="/Admin/Quizzes">Quiz</a>

        <hr style="border-color:#334155">

        <a href="/Auth/Logout">🚪 Đăng xuất</a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <!-- HEADER -->
        <div class="page-header">
            <div>
                <h3 class="mb-0">
                    @(Model.IsEdit ? "Sửa quiz" : "Tạo quiz mới")
                </h3>
                <small class="text-muted">Thiết lập bài kiểm tra</small>
            </div>

            <a href="/Admin/Quizzes" class="btn btn-outline-secondary">← Quay lại</a>
        </div>

        <!-- FORM -->
        <div class="card-box">

            <form method="post">
                <input type="hidden" asp-for="Input.Id" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">

                    <!-- COURSE -->
                    <div class="col-md-6">
                        <label class="form-label section-title">Khóa học</label>
                        <select asp-for="Input.CourseId" class="form-select">
                            <option value="">-- Chọn khóa học --</option>
                            @foreach (var course in Model.AvailableCourses)
                            {
                                <option value="@course.Id">
                                    @course.Name (@course.Level)
                                </option>
                            }
                        </select>
                    </div>

                    <!-- TIME -->
                    <div class="col-md-6">
                        <label class="form-label section-title">Thời gian (phút)</label>
                        <input asp-for="Input.TimeLimitMinutes" type="number" min="1" class="form-control" />
                        <div class="hint">Khuyến nghị: 20 - 60 phút</div>
                    </div>

                    <!-- START -->
                    <div class="col-md-6">
                        <label class="form-label section-title">Bắt đầu</label>
                        <input asp-for="Input.StartAt" type="datetime-local" class="form-control" />
                        <div class="hint">Để trống = mở ngay</div>
                    </div>

                    <!-- END -->
                    <div class="col-md-6">
                        <label class="form-label section-title">Kết thúc</label>
                        <input asp-for="Input.EndAt" type="datetime-local" class="form-control" />
                    </div>

                    <!-- TITLE -->
                    <div class="col-12">
                        <label class="form-label section-title">Tiêu đề</label>
                        <input asp-for="Input.Title" class="form-control" />
                    </div>

                    <!-- DESC -->
                    <div class="col-12">
                        <label class="form-label section-title">Mô tả</label>
                        <textarea asp-for="Input.Description" rows="4" class="form-control"></textarea>
                    </div>

                    <!-- ACTIVE -->
                    <div class="col-12 form-check form-switch ms-2">
                        <input asp-for="Input.IsActive" class="form-check-input" />
                        <label class="form-check-label">Kích hoạt ngay</label>
                    </div>

                </div>

                <!-- ACTION -->
                <div class="mt-4 d-flex gap-2">
                    <a href="/Admin/Quizzes" class="btn btn-outline-secondary">Hủy</a>
                    <button type="submit" class="btn btn-green">
                        @(Model.IsEdit ? "Lưu thay đổi" : "Tạo quiz")
                    </button>
                </div>

            </form>

        </div>

    </div>

</body>
</html>