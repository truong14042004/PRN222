@page
@model StudentManagementApp.Pages.Admin.Users.CreateTeacherModel
@{
    ViewData["Title"] = "Tạo giáo viên mới";
    ViewData["ActivePage"] = "Users";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var userName = HttpContext.Session.GetString("UserName");
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Quản lý nhân sự</h6>
        <h2 class="fw-bold mb-0">Tạo tài khoản Giáo viên</h2>
    </div>
    <a href="/Admin/Users?tab=teachers" class="btn btn-light border fw-bold px-4">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="admin-card">
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
            {
                <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
                    @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                    {
                        <div><i class="bi bi-exclamation-triangle-fill me-2"></i>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Họ và tên</label>
                        <input type="text" class="form-control fw-bold" name="fullName" placeholder="Nhập họ và tên giáo viên..." required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Email công việc</label>
                        <input type="email" class="form-control" name="email" placeholder="teacher@mesh.edu.vn" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Tên đăng nhập</label>
                        <input type="text" class="form-control" name="username" placeholder="Nhập username..." required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Số điện thoại</label>
                        <input type="text" class="form-control" name="phone" placeholder="Nhập số điện thoại...">
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold small text-muted text-uppercase">Mật khẩu khởi tạo</label>
                        <div class="input-group">
                            <input type="password" class="form-control" name="password" id="passwordInput" placeholder="Nhập mật khẩu..." required>
                            <button class="btn btn-outline-secondary border-start-0" type="button" onclick="togglePassword()">
                                <i class="bi bi-eye" id="passwordIcon"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mt-5 p-3 bg-light rounded-3 border-start border-4 border-primary">
                    <div class="small text-muted"><i class="bi bi-info-circle-fill me-2"></i>Mật khẩu này sẽ được gửi tới giáo viên qua email hoặc bàn giao trực tiếp. Sau khi tạo, giáo viên có thể tự đổi mật khẩu.</div>
                </div>

                <hr class="my-5 opacity-50">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary-res px-5 py-3 fw-bold shadow-sm">
                        <i class="bi bi-person-plus me-2"></i>Tạo tài khoản giáo viên
                    </button>
                    <a href="/Admin/Users?tab=teachers" class="btn btn-light border px-5 py-3 fw-bold">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control {
        padding: 0.75rem 1rem;
        border-radius: 12px !important;
        border: 1px solid #e2e8f0;
    }
    .form-control:focus {
        border-color: var(--res-red);
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }
    .input-group .btn {
        border-top-right-radius: 12px !important;
        border-bottom-right-radius: 12px !important;
    }
</style>

@section Scripts {
    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            const icon = document.getElementById("passwordIcon");
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            }
        }
    </script>
}