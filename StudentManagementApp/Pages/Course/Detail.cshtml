@page "{id:int?}"
@model StudentManagementApp.Pages.Course.DetailModel
@{
    ViewData["Title"] = Model.Course?.Name ?? "Chi tiết khóa học";
    var userId = HttpContext.Session.GetString("UserId");
}

<section class="py-5 bg-light">
    <div class="container">
        @if (Model.Course != null)
        {
            <div id="courseDetailContent" class="row g-4">
                <div class="col-lg-8">
                    <div class="res-card mb-4">
                        <div class="res-card-header">
                            THÔNG TIN KHÓA HỌC
                        </div>
                        <div class="card-body p-4">
                            <h2 id="courseTitle" class="fw-bold mb-3">@Model.Course.Name</h2>
                            <div class="mb-4">
                                <span id="courseLevel" class="badge bg-res-red text-white px-4 py-2 rounded-pill fw-bold">TRÌNH ĐỘ: @Model.Course.Level</span>
                            </div>
                            <div id="courseDescription" class="text-muted h5 fw-normal mb-5" style="line-height: 1.8;">
                                @(Model.Course.Description ?? "Khóa học đang được cập nhật nội dung.")
                            </div>

                            <div class="p-4 bg-light rounded-3 border-start border-4 border-res-red d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="small text-muted fw-bold text-uppercase">Học phí ưu đãi</div>
                                    <div id="courseFee" class="h3 mb-0 fw-bold text-res-red">@Model.Course.TuitionFee.ToString("N0") VNĐ</div>
                                </div>
                                <i class="bi bi-gift text-res-red h1 mb-0 opacity-25"></i>
                            </div>
                        </div>
                    </div>

                    <div class="res-card">
                        <div class="res-card-header">
                            🗓️ LỊCH KHAI GIẢNG CÁC LỚP
                        </div>
                        <div class="card-body p-0">
                            @if (Model.Classes != null && Model.Classes.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table res-table mb-0">
                                        <thead>
                                            <tr>
                                                <th>Tên lớp</th>
                                                <th>Khai giảng</th>
                                                <th>Kết thúc</th>
                                                <th>Trạng thái</th>
                                                <th>Hành động</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var cls in Model.Classes)
                                            {
                                                <tr>
                                                    <td class="fw-bold text-dark">@cls.ClassName</td>
                                                    <td>@cls.StartDate.ToString("dd/MM/yyyy")</td>
                                                    <td>@cls.EndDate.ToString("dd/MM/yyyy")</td>
                                                    <td>
                                                        @{
                                                            var badgeClass = cls.Status switch
                                                            {
                                                                "Upcoming" => "badge-upcoming",
                                                                "Ongoing" => "badge-ongoing",
                                                                _ => "bg-secondary text-white"
                                                            };
                                                        }
                                                        <span class="badge-res @badgeClass">@cls.Status</span>
                                                    </td>
                                                    <td class="text-end">
                                                        @if (userId != null && cls.Status == "Upcoming")
                                                        {
                                                            <form method="post" asp-page-handler="AddToCart" asp-route-id="@Model.Course.Id">
                                                                <input type="hidden" name="classId" value="@cls.Id" />
                                                                <button type="submit" class="btn btn-primary-res btn-sm">ĐĂNG KÝ NGAY</button>
                                                            </form>
                                                        }
                                                        else if (userId == null)
                                                        {
                                                            <a href="/Auth/Login" class="btn btn-outline-res btn-sm">ĐĂNG NHẬP</a>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="p-5 text-center">
                                    <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                                    <p class="text-muted mt-3 h5">Hiện chưa có lớp học nào khả dụng.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="res-card sticky-top" style="top: 100px;">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 text-res-red border-bottom pb-2">ƯU ĐIỂM TẠI RES</h5>
                            <div class="d-flex mb-4">
                                <div class="bg-res-red bg-opacity-10 p-2 rounded me-3" style="height: fit-content;">
                                    <i class="bi bi-patch-check-fill text-res-red h4 mb-0"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Cam kết đầu ra</h6>
                                    <p class="small text-muted mb-0">Hỗ trợ học lại miễn phí nếu không đạt mục tiêu.</p>
                                </div>
                            </div>
                            <div class="d-flex mb-4">
                                <div class="bg-res-red bg-opacity-10 p-2 rounded me-3" style="height: fit-content;">
                                    <i class="bi bi-clock-history text-res-red h4 mb-0"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Thời gian linh hoạt</h6>
                                    <p class="small text-muted mb-0">Nhiều ca học phù hợp cho cả học sinh và người đi làm.</p>
                                </div>
                            </div>
                            <div class="d-flex mb-4">
                                <div class="bg-res-red bg-opacity-10 p-2 rounded me-3" style="height: fit-content;">
                                    <i class="bi bi-lightning-fill text-res-red h4 mb-0"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Hỗ trợ 24/7</h6>
                                    <p class="small text-muted mb-0">Đội ngũ trợ giảng luôn sẵn sàng giải đáp thắc mắc.</p>
                                </div>
                            </div>
                            <hr>
                            <a href="/Course" class="btn btn-outline-dark w-100 rounded-pill fw-bold">QUAY LẠI DANH SÁCH</a>
                        </div>
                    </div>
                </div>
            </div>

            <div id="courseUnavailableState" class="text-center py-5" hidden>
                <i class="bi bi-search text-muted display-1 mb-3"></i>
                <h2 class="text-muted">Khóa học hiện không còn khả dụng</h2>
                <p class="text-muted">Thông tin khóa học đã thay đổi. Bạn có thể chọn một khóa học khác.</p>
                <a href="/Course" class="btn btn-primary-res mt-3">XEM CÁC KHÓA HỌC KHÁC</a>
            </div>
        }
        else
        {
            <div id="courseUnavailableState" class="text-center py-5">
                <i class="bi bi-search text-muted display-1 mb-3"></i>
                <h2 class="text-muted">Không tìm thấy khóa học</h2>
                <a href="/Course" class="btn btn-primary-res mt-3">XEM CÁC KHÓA HỌC KHÁC</a>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="/js/course-realtime.js"></script>
    <script>
        (() => {
            const realtime = window.meshCourseRealtime;
            const detailContent = document.getElementById("courseDetailContent");
            const unavailableState = document.getElementById("courseUnavailableState");
            const currentCourseId = @(Model.Course?.Id ?? 0);
            if (!realtime || !detailContent || !unavailableState || !currentCourseId) {
                return;
            }

            const courseTitle = document.getElementById("courseTitle");
            const courseLevel = document.getElementById("courseLevel");
            const courseDescription = document.getElementById("courseDescription");
            const courseFee = document.getElementById("courseFee");

            const showUnavailableState = (message) => {
                detailContent.hidden = true;
                unavailableState.hidden = false;
                document.title = "Chi tiết khóa học - English Center";
            };

            const showCourseContent = (course, message) => {
                if (!course) {
                    return;
                }

                detailContent.hidden = false;
                unavailableState.hidden = true;
                courseTitle.textContent = course.name;
                courseLevel.textContent = `TRÌNH ĐỘ: ${course.level}`;
                courseDescription.textContent = course.description || "Khóa học đang được cập nhật nội dung.";
                courseFee.textContent = realtime.formatCurrency(course.tuitionFee);
                document.title = `${course.name} - English Center`;
            };

            realtime.connect({
                onCourseChanged: (notification) => {
                    if (!notification || notification.courseId !== currentCourseId) {
                        return;
                    }

                    const course = notification.course || null;
                    const isUnavailable = notification.action === "Deleted" || (course && course.isActive === false);

                    if (isUnavailable) {
                        showUnavailableState(notification.message);
                    } else {
                        showCourseContent(course, notification.message);
                    }
                }
            });
        })();
    </script>
}
