@page
@model StudentManagementApp.Pages.Admin.Enrollments.IndexModel
@{
    ViewData["Title"] = "Quản lý đăng ký";
    ViewData["ActivePage"] = "Enrollments";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var userName = HttpContext.Session.GetString("UserName");
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Quy trình đăng ký</h6>
        <h2 class="fw-bold mb-0">Quản lý ghi danh</h2>
    </div>
</div>

<div class="admin-card">
    <!-- TABS -->
    <ul class="nav nav-pills mb-4 bg-light p-2 rounded-3" style="width: fit-content;">
        <li class="nav-item">
            <a class="nav-link px-4 fw-bold @(Model.Pending ? "text-muted" : "active bg-res-red")"
               href="/Admin/Enrollments">
                Tất cả hồ sơ
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link px-4 fw-bold @(Model.Pending ? "active bg-res-red" : "text-muted")"
               href="/Admin/Enrollments?pending=true">
                Đang chờ duyệt
            </a>
        </li>
    </ul>

    <!-- TABLE -->
    @if (Model.Enrollments.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Học viên</th>
                        <th>Thông tin lớp học</th>
                        <th>Thời gian đăng ký</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model.Enrollments)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@e.StudentName</div>
                                <div class="text-muted small">ID Đăng ký: #@e.Id</div>
                            </td>
                            <td>
                                <div class="fw-bold">@e.ClassName</div>
                                <div class="text-muted small">Khóa: @e.CourseName</div>
                            </td>
                            <td>
                                <div class="small">@e.EnrolledAt.ToString("dd/MM/yyyy")</div>
                                <div class="small text-muted">@e.EnrolledAt.ToString("HH:mm")</div>
                            </td>
                            <td>
                                @{
                                    var badgeClass = e.Status switch
                                    {
                                        "Confirmed" => "bg-success-subtle text-success",
                                        "Registered" => "bg-warning-subtle text-warning-emphasis",
                                        _ => "bg-secondary-subtle text-muted"
                                    };
                                }
                                <span class="badge rounded-pill @badgeClass px-3">
                                    @if(e.Status == "Confirmed") { <i class="bi bi-check-circle-fill me-1"></i> }
                                    else if(e.Status == "Registered") { <i class="bi bi-clock-history me-1"></i> }
                                    @e.Status
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                @if (e.Status == "Registered")
                                {
                                    <div class="d-flex justify-content-end gap-2">
                                        <form method="post" asp-page="/Admin/Enrollments/Confirm" class="d-inline">
                                            <input type="hidden" name="id" value="@e.Id" />
                                            <button class="btn btn-sm btn-success fw-bold px-3">
                                                Duyệt
                                            </button>
                                        </form>

                                        <form method="post" asp-page="/Admin/Enrollments/Cancel" class="d-inline">
                                            <input type="hidden" name="id" value="@e.Id" />
                                            <button class="btn btn-sm btn-outline-danger fw-bold px-3">
                                                Từ chối
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small italic">Không có thao tác</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-clipboard-x text-muted opacity-25 display-1"></i>
            <p class="mt-3 text-muted fw-bold">Không có hồ sơ đăng ký nào được tìm thấy.</p>
        </div>
    }
</div>

<style>
    .bg-success-subtle { background: #ecfdf5 !important; }
    .bg-warning-subtle { background: #fffbeb !important; }
    .bg-secondary-subtle { background: #f8fafc !important; }
    .text-warning-emphasis { color: #92400e !important; }
    .custom-table thead th {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.5px; color: #64748b; padding-top: 15px; padding-bottom: 15px;
    }
    .custom-table tbody td { padding-top: 15px; padding-bottom: 15px; }
</style>