@page "{id:int}"
@model StudentManagementApp.Pages.Admin.Courses.EditModel
@{
    ViewData["Title"] = "Sửa khóa học";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        <h1>Sửa khóa học</h1>

        <form method="post" class="mt-3">
            <input asp-for="Input.Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label class="form-label">Tên khóa học</label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Cấp độ</label>
                <select asp-for="Input.Level" class="form-select">
                    <option value="A1">A1</option>
                    <option value="A2">A2</option>
                    <option value="B1">B1</option>
                    <option value="B2">B2</option>
                    <option value="C1">C1</option>
                    <option value="C2">C2</option>
                </select>
                <span asp-validation-for="Input.Level" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Học phí</label>
                <input asp-for="Input.TuitionFee" type="number" min="0" class="form-control" />
                <span asp-validation-for="Input.TuitionFee" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Thumbnail URL (tuỳ chọn)</label>
                <input asp-for="Input.ThumbnailUrl" class="form-control" />
            </div>
            <div class="form-check mb-3">
                <input asp-for="Input.IsActive" class="form-check-input" />
                <label asp-for="Input.IsActive" class="form-check-label">Đang hoạt động</label>
            </div>

            <button type="submit" class="btn btn-primary">Lưu</button>
            <a href="/Admin/Courses" class="btn btn-secondary">Hủy</a>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
