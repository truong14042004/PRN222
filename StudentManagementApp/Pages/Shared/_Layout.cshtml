@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/res-style.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var userName = Context.Session.GetString("UserName");
        var userRole = Context.Session.GetString("UserRole");
        var userId = Context.Session.GetString("UserId");
    }

    <nav class="navbar navbar-expand-lg navbar-res sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="/images/logo.jpg" alt="English Center Logo">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Course">Khóa học</a></li>
                    @if (userRole == "Student" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Student">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" href="/PurchasableItems">Cửa hàng</a></li>
                    }
                    @if (userRole == "Teacher" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Teacher">Lớp dạy</a></li>
                    }
                    @if (userRole == "Admin" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link text-primary" href="/Admin">Quản trị</a></li>
                    }
                </ul>
                <ul class="navbar-nav align-items-center">
                    @if (userId != null)
                    {
                        <li class="nav-item me-3">
                            <a href="/Cart" class="nav-link position-relative p-2">
                                <i class="bi bi-cart3 fs-5"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-res-red" style="font-size: 0.6rem;">
                                    !
                                </span>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle btn btn-outline-res px-4 py-2" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> @userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                @if (userRole == "Student") {
                                    <li><a class="dropdown-item py-2" href="/Student"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                                    <li><a class="dropdown-item py-2" href="/Student/Orders"><i class="bi bi-clock-history me-2"></i> Lịch sử đơn hàng</a></li>
                                }
                                <li><a class="dropdown-item py-2" href="/Account/Profile"><i class="bi bi-person-badge me-2"></i> Hồ sơ cá nhân</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2"><a class="nav-link" href="/Auth/Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="btn btn-primary-res px-4" href="/Auth/Register">Tham gia ngay</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show border-0 border-start border-4 border-success shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show border-0 border-start border-4 border-danger shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="footer-res">
        <div class="footer-res-main">
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-4">
                        <img src="/images/logo.jpg" alt="Footer Logo" class="footer-logo mb-4">
                        <p class="small mb-4 text-white-50">Hệ thống đào tạo Tiếng Anh chuẩn quốc tế hàng đầu Việt Nam, giúp học viên đạt mục tiêu IELTS trong thời gian ngắn nhất.</p>
                        <div class="d-flex">
                            <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="social-icon"><i class="bi bi-youtube"></i></a>
                            <a href="#" class="social-icon"><i class="bi bi-tiktok"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-4">
                        <h6>Khóa học</h6>
                        <ul class="list-unstyled">
                            <li class="mb-2"><a href="/Course">Tiếng Anh Trẻ Em</a></li>
                            <li class="mb-2"><a href="/Course">Luyện thi IELTS</a></li>
                            <li class="mb-2"><a href="/Course">Tiếng Anh Giao Tiếp</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-2 col-md-4">
                        <h6>Tiện ích</h6>
                        <ul class="list-unstyled">
                            <li class="mb-2"><a href="/PurchasableItems">Cửa hàng vật phẩm</a></li>
                            <li class="mb-2"><a href="/Student">Xem kết quả học</a></li>
                            <li class="mb-2"><a href="/Account/Profile">Cài đặt tài khoản</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-4 col-md-4">
                        <h6>Liên hệ</h6>
                        <ul class="list-unstyled text-white-50 small">
                            <li class="mb-3 d-flex align-items-start">
                                <i class="bi bi-geo-alt-fill me-2 mt-1"></i>
                                <span>Trụ sở chính: 123 Đường Hồ Chí Minh, Quận 1, TP. HCM</span>
                            </li>
                            <li class="mb-3 d-flex align-items-center">
                                <i class="bi bi-telephone-fill me-2"></i>
                                <span>Hotline: 1800 1234 (Miễn phí)</span>
                            </li>
                            <li class="mb-3 d-flex align-items-center">
                                <i class="bi bi-envelope-fill me-2"></i>
                                <span>Email: contact@mesh.edu.vn</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-res-bottom text-center">
            <div class="container">
                <p class="mb-0">© 2026 MESH English Center. All rights reserved. Designed for excellence.</p>
            </div>
        </div>
    </footer>

    @if (userRole == "Student" && !string.IsNullOrWhiteSpace(userId))
    {
        <div id="notificationToastContainer" class="notification-toast-container position-fixed top-0 end-0 p-3"></div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @if (userRole == "Student" && !string.IsNullOrWhiteSpace(userId))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
        <script>
            (() => {
                const toastContainer = document.getElementById("notificationToastContainer");
                if (!toastContainer || typeof signalR === "undefined") {
                    return;
                }

                const buildToast = (notification) => {
                    const wrapper = document.createElement("div");
                    wrapper.className = "toast notification-toast border-0 shadow-sm";
                    wrapper.role = "alert";
                    wrapper.ariaLive = "assertive";
                    wrapper.ariaAtomic = "true";

                    const header = document.createElement("div");
                    header.className = "toast-header";

                    const icon = document.createElement("i");
                    icon.className = "bi bi-bell-fill text-res-red me-2";

                    const title = document.createElement("strong");
                    title.className = "me-auto";
                    title.textContent = notification.title || "Thông báo mới";

                    const time = document.createElement("small");
                    const confirmedAt = notification.confirmedAt ? new Date(notification.confirmedAt) : null;
                    time.textContent = confirmedAt && !Number.isNaN(confirmedAt.valueOf())
                        ? confirmedAt.toLocaleTimeString("vi-VN", { hour: "2-digit", minute: "2-digit" })
                        : "Vừa xong";

                    const closeButton = document.createElement("button");
                    closeButton.type = "button";
                    closeButton.className = "btn-close";
                    closeButton.setAttribute("data-bs-dismiss", "toast");
                    closeButton.setAttribute("aria-label", "Close");

                    header.append(icon, title, time, closeButton);

                    const body = document.createElement("div");
                    body.className = "toast-body";
                    body.textContent = notification.message || "Bạn có thông báo mới.";

                    wrapper.append(header, body);
                    return wrapper;
                };

                const showToast = (notification) => {
                    const toastElement = buildToast(notification);
                    toastContainer.appendChild(toastElement);

                    const toast = bootstrap.Toast.getOrCreateInstance(toastElement, {
                        autohide: true,
                        delay: 8000
                    });

                    toastElement.addEventListener("hidden.bs.toast", () => {
                        toastElement.remove();
                    }, { once: true });

                    toast.show();
                };

                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/hubs/notifications")
                    .withAutomaticReconnect()
                    .build();

                connection.on("EnrollmentConfirmed", showToast);
                connection.start().catch((error) => {
                    console.error("SignalR enrollment notification connection failed.", error);
                });
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
