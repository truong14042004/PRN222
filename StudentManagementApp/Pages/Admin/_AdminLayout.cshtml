@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<style>
    .admin-container {
        display: flex;
        min-height: calc(100vh - 72px);
        background: #f8f9fa;
    }

    /* Modern Sidebar */
    .admin-sidebar {
        width: 260px;
        background: white;
        border-right: 1px solid #eee;
        padding: 30px 15px;
        flex-shrink: 0;
    }

    .admin-sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 8px;
        position: sticky;
        top: 102px;
    }

    .admin-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 20px;
        border-radius: 12px;
        color: #64748b;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s;
    }

    .admin-nav-item i {
        font-size: 1.2rem;
    }

    .admin-nav-item:hover {
        background: #f1f5f9;
        color: var(--res-red);
    }

    .admin-nav-item.active {
        background: var(--res-red);
        color: white;
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.2);
    }

    /* Content Area */
    .admin-main {
        flex-grow: 1;
        padding: 40px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .admin-header {
        margin-bottom: 40px;
    }

    .admin-card {
        padding: 24px;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

    @@media (max-width: 992px) {
        .admin-sidebar { width: 80px; padding: 20px 10px; }
        .admin-nav-item span { display: none; }
        .admin-nav-item { justify-content: center; padding: 15px; }
    }
</style>

<div class="admin-container">
    <aside class="admin-sidebar">
        <nav class="admin-sidebar-nav">
            <a class="admin-nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")" href="/Admin">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
            </a>
            <a class="admin-nav-item @(ViewData["ActivePage"]?.ToString() == "Users" ? "active" : "")" href="/Admin/Users">
                <i class="bi bi-people"></i>
                <span>Người dùng</span>
            </a>
            <a class="admin-nav-item @(ViewData["ActivePage"]?.ToString() == "Courses" ? "active" : "")" href="/Admin/Courses">
                <i class="bi bi-journal-bookmark"></i>
                <span>Khóa học</span>
            </a>
            <a class="admin-nav-item @(ViewData["ActivePage"]?.ToString() == "Classes" ? "active" : "")" href="/Admin/Classes">
                <i class="bi bi-mortarboard"></i>
                <span>Lớp học</span>
            </a>
            <a class="admin-nav-item @(ViewData["ActivePage"]?.ToString() == "Enrollments" ? "active" : "")" href="/Admin/Enrollments">
                <i class="bi bi-clipboard-check"></i>
                <span>Đăng ký</span>
            </a>
            <a class="admin-nav-item @(ViewData["ActivePage"]?.ToString() == "PurchasableItems" ? "active" : "")" href="/Admin/PurchasableItems">
                <i class="bi bi-bag"></i>
                <span>Cửa hàng</span>
            </a>
            <a class="admin-nav-item @(ViewData["ActivePage"]?.ToString() == "Quizzes" ? "active" : "")" href="/Admin/Quizzes">
                <i class="bi bi-patch-question"></i>
                <span>Bài Quiz</span>
            </a>
            <div class="mt-auto pt-4 border-top">
                <a class="admin-nav-item text-danger" href="/Auth/Logout">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Đăng xuất</span>
                </a>
            </div>
        </nav>
    </aside>

    <main class="admin-main">
        @RenderBody()
    </main>
</div>

@await RenderSectionAsync("Styles", required: false)
@await RenderSectionAsync("Scripts", required: false)
