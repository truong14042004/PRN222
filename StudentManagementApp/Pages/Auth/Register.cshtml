@page
@model StudentManagementApp.Pages.Auth.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký - English Center</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --ink: #0f172a;
            --muted: #64748b;
            --line: #d9e4f2;
            --brand: #1d4ed8;
            --brand-2: #0f766e;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(900px 440px at 0% 0%, #dbeafe 0%, transparent 70%),
                radial-gradient(900px 440px at 100% 100%, #dcfce7 0%, transparent 70%),
                #f3f7ff;
            display: grid;
            place-items: center;
            padding: 18px;
        }

        .auth-shell {
            width: min(1040px, 100%);
            border: 1px solid var(--line);
            border-radius: 22px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 26px 52px rgba(15, 23, 42, .15);
            display: grid;
            grid-template-columns: 1fr 1.15fr;
        }

        .intro {
            padding: 28px;
            color: #fff;
            background: linear-gradient(135deg, var(--brand) 0%, var(--brand-2) 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 16px;
        }

        .intro h1 {
            margin: 0;
            font-size: clamp(1.45rem, 2.4vw, 2rem);
            font-weight: 800;
        }

        .intro p {
            margin: 8px 0 0;
            color: rgba(255,255,255,.92);
            line-height: 1.62;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            padding: 7px 12px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,.35);
            background: rgba(255,255,255,.08);
            font-size: .85rem;
            font-weight: 600;
        }

        .form-side {
            padding: 24px 22px;
        }

        .form-title {
            margin: 0;
            font-size: 1.42rem;
            font-weight: 800;
        }

        .form-sub {
            margin-top: 6px;
            color: var(--muted);
            font-size: .92rem;
        }

        .form-label {
            font-weight: 600;
            font-size: .9rem;
        }

        .form-control {
            border-radius: 10px;
            border-color: #cfdbee;
            padding: .6rem .78rem;
        }

        .form-control:focus {
            border-color: #6ea1ff;
            box-shadow: 0 0 0 .2rem rgba(59, 130, 246, .15);
        }

        .btn-auth {
            border: 0;
            border-radius: 10px;
            background: linear-gradient(135deg, #1d4ed8 0%, #0f766e 100%);
            color: #fff;
            font-weight: 700;
            width: 100%;
            padding: .72rem;
        }

        .btn-auth:hover {
            color: #fff;
            filter: brightness(.96);
        }

        .foot-note {
            color: var(--muted);
            font-size: .9rem;
        }

        @@media (max-width: 900px) {
            .auth-shell {
                grid-template-columns: 1fr;
            }

            .intro {
                padding: 20px;
            }

            .form-side {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="auth-shell">
        <section class="intro">
            <div>
                <span class="tag">English Center</span>
                <h1 class="mt-3">Tạo tài khoản học viên</h1>
                <p>Sau khi đăng ký, hệ thống sẽ gửi mã OTP qua email để xác thực.</p>
            </div>
            <a href="/" class="btn btn-light btn-sm align-self-start px-3">Về trang chủ</a>
        </section>

        <section class="form-side">
            <h2 class="form-title">Đăng ký</h2>
            <p class="form-sub">Điền thông tin để bắt đầu học.</p>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post" class="mt-3">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Họ và tên</label>
                        <input type="text" class="form-control" asp-for="FullName" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" asp-for="Email" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Tên đăng nhập</label>
                        <input type="text" class="form-control" asp-for="Username" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại</label>
                        <input type="text" class="form-control" asp-for="Phone">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mật khẩu</label>
                        <input type="password" class="form-control" asp-for="Password" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <input type="password" class="form-control" asp-for="ConfirmPassword" required>
                    </div>
                </div>

                <button type="submit" class="btn-auth mt-3">Gửi mã OTP</button>
            </form>

            <div class="mt-3 foot-note">
                Đã có tài khoản?
                <a href="/Auth/Login" class="fw-semibold text-decoration-none">Đăng nhập</a>
            </div>
        </section>
    </div>
</body>
</html>
