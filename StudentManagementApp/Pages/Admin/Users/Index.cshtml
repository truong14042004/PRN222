@page
@model StudentManagementApp.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["ActivePage"] = "Users";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var userName = HttpContext.Session.GetString("UserName");
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Hệ thống người dùng</h6>
        <h2 class="fw-bold mb-0">Quản lý người dùng</h2>
    </div>
    @if (Model.Tab == "teachers")
    {
        <a href="/Admin/Users/CreateTeacher" class="btn btn-primary-res px-4">
            <i class="bi bi-person-plus me-2"></i>Thêm giáo viên
        </a>
    }
</div>

<div class="admin-card mb-4">
    <!-- TABS -->
    <ul class="nav nav-pills mb-4 bg-light p-2 rounded-3" style="width: fit-content;">
        <li class="nav-item">
            <a class="nav-link px-4 fw-bold @(Model.Tab == "students" ? "active bg-res-red" : "text-muted")"
               href="/Admin/Users?tab=students">
                Học viên
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link px-4 fw-bold @(Model.Tab == "teachers" ? "active bg-res-red" : "text-muted")"
               href="/Admin/Users?tab=teachers">
                Giáo viên
            </a>
        </li>
    </ul>

    <!-- FILTER -->
    <form method="get" class="row g-3 align-items-center mb-4">
        <input type="hidden" name="tab" value="@Model.Tab" />
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="Tìm tên, email, số điện thoại..." value="@Model.Q">
            </div>
        </div>
        <div class="col-md-2">
            <button class="btn btn-dark px-4 w-100 fw-bold">Tìm kiếm</button>
        </div>
        <div class="col-md-6 text-end">
            <span class="text-muted small fw-bold text-uppercase">Tổng số: @Model.TotalCount</span>
        </div>
    </form>

    <!-- TABLE -->
    @if (Model.Users.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Thành viên</th>
                        <th>Thông tin liên hệ</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle bg-light text-res-red fw-bold">
                                        @user.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@user.FullName</div>
                                        <div class="text-muted small">ID: #@user.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="small"><i class="bi bi-envelope me-2"></i>@user.Email</div>
                                <div class="small"><i class="bi bi-telephone me-2"></i>@user.Phone</div>
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success px-3">
                                        <i class="bi bi-check-circle-fill me-1"></i>Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-danger-subtle text-danger px-3">
                                        <i class="bi bi-x-circle-fill me-1"></i>Vô hiệu
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/Admin/Users/Edit/@user.Id?tab=@Model.Tab"
                                       class="btn btn-sm btn-light border fw-bold text-muted px-3">
                                        <i class="bi bi-pencil-square me-1"></i>Sửa
                                    </a>

                                    <form method="post" asp-page="/Admin/Users/Toggle" class="d-inline">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <input type="hidden" name="tab" value="@Model.Tab" />
                                        <button class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success") fw-bold px-3">
                                            <i class="bi @(user.IsActive ? "bi-slash-circle" : "bi-check-circle") me-1"></i>
                                            @(user.IsActive ? "Vô hiệu" : "Kích hoạt")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link px-3 fw-bold @(i == Model.CurrentPage ? "bg-res-red border-res-red" : "text-dark")"
                               href="/Admin/Users?tab=@Model.Tab&page=@i&q=@Model.Q">
                                @i
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-people text-muted opacity-25 display-1"></i>
            <p class="mt-3 text-muted fw-bold">Không tìm thấy người dùng nào phù hợp.</p>
        </div>
    }
</div>

<style>
    .avatar-circle {
        width: 40px; height: 40px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; border: 1px solid #eee;
    }
    .bg-success-subtle { background: #ecfdf5 !important; }
    .bg-danger-subtle { background: #fef2f2 !important; }
    .custom-table thead th {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.5px; color: #64748b; padding-top: 15px; padding-bottom: 15px;
    }
    .custom-table tbody td { padding-top: 15px; padding-bottom: 15px; }
</style>
