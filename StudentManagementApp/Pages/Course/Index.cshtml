@page
@model StudentManagementApp.Pages.Course.IndexModel
@{
    ViewData["Title"] = "Tất cả khóa học";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="res-section-title center">KHÁM PHÁ CÁC KHÓA HỌC</h2>
        <p class="text-muted">Chúng tôi cung cấp lộ trình học tập tối ưu cho mọi cấp độ.</p>
    </div>

    <div class="row g-4">
        @if (Model.Courses != null && Model.Courses.Any())
        {
            @foreach (var course in Model.Courses)
            {
                <div class="col-md-4">
                    <div class="res-card">
                        @if (!string.IsNullOrEmpty(course.ThumbnailUrl)) {
                            <img src="@course.ThumbnailUrl" class="card-img-top" alt="@course.Name" style="height: 200px; object-fit: cover;">
                        }
                        <div class="card-body">
                            <span class="badge-res bg-res-red text-white mb-2 d-inline-block">LEVEL: @course.Level</span>
                            <h5 class="card-title fw-bold">@course.Name</h5>
                            <p class="card-text text-muted small">@course.Description</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="text-res-red fw-bold h5 mb-0">@course.TuitionFee.ToString("N0") <small>VNĐ</small></span>
                                <a href="/Course/Detail/@course.Id" class="btn btn-outline-res btn-sm rounded-pill px-4">Chi tiết</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">Hiện không có khóa học nào khả dụng.</p>
            </div>
        }
    </div>
</div>
