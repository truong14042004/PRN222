@page
@model StudentManagementApp.Pages.Auth.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/res-style.css">
    <style>
        body {
            height: 100vh;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, #fdf8f0 0%, #ffffff 100%);
        }
        .auth-card {
            width: 100%;
            max-width: 900px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0,0,0,0.1);
        }
        .auth-intro {
            background-color: var(--res-red);
            color: white;
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .auth-form-side {
            background: white;
            padding: 3rem;
        }
        @@media (max-width: 768px) {
            .auth-card { grid-template-columns: 1fr; }
            .auth-intro { display: none; }
        }
    </style>
</head>
<body class="form-res">
    <div class="auth-card">
        <div class="auth-intro">
            <img src="/images/logo.jpg" alt="Logo" class="footer-logo brightness-0 invert mb-4" style="height: 60px; width: auto;">
            <h2 class="fw-bold h1">Chào mừng quay trở lại!</h2>
            <p class="mt-3 opacity-75">Đăng nhập để quản lý lộ trình học tập, xem lịch học và tham gia các bài kiểm tra định kỳ.</p>
            <div class="mt-5">
                <a href="/" class="btn btn-outline-light rounded-pill px-4">
                    <i class="bi bi-house-door me-1"></i> Về trang chủ
                </a>
            </div>
        </div>
        <div class="auth-form-side">
            <div class="mb-4 text-center d-md-none">
                <img src="/images/logo.jpg" alt="Logo" style="height: 40px;">
            </div>
            <h3 class="fw-bold mb-1">Đăng nhập</h3>
            <p class="text-muted small mb-4">Nhập thông tin tài khoản của bạn để tiếp tục.</p>

            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger border-0 border-start border-danger border-4 small">
                    <i class="bi bi-exclamation-circle-fill me-2"></i> @ViewData["Error"]
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label small fw-bold">Tên đăng nhập / Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" asp-for="Username" placeholder="your_username" required>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label small fw-bold">Mật khẩu</label>
                        <a href="#" class="small text-decoration-none text-res-red">Quên mật khẩu?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                        <input type="password" class="form-control border-start-0 ps-0" asp-for="Password" placeholder="••••••••" required>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary-res w-100 py-3 rounded-pill shadow">ĐĂNG NHẬP NGAY</button>
                </div>
            </form>

            <div class="mt-4 text-center small text-muted">
                Bạn chưa có tài khoản? 
                <a href="/Auth/Register" class="text-res-red fw-bold text-decoration-none">Đăng ký thành viên</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
