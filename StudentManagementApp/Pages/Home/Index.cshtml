@page
@model StudentManagementApp.Pages.Home.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
}

@* Hero Section *@
<section class="hero-section position-relative overflow-hidden" style="background: url('/images/banner.jpg') no-repeat center center; background-size: cover; min-height: 600px;">
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.3));"></div>
    <div class="container position-relative h-100 d-flex align-items-center" style="min-height: 600px;">
        <div class="row w-100">
            <div class="col-lg-7 text-white">
                <h1 class="display-3 fw-bold mb-3 animate__animated animate__fadeInUp">HỆ THỐNG ANH NGỮ MESH</h1>
                <p class="h4 fw-normal mb-5 text-white animate__animated animate__fadeInUp animate__delay-1s">Đơn vị đào tạo IELTS hàng đầu Việt Nam với lộ trình cá nhân hóa, giúp bạn đạt mục tiêu nhanh nhất.</p>
                <div class="d-flex gap-3 animate__animated animate__fadeInUp animate__delay-2s">
                    <a href="/Course" class="btn btn-primary-res btn-lg px-5">KHÁM PHÁ KHÓA HỌC</a>
                    <a href="/Auth/Register" class="btn btn-outline-light btn-lg px-5 rounded-pill fw-bold border-2">ĐĂNG KÝ NGAY</a>
                </div>
            </div>
        </div>
    </div>
</section>

@* Stats Section *@
<section class="py-5 bg-res-red text-white">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-3 col-6">
                <div class="h2 fw-bold mb-0">15+</div>
                <div class="small opacity-75 text-uppercase">Năm kinh nghiệm</div>
            </div>
            <div class="col-md-3 col-6">
                <div class="h2 fw-bold mb-0">40+</div>
                <div class="small opacity-75 text-uppercase">Trung tâm toàn quốc</div>
            </div>
            <div class="col-md-3 col-6">
                <div class="h2 fw-bold mb-0">50,000+</div>
                <div class="small opacity-75 text-uppercase">Học viên IELTS 7.0+</div>
            </div>
            <div class="col-md-3 col-6">
                <div class="h2 fw-bold mb-0">100%</div>
                <div class="small opacity-75 text-uppercase">Giảng viên bản ngữ</div>
            </div>
        </div>
    </div>
</section>

@* Why RES Section *@
<section class="py-5">
    <div class="container py-4">
        <h2 class="res-section-title center">TẠI SAO CHỌN RES?</h2>
        <div class="row g-4 mt-2">
            <div class="col-lg-4">
                <div class="res-card p-4 text-center">
                    <div class="bg-res-red bg-opacity-10 p-3 rounded-circle d-inline-block mb-3">
                        <i class="bi bi-mortarboard-fill text-res-red h1 mb-0"></i>
                    </div>
                    <h5 class="fw-bold">Lộ trình chuyên sâu</h5>
                    <p class="text-muted small">Chương trình học được thiết kế bám sát cấu trúc đề thi IELTS mới nhất từ IDP và British Council.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="res-card p-4 text-center">
                    <div class="bg-res-red bg-opacity-10 p-3 rounded-circle d-inline-block mb-3">
                        <i class="bi bi-people-fill text-res-red h1 mb-0"></i>
                    </div>
                    <h5 class="fw-bold">Đội ngũ chuyên gia</h5>
                    <p class="text-muted small">Giảng viên là các chuyên gia khảo thí IELTS, giàu kinh nghiệm sư phạm và tâm huyết.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="res-card p-4 text-center">
                    <div class="bg-res-red bg-opacity-10 p-3 rounded-circle d-inline-block mb-3">
                        <i class="bi bi-laptop-fill text-res-red h1 mb-0"></i>
                    </div>
                    <h5 class="fw-bold">Hệ thống Hybrid</h5>
                    <p class="text-muted small">Kết hợp học trực tiếp tại trung tâm và ôn luyện trực tuyến qua hệ thống LMS hiện đại.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@* CTA Section *@
<section class="py-5 bg-light">
    <div class="container">
        <div class="res-card bg-white border-0 shadow-lg p-5 text-center">
            <h2 class="fw-bold mb-3">SẴN SÀNG CHINH PHỤC IELTS?</h2>
            <p class="text-muted mb-4 mx-auto" style="max-width: 700px;">Đừng để rào cản tiếng Anh ngăn bước tiến của bạn. Hãy để RES đồng hành cùng bạn trên con đường chinh phục đỉnh cao học thuật.</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/Auth/Register" class="btn btn-primary-res px-5 py-3">NHẬN TƯ VẤN MIỄN PHÍ</a>
                <a href="tel:18001234" class="btn btn-outline-res px-5 py-3"><i class="bi bi-telephone-fill me-2"></i>GỌI HOTLINE</a>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
}
