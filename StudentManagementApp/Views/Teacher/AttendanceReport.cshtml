@using StudentManagementApp.BLL.DTOs
@{
    ViewData["Title"] = "Báo cáo điểm danh";
    var cls = ViewBag.Class as ClassDto;
    var students = ViewBag.Students as IEnumerable<EnrollmentDto> ?? Enumerable.Empty<EnrollmentDto>();
    var byDate = ViewBag.ByDate as IEnumerable<IGrouping<DateOnly, AttendanceDto>> ?? Enumerable.Empty<IGrouping<DateOnly, AttendanceDto>>();
    var studentList = students.ToList();
    var dateList = byDate.ToList();
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Báo cáo điểm danh — @cls?.ClassName</h4>
            <p class="text-muted mb-0">@cls?.CourseName &nbsp;|&nbsp; @cls?.StartDate.ToString("dd/MM/yyyy") — @cls?.EndDate.ToString("dd/MM/yyyy")</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Quay lại</a>
    </div>

    @if (!dateList.Any())
    {
        <div class="alert alert-info">Chưa có buổi điểm danh nào được ghi nhận.</div>
    }
    else
    {
        <!-- Summary per student -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light fw-bold">Tổng hợp theo học viên</div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Học viên</th>
                            <th class="text-center">Số buổi có mặt</th>
                            <th class="text-center">Tổng buổi</th>
                            <th class="text-center">Tỷ lệ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in studentList)
                        {
                            int total = dateList.Count;
                            int present = dateList.Sum(g => g.Any(a => a.StudentId == s.StudentId && a.IsPresent) ? 1 : 0);
                            double pct = total > 0 ? (double)present / total * 100 : 0;
                            <tr>
                                <td class="fw-semibold">@s.StudentName</td>
                                <td class="text-center text-success fw-bold">@present</td>
                                <td class="text-center">@total</td>
                                <td class="text-center">
                                    <span class="badge @(pct >= 80 ? "bg-success" : pct >= 60 ? "bg-warning text-dark" : "bg-danger")">
                                        @pct.ToString("0")%
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Detail per session -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light fw-bold">Chi tiết từng buổi học</div>
            <div class="table-responsive">
                <table class="table table-bordered table-sm mb-0 text-center align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-start">Học viên</th>
                            @foreach (var g in dateList)
                            {
                                <th>@g.Key.ToString("dd/MM")</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in studentList)
                        {
                            <tr>
                                <td class="text-start fw-semibold">@s.StudentName</td>
                                @foreach (var g in dateList)
                                {
                                    var att = g.FirstOrDefault(a => a.StudentId == s.StudentId);
                                    if (att == null)
                                    {
                                        <td class="text-muted">—</td>
                                    }
                                    else if (att.IsPresent)
                                    {
                                        <td title="@att.Note"><i class="fa fa-check text-success"></i></td>
                                    }
                                    else
                                    {
                                        <td title="@att.Note"><i class="fa fa-times text-danger"></i></td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
