@page
@model StudentManagementApp.Pages.Auth.VerifyRegistrationModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác thực đăng ký - MESH English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --res-red: #DC343B;
            --res-red-dark: #B92B31;
            --res-bg: #f8f9fa;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        h3 {
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            color: #333;
        }

        .verify-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            overflow: hidden;
            border: none;
            max-width: 450px;
            width: 100%;
        }

        .verify-header {
            background: var(--res-red);
            padding: 30px;
            text-align: center;
            color: white;
        }

        .verify-body {
            padding: 40px;
        }

        .otp-input {
            letter-spacing: 0.5rem;
            font-weight: 700;
            font-size: 1.5rem;
            text-align: center;
            border-radius: 12px;
            border: 2px solid #eee;
            padding: 12px;
            transition: all 0.3s ease;
        }

        .otp-input:focus {
            border-color: var(--res-red);
            box-shadow: 0 0 0 0.25rem rgba(220, 52, 59, 0.1);
        }

        .btn-verify {
            background: var(--res-red);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            color: white;
        }

        .btn-verify:hover {
            background: var(--res-red-dark);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(220, 52, 59, 0.3);
            color: white;
        }

        .resend-link {
            color: #666;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .resend-link:hover {
            color: var(--res-red);
        }

        .info-box {
            background: rgba(220, 52, 59, 0.05);
            border-left: 4px solid var(--res-red);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 25px;
            font-size: 0.9rem;
        }

        .status-alert {
            border-radius: 12px;
            border: none;
            padding: 15px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center p-3">
        <div class="verify-card shadow-lg">
            <div class="verify-header">
                <i class="bi bi-shield-check" style="font-size: 3rem;"></i>
                <h3 class="text-white mt-2 mb-0">Xác thực đăng ký</h3>
            </div>
            
            <div class="verify-body">
                @if (TempData["Error"] != null || !ViewData.ModelState.IsValid)
                {
                    <div class="mb-3">
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger status-alert d-flex align-items-center">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <div>@TempData["Error"]</div>
                            </div>
                        }

                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                        {
                            <div class="alert alert-danger status-alert">
                                <ul class="mb-0 ps-3">
                                    @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                }

                <div class="info-box text-muted">
                    <p class="mb-1">Chào <strong>@Model.FullName</strong>,</p>
                    <p class="mb-0">Mã OTP đã được gửi tới <strong>@Model.Email</strong>. Vui lòng nhập mã để hoàn tất đăng ký tài khoản.</p>
                </div>

                <form method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-uppercase text-muted">Mã OTP (6 chữ số)</label>
                        <input type="text" class="form-control otp-input" asp-for="OtpCode" maxlength="6" 
                               placeholder="------" autocomplete="one-time-code" autofocus required />
                    </div>
                    <button type="submit" class="btn btn-verify w-100 mb-3">Xác thực và tạo tài khoản</button>
                </form>

                <form method="post" asp-page-handler="Resend" id="resendForm">
                    <div class="text-center">
                        <span class="text-muted small">Không nhận được mã? </span>
                        <a href="javascript:void(0)" onclick="document.getElementById('resendForm').submit()" class="resend-link small">Gửi lại mã OTP</a>
                    </div>
                </form>

                <hr class="my-4">

                <div class="text-center">
                    <a href="/Auth/Register" class="text-muted small text-decoration-none">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại trang đăng ký
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

