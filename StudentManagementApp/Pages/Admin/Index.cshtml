@page
@model StudentManagementApp.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Quản trị";
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">English Center - Admin</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link active" href="/Admin">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Users">Người dùng</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Courses">Khóa học</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Classes">Lớp học</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Enrollments">Đăng ký</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Quizzes">Quiz</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Xin chào, @userName</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Auth/Logout">Đăng xuất</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h1>Dashboard</h1>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="row mt-4">
            <div class="col-md-3">
                <div class="card text-center bg-primary text-white">
                    <div class="card-body">
                        <h2>@Model.StudentCount</h2>
                        <p>Học viên</p>
                        <a href="/Admin/Users?tab=students" class="btn btn-light">Quản lý</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center bg-success text-white">
                    <div class="card-body">
                        <h2>@Model.TeacherCount</h2>
                        <p>Giáo viên</p>
                        <a href="/Admin/Users?tab=teachers" class="btn btn-light">Quản lý</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center bg-info text-white">
                    <div class="card-body">
                        <h2>@Model.CourseCount</h2>
                        <p>Khóa học</p>
                        <a href="/Admin/Courses" class="btn btn-light">Quản lý</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center bg-warning text-dark">
                    <div class="card-body">
                        <h2>@Model.ClassCount</h2>
                        <p>Lớp học</p>
                        <a href="/Admin/Classes" class="btn btn-light">Quản lý</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
