@using StudentManagementApp.BLL.DTOs
@model IEnumerable<CourseDto>

@{
    ViewData["Title"] = "Quản lý khóa học";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Quản lý khóa học</h4>
        <a asp-action="CreateCourse" class="btn btn-primary rounded-pill px-4">
            <i class="fa fa-plus me-1"></i> Thêm khóa học
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3 pb-2 px-3">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="q" value="@ViewBag.Q" class="form-control" placeholder="Tìm theo tên khóa học, cấp độ..." />
                <button type="submit" class="btn btn-outline-primary rounded-pill px-3"><i class="fa fa-search"></i></button>
                @if (!string.IsNullOrEmpty(ViewBag.Q as string))
                {
                    <a asp-action="Courses" class="btn btn-outline-secondary rounded-pill px-3">Xóa</a>
                }
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tên khóa học</th>
                        <th>Cấp độ</th>
                        <th>Học phí</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@c.Name</td>
                            <td><span class="badge bg-warning text-dark">@c.Level</span></td>
                            <td>@c.TuitionFee.ToString("N0") ₫</td>
                            <td>
                                <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">
                                    @(c.IsActive ? "Đang mở" : "Đã đóng")
                                </span>
                            </td>
                            <td>
                                <a asp-action="EditCourse" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary rounded-pill">Sửa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if ((int)ViewBag.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                        <a class="page-link" asp-action="Courses" asp-route-q="@ViewBag.Q" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
        <p class="text-center text-muted small">Tổng: @ViewBag.TotalCount khóa học</p>
    }
</div>
