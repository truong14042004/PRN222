@page
@model StudentManagementApp.Pages.Teacher.ScheduleModel
@{
    ViewData["Title"] = "Lịch dạy tuần";
}

<style>
    .schedule-day-column {
        min-height: 120px;
        background: #f8f9fa;
        border-radius: 12px;
        padding: 15px;
        height: 100%;
        border: 1px solid #eee;
    }

    .schedule-item {
        background: white;
        border-radius: 10px;
        padding: 12px;
        margin-bottom: 12px;
        border-left: 4px solid var(--res-red);
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
        transition: transform 0.2s;
    }

    .schedule-item:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 15px rgba(0,0,0,0.08);
    }

    .day-header {
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        color: #333;
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .day-header span {
        font-size: 0.75rem;
        color: var(--res-red);
        background: var(--res-red-light);
        padding: 2px 8px;
        border-radius: 4px;
    }

    .date-nav-pill {
        background: white;
        padding: 10px 25px;
        border-radius: 50px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        display: inline-flex;
        align-items: center;
        gap: 20px;
    }
</style>

<section class="py-5 bg-light min-vh-100">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h6 class="text-res-red fw-bold text-uppercase mb-1">Thời khóa biểu</h6>
                <h2 class="fw-bold mb-0">LỊCH DẠY CHI TIẾT</h2>
            </div>
            
            <div class="date-nav-pill">
                <a href="/Teacher/Schedule?date=@Model.PreviousWeek.ToString("yyyy-MM-dd")" class="btn btn-light btn-sm rounded-circle shadow-sm">
                    <i class="bi bi-chevron-left"></i>
                </a>
                <span class="fw-bold text-dark">
                    @Model.WeekStart.ToString("dd/MM") - @Model.WeekEnd.ToString("dd/MM/yyyy")
                </span>
                <a href="/Teacher/Schedule?date=@Model.NextWeek.ToString("yyyy-MM-dd")" class="btn btn-light btn-sm rounded-circle shadow-sm">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </div>

        <div class="row g-3">
            @foreach (var day in Model.WeekDays)
            {
                var sessions = Model.Sessions.Where(s => s.DayOfWeek == day.DayOfWeek).ToList();
                <div class="col-xl-4 col-md-6">
                    <div class="schedule-day-column @(day.Date == DateOnly.FromDateTime(DateTime.Today) ? "border-res-red shadow-sm" : "")">
                        <div class="day-header">
                            <div>@day.DayName</div>
                            <span>@day.Date.ToString("dd/MM")</span>
                        </div>

                        @if (sessions.Any())
                        {
                            @foreach (var s in sessions)
                            {
                                <div class="schedule-item">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div class="badge bg-dark" style="font-size: 0.65rem;">
                                            <i class="bi bi-clock me-1"></i> @s.StartTime - @s.EndTime
                                        </div>
                                        <a href="/Teacher/Attendance/@s.ClassId" class="small text-res-red fw-bold text-decoration-none">
                                            ĐIỂM DANH
                                        </a>
                                    </div>
                                    <h6 class="fw-bold mb-1 text-dark">@s.ClassName</h6>
                                    <p class="small text-muted mb-0">
                                        <i class="bi bi-book me-1"></i> @s.CourseName
                                    </p>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted small italic">
                                <i class="bi bi-calendar-x d-block mb-1 opacity-50"></i>
                                Không có lịch dạy
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>
