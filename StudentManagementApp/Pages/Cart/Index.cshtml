@page
@model StudentManagementApp.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<section class="py-5 bg-light min-vh-100">
    <div class="container py-4">
        <div class="mb-5">
            <h6 class="text-res-red fw-bold text-uppercase mb-1">Thanh toán</h6>
            <h2 class="fw-bold mb-0">GIỎ HÀNG CỦA BẠN</h2>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="res-card">
                    <div class="res-card-header bg-white">
                        <i class="bi bi-cart3 me-2"></i> DANH SÁCH SẢN PHẨM
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Cart.Items != null && Model.Cart.Items.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var item in Model.Cart.Items)
                                {
                                    <div class="list-group-item p-4 border-0 border-bottom">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <div class="bg-res-red bg-opacity-10 p-3 rounded-3 text-res-red">
                                                    @if (item.ItemType == "Course") { <i class="bi bi-mortarboard h3 mb-0"></i> }
                                                    else { <i class="bi bi-box-seam h3 mb-0"></i> }
                                                </div>
                                            </div>
                                            <div class="col">
                                                <h5 class="fw-bold mb-1">@item.Name</h5>
                                                <span class="badge-res bg-light text-dark border py-1 px-3" style="font-size: 0.6rem;">@item.ItemType.ToUpper()</span>
                                            </div>
                                            <div class="col-auto">
                                                <form method="post" asp-page-handler="UpdateQuantity" class="d-flex align-items-center">
                                                    <input type="hidden" name="itemType" value="@item.ItemType" />
                                                    <input type="hidden" name="itemId" value="@item.ItemId" />
                                                    <div class="input-group input-group-sm" style="width: 120px;">
                                                        <button class="btn btn-outline-secondary" type="button" onclick="this.nextElementSibling.stepDown(); this.form.submit();" @(item.ItemType == "Course" ? "disabled" : "")>-</button>
                                                        <input type="number" name="quantity" value="@item.Quantity" class="form-control text-center fw-bold" min="1" onchange="this.form.submit()" @(item.ItemType == "Course" ? "disabled" : "") />
                                                        <button class="btn btn-outline-secondary" type="button" onclick="this.previousElementSibling.stepUp(); this.form.submit();" @(item.ItemType == "Course" ? "disabled" : "")>+</button>
                                                    </div>
                                                </form>
                                            </div>
                                            <div class="col-auto text-end" style="min-width: 150px;">
                                                <div class="fw-bold text-res-red h5 mb-2">@((item.Price * item.Quantity).ToString("N0")) VNĐ</div>
                                                <form method="post" asp-page-handler="Remove">
                                                    <input type="hidden" name="itemType" value="@item.ItemType" />
                                                    <input type="hidden" name="itemId" value="@item.ItemId" />
                                                    <button type="submit" class="btn btn-link text-muted btn-sm p-0 text-decoration-none">
                                                        <i class="bi bi-trash me-1"></i> Xóa bỏ
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-cart-x text-muted display-1 mb-3"></i>
                                <h4 class="text-muted">Giỏ hàng của bạn đang trống</h4>
                                <a href="/Course" class="btn btn-primary-res mt-3 px-5">ĐI MUA SẮM NGAY</a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="res-card border-top border-4 border-res-red shadow-lg sticky-top" style="top: 100px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">TỔNG KẾT ĐƠN HÀNG</h5>
                        
                        <div class="d-flex justify-content-between mb-3 text-muted fw-bold small">
                            <span>TẠM TÍNH (@(Model.Cart.Items?.Count() ?? 0) MÓN):</span>
                            <span class="text-dark">@Model.Cart.TotalAmount.ToString("N0") VNĐ</span>
                        </div>
                        
                        <div class="bg-light p-3 rounded-3 mb-4">
                            <div class="d-flex justify-content-between mb-2 small fw-bold">
                                <span>SỐ DƯ VÍ:</span>
                                <span class="text-success">@Model.WalletBalance.ToString("N0") VNĐ</span>
                            </div>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="useBalanceCheck" name="useBalance" value="true" checked>
                                <label class="form-check-label small fw-bold" for="useBalanceCheck">SỬ DỤNG SỐ DƯ VÍ</label>
                            </div>
                        </div>

                        <hr class="my-4">
                        
                        <div class="d-flex justify-content-between mb-4">
                            <span class="h5 fw-bold">TỔNG CỘNG:</span>
                            <div class="text-end">
                                <div class="h3 fw-bold text-res-red mb-0" id="finalPrice">@Model.Cart.TotalAmount.ToString("N0") VNĐ</div>
                                <small class="text-muted small fw-bold">ĐÃ BAO GỒM THUẾ</small>
                            </div>
                        </div>

                        <form method="post" asp-page-handler="Checkout">
                            <input type="hidden" name="useBalance" id="useBalanceHidden" value="true" />
                            <button type="submit" class="btn btn-primary-res btn-lg w-100 py-3 mb-3 shadow" @(Model.Cart.Items?.Any() == true ? "" : "disabled")>
                                TIẾN HÀNH THANH TOÁN
                            </button>
                        </form>
                        
                        <div class="text-center">
                            <div class="d-flex align-items-center justify-content-center text-muted small fw-bold">
                                <i class="bi bi-shield-lock-fill me-2 text-success h5 mb-0"></i>
                                BẢO MẬT QUA PAYOS
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const totalAmount = @Model.Cart.TotalAmount;
        const walletBalance = @Model.WalletBalance;
        const useBalanceCheck = document.getElementById('useBalanceCheck');
        const finalPriceLabel = document.getElementById('finalPrice');
        const useBalanceHidden = document.getElementById('useBalanceHidden');

        function updatePrice() {
            let finalPrice = totalAmount;
            if (useBalanceCheck.checked) {
                finalPrice = Math.max(0, totalAmount - walletBalance);
            }
            finalPriceLabel.innerText = finalPrice.toLocaleString('vi-VN') + ' VNĐ';
            useBalanceHidden.value = useBalanceCheck.checked;
        }

        useBalanceCheck.addEventListener('change', updatePrice);
        updatePrice();
    </script>
}
