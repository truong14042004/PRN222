@page
@model StudentManagementApp.Pages.Admin.QuizQuestionsModel
@{
    ViewData["Title"] = "Quản lý câu hỏi quiz";
    var quiz = Model.Quiz;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg: #edf3fb;
            --card: #fff;
            --ink: #0f172a;
            --muted: #5b6b83;
            --line: #d9e2ef;
            --brand: #1d4ed8;
            --ok: #16a34a;
            --danger: #b91c1c;
        }

        body {
            margin: 0;
            font-family: "Manrope", "Segoe UI", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(700px 380px at 0% 0%, #dbeafe 0%, transparent 70%),
                radial-gradient(650px 360px at 100% 100%, #e2e8f0 0%, transparent 70%),
                var(--bg);
            min-height: 100vh;
        }

        .shell {
            width: min(1160px, 94vw);
            margin: 0 auto;
            padding: 24px 0 48px;
        }

        .hero {
            border-radius: 22px;
            padding: 22px;
            color: #fff;
            background: linear-gradient(124deg, #1e40af, #1d4ed8, #2563eb);
            box-shadow: 0 22px 42px rgba(37, 99, 235, .23);
            margin-bottom: 16px;
            animation: rise .42s ease-out;
        }

        .hero h1 {
            margin: 0;
            font-size: clamp(1.35rem, 2.6vw, 2rem);
            font-weight: 800;
        }

        .hero .meta {
            margin-top: 8px;
            color: rgba(255,255,255,.9);
        }

        .grid {
            display: grid;
            grid-template-columns: 1.15fr .85fr;
            gap: 16px;
        }

        .panel {
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: 18px;
            box-shadow: 0 18px 32px rgba(15, 23, 42, .08);
            overflow: hidden;
            animation: rise .46s ease-out .08s both;
        }

        .panel-head {
            padding: 14px 16px;
            border-bottom: 1px solid var(--line);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .panel-head strong {
            font-size: 1rem;
        }

        .list {
            max-height: 72vh;
            overflow: auto;
        }

        .q-item {
            padding: 14px 16px;
            border-bottom: 1px solid #edf2f8;
        }

        .q-item:last-child {
            border-bottom: none;
        }

        .q-title {
            font-weight: 700;
        }

        .muted {
            color: var(--muted);
            font-size: .9rem;
        }

        .answer {
            display: inline-flex;
            align-items: center;
            padding: 4px 9px;
            border-radius: 999px;
            border: 1px solid #d6e2f2;
            color: #244264;
            background: #f8fbff;
            margin: 4px 6px 0 0;
            font-size: .82rem;
        }

        .answer.correct {
            border-color: #86efac;
            background: #f0fdf4;
            color: #166534;
        }

        .form-wrap {
            padding: 16px;
        }

        .form-label {
            font-weight: 700;
            font-size: .9rem;
        }

        .mode-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            border: 1px solid #d7e3f7;
            background: #f3f8ff;
            color: #23436f;
            padding: 4px 10px;
            font-size: .8rem;
            font-weight: 700;
        }

        .hidden {
            display: none;
        }

        @@keyframes rise {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@media (max-width: 992px) {
            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="shell">
        <section class="hero">
            <h1>@(quiz?.Title ?? "Quiz") - Câu hỏi</h1>
            <div class="meta">
                Khóa học: @quiz?.CourseName | Vai trò: @Model.CurrentRole | Tổng: @(quiz?.QuestionCount ?? 0) câu
            </div>
        </section>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="grid">
            <section class="panel">
                <header class="panel-head">
                    <strong>Ngân hàng câu hỏi</strong>
                    <a class="btn btn-sm btn-outline-secondary" href="/Admin/Quizzes">Quay lại</a>
                </header>
                <div class="list">
                    @if (quiz is not null && quiz.Questions.Any())
                    {
                        @foreach (var question in quiz.Questions.OrderBy(q => q.SortOrder))
                        {
                            <article class="q-item">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <div class="q-title">#@question.SortOrder - @question.QuestionText</div>
                                        <div class="muted">@question.QuestionType | @question.Point điểm</div>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <a class="btn btn-sm btn-outline-primary" href="/Admin/QuizQuestions?quizId=@Model.QuizId&editId=@question.Id">Sửa</a>
                                        <form method="post" asp-page-handler="Delete" asp-route-quizId="@Model.QuizId" asp-route-questionId="@question.Id" onsubmit="return confirm('Bạn có chắc muốn xóa câu hỏi này?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </div>
                                </div>

                                <div class="mt-2">
                                    @foreach (var option in question.Options.OrderBy(o => o.SortOrder))
                                    {
                                        <span class="answer @(option.IsCorrect ? "correct" : "")">@option.OptionText</span>
                                    }
                                </div>
                            </article>
                        }
                    }
                    else
                    {
                        <div class="p-4 muted">Chưa có câu hỏi nào trong quiz này.</div>
                    }
                </div>
            </section>

            <section class="panel">
                <header class="panel-head">
                    <strong>@(Model.Input.QuestionId.HasValue ? "Sửa câu hỏi" : "Thêm câu hỏi mới")</strong>
                    <span class="mode-chip" id="modeChip">Trắc nghiệm</span>
                </header>
                <div class="form-wrap">
                    <form method="post" asp-page="/Admin/QuizQuestions" asp-page-handler="Save" asp-route-quizId="@Model.QuizId">
                        <input type="hidden" name="quizId" value="@Model.QuizId" />
                        <input type="hidden" asp-for="Input.QuestionId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Input.QuestionText" class="form-label">Nội dung câu hỏi</label>
                            <textarea asp-for="Input.QuestionText" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label asp-for="Input.QuestionType" class="form-label">Loại câu hỏi</label>
                                <select asp-for="Input.QuestionType" class="form-select" id="questionType">
                                    <option value="MultipleChoice">Trắc nghiệm</option>
                                    <option value="FillInBlank">Điền đáp án</option>
                                </select>
                            </div>
                            <div class="col-3">
                                <label asp-for="Input.Point" class="form-label">Điểm</label>
                                <input asp-for="Input.Point" class="form-control" type="number" min="1" />
                            </div>
                            <div class="col-3">
                                <label asp-for="Input.SortOrder" class="form-label">Thứ tự</label>
                                <input asp-for="Input.SortOrder" class="form-control" type="number" min="0" />
                                <small class="text-muted">Để 0 để tự tăng.</small>
                            </div>
                        </div>

                        <div id="fillBlock" class="hidden">
                            <div class="mb-3">
                                <label asp-for="Input.FillInAnswer" class="form-label">Đáp án đúng</label>
                                <input asp-for="Input.FillInAnswer" class="form-control" />
                            </div>
                        </div>

                        <div id="mcqBlock">
                            <div class="row g-2">
                                <div class="col-12">
                                    <label class="form-label">Các lựa chọn</label>
                                </div>
                                <div class="col-12"><input asp-for="Input.OptionA" class="form-control" placeholder="Lựa chọn A" /></div>
                                <div class="col-12"><input asp-for="Input.OptionB" class="form-control" placeholder="Lựa chọn B" /></div>
                                <div class="col-12"><input asp-for="Input.OptionC" class="form-control" placeholder="Lựa chọn C (không bắt buộc)" /></div>
                                <div class="col-12"><input asp-for="Input.OptionD" class="form-control" placeholder="Lựa chọn D (không bắt buộc)" /></div>
                                <div class="col-12 mt-2">
                                    <label asp-for="Input.CorrectOptionSlot" class="form-label">Đáp án đúng</label>
                                    <select asp-for="Input.CorrectOptionSlot" class="form-select">
                                        <option value="1">A</option>
                                        <option value="2">B</option>
                                        <option value="3">C</option>
                                        <option value="4">D</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3 d-flex gap-2">
                            <a class="btn btn-outline-secondary" href="/Admin/QuizQuestions?quizId=@Model.QuizId">Làm mới</a>
                            <button type="submit" class="btn btn-primary">@(Model.Input.QuestionId.HasValue ? "Lưu câu hỏi" : "Thêm câu hỏi")</button>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>

    <script>
        (function () {
            const typeSelect = document.getElementById("questionType");
            const fillBlock = document.getElementById("fillBlock");
            const mcqBlock = document.getElementById("mcqBlock");
            const modeChip = document.getElementById("modeChip");

            function syncType() {
                const isFill = typeSelect.value === "FillInBlank";
                fillBlock.classList.toggle("hidden", !isFill);
                mcqBlock.classList.toggle("hidden", isFill);
                modeChip.textContent = isFill ? "Điền đáp án" : "Trắc nghiệm";
            }

            typeSelect.addEventListener("change", syncType);
            syncType();
        })();
    </script>
</body>
</html>
