@page
@model StudentManagementApp.Pages.Admin.QuizQuestionsModel
@{
    ViewData["Title"] = "Quản lý câu hỏi";
    ViewData["ActivePage"] = "Quizzes";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var quiz = Model.Quiz;
    var userName = HttpContext.Session.GetString("UserName");
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Thiết lập bài thi</h6>
        <h2 class="fw-bold mb-0">Quản lý câu hỏi</h2>
    </div>
    <a href="/Admin/Quizzes" class="btn btn-light border fw-bold px-4">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<!-- QUIZ INFO HERO -->
<div class="res-card p-4 border-0 shadow-sm mb-4 text-white" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%);">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h4 class="fw-bold mb-1">@(quiz?.Title ?? "Đang tải...")</h4>
            <p class="mb-0 opacity-75">Khóa học: @(quiz?.CourseName ?? "N/A") | Tổng câu hỏi hiện tại: <span class="badge bg-res-red">@(quiz?.QuestionCount ?? 0)</span></p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <div class="small opacity-75 mb-1 text-uppercase fw-bold">Thời gian làm bài</div>
            <div class="fs-5 fw-bold">@(quiz?.TimeLimitMinutes ?? 0) phút</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- LIST SECTION -->
    <div class="col-lg-7">
        <div class="admin-card h-100">
            <h5 class="fw-bold mb-4 border-bottom pb-2">Danh sách câu hỏi</h5>

            @if (quiz?.Questions?.Any() == true)
            {
                <div class="question-list">
                    @foreach (var q in quiz.Questions)
                    {
                        <div class="question-item mb-4 p-3 rounded-3 bg-light border-start border-4 border-res-red">
                            <div class="d-flex justify-content-between">
                                <div class="fw-bold text-dark mb-2">#@q.SortOrder - @q.QuestionText</div>
                                <span class="badge bg-white text-muted border small h-fit">@q.QuestionType</span>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mt-2">
                                @foreach (var o in q.Options)
                                {
                                    <span class="badge rounded-pill @(o.IsCorrect ? "bg-success" : "bg-white text-muted border") px-3 py-2">
                                        @if(o.IsCorrect) { <i class="bi bi-check-circle-fill me-1"></i> }
                                        @o.OptionText
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-file-earmark-plus display-1 opacity-25"></i>
                    <p class="mt-3 fw-bold">Chưa có câu hỏi nào được thêm.</p>
                </div>
            }
        </div>
    </div>

    <!-- FORM SECTION -->
    <div class="col-lg-5">
        <div class="admin-card sticky-top" style="top: 100px;">
            <h5 class="fw-bold mb-4 border-bottom pb-2">Thêm / Sửa câu hỏi</h5>

            <form method="post" asp-page-handler="Save" asp-route-quizId="@Model.QuizId">
                <input type="hidden" asp-for="Input.QuestionId" />

                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted text-uppercase">Nội dung câu hỏi</label>
                    <textarea asp-for="Input.QuestionText" class="form-control" rows="3" placeholder="Nhập nội dung câu hỏi..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small text-muted text-uppercase">Loại câu hỏi</label>
                    <select asp-for="Input.QuestionType" id="typeSelector" class="form-select fw-bold">
                        <option value="MultipleChoice">Trắc nghiệm (MCQ)</option>
                        <option value="FillInBlank">Điền vào chỗ trống</option>
                    </select>
                </div>

                <!-- MCQ OPTIONS -->
                <div id="mcqContainer">
                    <div class="mb-2">
                        <input asp-for="Input.OptionA" class="form-control" placeholder="Đáp án A">
                    </div>
                    <div class="mb-2">
                        <input asp-for="Input.OptionB" class="form-control" placeholder="Đáp án B">
                    </div>
                    <div class="mb-2">
                        <input asp-for="Input.OptionC" class="form-control" placeholder="Đáp án C">
                    </div>
                    <div class="mb-2">
                        <input asp-for="Input.OptionD" class="form-control" placeholder="Đáp án D">
                    </div>
                    <p class="small text-muted mt-2 italic"><i class="bi bi-info-circle me-1"></i>Mặc định đáp án A là đáp án đúng cho Trắc nghiệm.</p>
                </div>

                <!-- FILL IN BLANK -->
                <div id="fillContainer" class="d-none">
                    <div class="mb-2">
                        <input asp-for="Input.FillInAnswer" class="form-control border-primary" placeholder="Nhập đáp án đúng...">
                    </div>
                    <p class="small text-muted mt-2 italic"><i class="bi bi-info-circle me-1"></i>Hệ thống sẽ so khớp chính xác đáp án này.</p>
                </div>

                <button type="submit" class="btn btn-primary-res w-100 mt-4 py-3 fw-bold">
                    <i class="bi bi-save me-2"></i>Lưu câu hỏi
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    .h-fit { height: fit-content; }
    .italic { font-style: italic; }
    .question-item { transition: all 0.2s; }
    .question-item:hover { transform: translateX(5px); }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const typeSelector = document.getElementById("typeSelector");
            const mcqContainer = document.getElementById("mcqContainer");
            const fillContainer = document.getElementById("fillContainer");

            function toggleInputs() {
                if (typeSelector.value === "FillInBlank") {
                    mcqContainer.classList.add("d-none");
                    fillContainer.classList.remove("d-none");
                } else {
                    mcqContainer.classList.remove("d-none");
                    fillContainer.classList.add("d-none");
                }
            }

            typeSelector.addEventListener("change", toggleInputs);
            toggleInputs();
        });
    </script>
}