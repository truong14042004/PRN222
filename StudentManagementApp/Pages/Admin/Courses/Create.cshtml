@page
@model StudentManagementApp.Pages.Admin.Courses.CreateModel
@{
    ViewData["Title"] = "Tạo khóa học mới";
    ViewData["ActivePage"] = "Courses";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var userName = HttpContext.Session.GetString("UserName");
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Chương trình đào tạo</h6>
        <h2 class="fw-bold mb-0">Thêm khóa học mới</h2>
    </div>
    <a href="/Admin/Courses" class="btn btn-light border fw-bold px-4">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="admin-card">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm rounded-4 mb-4"></div>

                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted text-uppercase">Tên khóa học</label>
                            <input asp-for="Input.Name" class="form-control fw-bold fs-5" placeholder="Nhập tên khóa học..." />
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted text-uppercase">Mô tả khóa học</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="6" placeholder="Nhập mô tả chi tiết chương trình học..."></textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Cấp độ đào tạo</label>
                                <select asp-for="Input.Level" class="form-select fw-bold">
                                    <option value="">-- Chọn cấp độ --</option>
                                    <option value="A1">Cấp độ A1 - Beginner</option>
                                    <option value="A2">Cấp độ A2 - Elementary</option>
                                    <option value="B1">Cấp độ B1 - Intermediate</option>
                                    <option value="B2">Cấp độ B2 - Upper</option>
                                    <option value="C1">Cấp độ C1 - Advanced</option>
                                    <option value="C2">Cấp độ C2 - Master</option>
                                </select>
                                <span asp-validation-for="Input.Level" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Học phí niêm yết (VNĐ)</label>
                                <div class="input-group">
                                    <input asp-for="Input.TuitionFee" type="number" min="0" class="form-control fw-bold text-res-red" placeholder="0" />
                                    <span class="input-group-text bg-white">đ</span>
                                </div>
                                <span asp-validation-for="Input.TuitionFee" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-4 h-100">
                            <label class="form-label fw-bold small text-muted text-uppercase">Hình ảnh đại diện</label>
                            <input asp-for="Input.ThumbnailUrl" class="form-control mb-3" id="thumbInput" placeholder="Dán link ảnh tại đây..." />
                            
                            <div id="previewBox" style="display:none;">
                                <img id="previewImg" class="thumbnail-preview shadow-sm mb-3" />
                                <div class="small text-muted text-center italic">Xem trước hiển thị</div>
                            </div>

                            <div id="emptyPreview" class="thumbnail-preview-placeholder d-flex flex-column align-items-center justify-content-center text-muted border-dashed">
                                <i class="bi bi-image fs-1 mb-2"></i>
                                <div class="small fw-bold">Chưa có ảnh</div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-5 opacity-50">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary-res px-5 py-3 fw-bold shadow-sm">
                        <i class="bi bi-plus-circle me-2"></i>Khởi tạo khóa học
                    </button>
                    <a href="/Admin/Courses" class="btn btn-light border px-5 py-3 fw-bold">
                        Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .thumbnail-preview, .thumbnail-preview-placeholder {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-radius: 12px;
    }
    .thumbnail-preview { border: 2px solid white; }
    .thumbnail-preview-placeholder {
        background: #f1f5f9;
        border: 2px dashed #cbd5e1;
    }
    .form-control, .form-select {
        padding: 0.75rem 1rem;
        border-radius: 12px !important;
        border: 1px solid #e2e8f0;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--res-red);
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }
    .border-dashed { border-style: dashed !important; }
    .italic { font-style: italic; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const input = document.getElementById("thumbInput");
            const previewBox = document.getElementById("previewBox");
            const emptyPreview = document.getElementById("emptyPreview");
            const img = document.getElementById("previewImg");

            input.addEventListener("input", function () {
                if (this.value) {
                    img.src = this.value;
                    previewBox.style.display = "block";
                    emptyPreview.style.display = "none";
                } else {
                    previewBox.style.display = "none";
                    emptyPreview.style.display = "flex";
                }
            });
        });
    </script>
}