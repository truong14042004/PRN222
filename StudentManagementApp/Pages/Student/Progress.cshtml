@page
@model StudentManagementApp.Pages.Student.ProgressModel
@{
    ViewData["Title"] = "Tiến độ học tập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-4 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h1 class="mb-1">Tiến độ học tập</h1>
                <div class="text-muted">Xin chào, @Model.UserName</div>
            </div>
            <a href="/Student" class="btn btn-outline-secondary">Về trang học viên</a>
        </div>

        @if (Model.Progresses.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-bordered bg-white">
                    <thead>
                        <tr>
                            <th>Khóa học</th>
                            <th>Bài học hoàn thành</th>
                            <th>Tỷ lệ hoàn thành</th>
                            <th>Số quiz đã làm</th>
                            <th>Điểm quiz trung bình</th>
                            <th>Cập nhật gần nhất</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Progresses)
                        {
                            <tr>
                                <td>@p.CourseName</td>
                                <td>@p.CompletedLessons / @p.TotalLessons</td>
                                <td>@p.Percentage.ToString("F1")%</td>
                                <td>@p.QuizzesTaken</td>
                                <td>@p.AverageScore.ToString("F1")%</td>
                                <td>@p.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">Chưa có dữ liệu tiến độ cho bạn.</div>
        }
    </div>
</body>
</html>
