@using StudentManagementApp.BLL.DTOs
@model IEnumerable<ClassDto>

@{
    ViewData["Title"] = "Quản lý lớp học";
    string[] days = { "", "CN", "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "CN" };
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Quản lý lớp học</h4>
        <a asp-action="CreateClass" class="btn btn-primary rounded-pill px-4">
            <i class="fa fa-plus me-1"></i> Thêm lớp học
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3 pb-2 px-3">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="q" value="@ViewBag.Q" class="form-control" placeholder="Tìm theo tên lớp, khóa học, giáo viên..." />
                <button type="submit" class="btn btn-outline-primary rounded-pill px-3"><i class="fa fa-search"></i></button>
                @if (!string.IsNullOrEmpty(ViewBag.Q as string))
                {
                    <a asp-action="Classes" class="btn btn-outline-secondary rounded-pill px-3">Xóa</a>
                }
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Lớp</th>
                        <th>Khóa học</th>
                        <th>Giáo viên</th>
                        <th>Lịch học</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cls in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@cls.ClassName</td>
                            <td>@cls.CourseName</td>
                            <td>@(cls.TeacherName ?? "Chưa có")</td>
                            <td class="small">
                                @string.Join(", ", cls.Schedules.Select(s => $"{days[s.DayOfWeek]} {s.StartTime:hh\\:mm}"))
                            </td>
                            <td class="small">@cls.StartDate.ToString("dd/MM/yy") — @cls.EndDate.ToString("dd/MM/yy")</td>
                            <td>
                                <span class="badge @(cls.Status == "Ongoing" ? "bg-success" : cls.Status == "Upcoming" ? "bg-primary" : "bg-secondary")">
                                    @(cls.Status == "Ongoing" ? "Đang học" : cls.Status == "Upcoming" ? "Sắp khai giảng" : "Kết thúc")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if ((int)ViewBag.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                        <a class="page-link" asp-action="Classes" asp-route-q="@ViewBag.Q" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
        <p class="text-center text-muted small">Tổng: @ViewBag.TotalCount lớp học</p>
    }
</div>
