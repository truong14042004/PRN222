@using StudentManagementApp.BLL.DTOs
@model IEnumerable<UserDto>

@{
    ViewData["Title"] = "Quản lý người dùng";
    string tab = ViewBag.Tab ?? "students";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Quản lý người dùng</h4>
        <a asp-action="CreateTeacher" class="btn btn-primary rounded-pill px-4">
            <i class="fa fa-plus me-1"></i> Thêm giáo viên
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- Tab buttons -->
    <div class="mb-3 d-flex gap-2">
        <a asp-action="Users" asp-route-tab="students" asp-route-q="@ViewBag.Q"
           class="btn rounded-pill @(tab == "students" ? "btn-primary" : "btn-outline-primary")">
            <i class="fa fa-user-graduate me-1"></i> Học viên
        </a>
        <a asp-action="Users" asp-route-tab="teachers" asp-route-q="@ViewBag.Q"
           class="btn rounded-pill @(tab == "teachers" ? "btn-success" : "btn-outline-success")">
            <i class="fa fa-chalkboard-teacher me-1"></i> Giáo viên
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3 pb-2 px-3">
            <form method="get" class="d-flex gap-2">
                <input type="hidden" name="tab" value="@tab" />
                <input type="text" name="q" value="@ViewBag.Q" class="form-control"
                       placeholder="Tìm theo tên, email, số điện thoại..." />
                <button type="submit" class="btn btn-outline-primary rounded-pill px-3"><i class="fa fa-search"></i></button>
                @if (!string.IsNullOrEmpty(ViewBag.Q as string))
                {
                    <a asp-action="Users" asp-route-tab="@tab" class="btn btn-outline-secondary rounded-pill px-3">Xóa</a>
                }
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        @if (tab == "teachers")
                        {
                            <th>Trạng thái</th>
                        }
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@(user.Phone ?? "—")</td>
                            @if (tab == "teachers")
                            {
                                <td>
                                    <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">
                                        @(user.IsActive ? "Hoạt động" : "Vô hiệu")
                                    </span>
                                </td>
                            }
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill"
                                        data-bs-toggle="modal" data-bs-target="#emailModal"
                                        data-userid="@user.Id" data-email="@user.Email">
                                    Sửa Email
                                </button>
                                @if (tab == "teachers")
                                {
                                    <form asp-action="ToggleUser" method="post" class="d-inline ms-1">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <input type="hidden" name="tab" value="@tab" />
                                        <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success") rounded-pill">
                                            @(user.IsActive ? "Vô hiệu hóa" : "Kích hoạt")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if ((int)ViewBag.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                        <a class="page-link" asp-action="Users" asp-route-tab="@tab" asp-route-q="@ViewBag.Q" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
        <p class="text-center text-muted small">Tổng: @ViewBag.TotalCount người dùng</p>
    }
</div>

<!-- Modal sửa Email -->
<div class="modal fade" id="emailModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold">Cập nhật email</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateEmail" method="post">
                <div class="modal-body">
                    <input type="hidden" name="userId" id="modalUserId" />
                    <input type="hidden" name="tab" value="@tab" />
                    <input type="email" name="newEmail" id="modalEmail" class="form-control" placeholder="Email mới" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('emailModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('modalUserId').value = btn.getAttribute('data-userid');
            document.getElementById('modalEmail').value = btn.getAttribute('data-email') || '';
        });
    </script>
}
