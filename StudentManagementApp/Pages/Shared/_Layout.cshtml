    @if (userRole == "Student" && !string.IsNullOrWhiteSpace(userId))
    {
        <div id="notificationToastContainer" class="notification-toast-container position-fixed top-0 end-0 p-3"></div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @if (userRole == "Student" && !string.IsNullOrWhiteSpace(userId))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
        <script>
            (() => {
                const toastContainer = document.getElementById("notificationToastContainer");
                if (!toastContainer || typeof signalR === "undefined") {
                    return;
                }

                const buildToast = (notification) => {
                    const wrapper = document.createElement("div");
                    wrapper.className = "toast notification-toast border-0 shadow-sm";
                    wrapper.role = "alert";
                    wrapper.ariaLive = "assertive";
                    wrapper.ariaAtomic = "true";

                    const header = document.createElement("div");
                    header.className = "toast-header";

                    const icon = document.createElement("i");
                    icon.className = "bi bi-bell-fill text-res-red me-2";

                    const title = document.createElement("strong");
                    title.className = "me-auto";
                    title.textContent = notification.title || "Thông báo mới";

                    const time = document.createElement("small");
                    const confirmedAt = notification.confirmedAt ? new Date(notification.confirmedAt) : null;
                    time.textContent = confirmedAt && !Number.isNaN(confirmedAt.valueOf())
                        ? confirmedAt.toLocaleTimeString("vi-VN", { hour: "2-digit", minute: "2-digit" })
                        : "Vừa xong";

                    const closeButton = document.createElement("button");
                    closeButton.type = "button";
                    closeButton.className = "btn-close";
                    closeButton.setAttribute("data-bs-dismiss", "toast");
                    closeButton.setAttribute("aria-label", "Close");

                    header.append(icon, title, time, closeButton);

                    const body = document.createElement("div");
                    body.className = "toast-body";
                    body.textContent = notification.message || "Bạn có thông báo mới.";

                    wrapper.append(header, body);
                    return wrapper;
                };

                const showToast = (notification) => {
                    const toastElement = buildToast(notification);
                    toastContainer.appendChild(toastElement);

                    const toast = bootstrap.Toast.getOrCreateInstance(toastElement, {
                        autohide: true,
                        delay: 8000
                    });

                    toastElement.addEventListener("hidden.bs.toast", () => {
                        toastElement.remove();
                    }, { once: true });

                    toast.show();
                };

                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/hubs/notifications")
                    .withAutomaticReconnect()
                    .build();

                connection.on("EnrollmentConfirmed", showToast);
                connection.start().catch((error) => {
                    console.error("SignalR enrollment notification connection failed.", error);
                });
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
