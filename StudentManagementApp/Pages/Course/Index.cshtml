@page
@model StudentManagementApp.Pages.Course.IndexModel
@{
    ViewData["Title"] = "Danh sách khóa học";
}

<section class="py-5 bg-light">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="res-section-title center">CÁC KHÓA HỌC TẠI MESH</h2>
            <p class="text-muted">Chúng tôi cung cấp đa dạng các lộ trình phù hợp với mọi trình độ và nhu cầu học tập.</p>
        </div>

        <div class="row g-4">
            @if (Model.Courses != null && Model.Courses.Any())
            {
                @foreach (var course in Model.Courses)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="res-card d-flex flex-column">
                            <div class="position-relative">
                                <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=2022&auto=format&fit=crop" class="card-img-top" alt="@course.Name" style="height: 200px; object-fit: cover;">
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-res-red text-white px-3 py-2 rounded-pill fw-bold">@course.Level</span>
                                </div>
                            </div>
                            <div class="card-body p-4 flex-grow-1">
                                <h5 class="fw-bold mb-3">@course.Name</h5>
                                <p class="text-muted small mb-4 text-truncate-3">@course.Description</p>
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <div class="text-res-red fw-bold h5 mb-0">@course.TuitionFee.ToString("N0") VNĐ</div>
                                    <a href="/Course/Detail/@course.Id" class="btn btn-outline-res btn-sm">CHI TIẾT</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Hiện chưa có khóa học nào được đăng tải.</p>
                </div>
            }
        </div>
    </div>
</section>

@section Styles {
    <style>
        .text-truncate-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
}
