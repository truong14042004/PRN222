@page "{id:int}"
@model StudentManagementApp.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Sửa người dùng";
    ViewData["ActivePage"] = "Users";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Chỉnh sửa thông tin</h6>
        <h2 class="fw-bold mb-0">@Model.Input.FullName</h2>
    </div>
    <a href="/Admin/Users?tab=@Model.Tab" class="btn btn-light border fw-bold px-4">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="admin-card">
            <form method="post">
                <input asp-for="Input.Id" type="hidden" />
                <input asp-for="Tab" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm rounded-4 mb-4"></div>

                <!-- Avatar Section -->
                <div class="mb-5 d-flex align-items-center gap-4 p-4 bg-light rounded-4">
                    <img src="@(string.IsNullOrEmpty(Model.Input.AvatarUrl) ? "/images/default-avatar.png" : Model.Input.AvatarUrl)"
                         class="avatar-preview shadow-sm" id="avatarImg" />
                    <div class="flex-grow-1">
                        <label class="form-label fw-bold small text-muted text-uppercase">URL Ảnh đại diện</label>
                        <input asp-for="Input.AvatarUrl" class="form-control" placeholder="Nhập liên kết ảnh..." 
                               oninput="document.getElementById('avatarImg').src = this.value || '/images/default-avatar.png'" />
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Họ tên</label>
                        <input asp-for="Input.FullName" class="form-control fw-bold" placeholder="Nhập họ và tên..." />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Email</label>
                        <input asp-for="Input.Email" type="email" class="form-control" placeholder="example@email.com" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Số điện thoại</label>
                        <input asp-for="Input.Phone" class="form-control" placeholder="Nhập số điện thoại..." />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Tên đăng nhập</label>
                        <input asp-for="Input.Username" class="form-control bg-light" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Vai trò</label>
                        <input asp-for="Input.Role" class="form-control bg-light" readonly />
                    </div>

                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check form-switch mb-2">
                            <input asp-for="Input.IsActive" class="form-check-input" style="width: 3em; height: 1.5em;" />
                            <label asp-for="Input.IsActive" class="form-check-label ms-2 fw-bold text-dark">
                                Tài khoản đang hoạt động
                            </label>
                        </div>
                    </div>
                </div>

                <hr class="my-5 opacity-50">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary-res px-5 py-3 fw-bold">
                        <i class="bi bi-save me-2"></i>Lưu thay đổi
                    </button>
                    <a href="/Admin/Users?tab=@Model.Tab" class="btn btn-light border px-5 py-3 fw-bold">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .avatar-preview {
        width: 100px;
        height: 100px;
        border-radius: 24px;
        object-fit: cover;
        border: 4px solid white;
    }
    .form-control {
        padding: 0.75rem 1rem;
        border-radius: 12px !important;
        border: 1px solid #e2e8f0;
    }
    .form-control:focus {
        border-color: var(--res-red);
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }
</style>