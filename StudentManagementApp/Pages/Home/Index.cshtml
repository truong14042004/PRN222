@page
@model StudentManagementApp.Pages.Home.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
    var userId = HttpContext.Session.GetString("UserId");
}

@section Styles {
    <style>
        .hero-section {
            position: relative;
            width: 100%;
            height: 600px;
            background: url('/images/banner.jpg') no-repeat center center;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            margin-top: -10px; /* Offset to connect with navbar */
        }

        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.2));
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 800px;
        }

        .hero-content h1 {
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
        }

        .search-container {
            background: white;
            padding: 15px;
            border-radius: 10px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.05);
            margin-top: -40px;
            position: relative;
            z-index: 10;
        }
        
        .course-card img {
            height: 200px;
            object-fit: cover;
        }
    </style>
}

<div class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1>Nền tảng Quản lý Tiếng Anh Hiện đại</h1>
        <p class="lead">Đồng hành cùng học viên vươn tới đỉnh cao tri thức cùng trung tâm English Center.</p>
        @if (userId == null)
        {
            <a class="btn btn-primary-res btn-lg rounded-pill px-5 py-3 shadow-lg mt-3" href="/Auth/Register">KHÁM PHÁ NGAY</a>
        }
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="search-container">
                <form method="get" class="row g-2">
                    <div class="col-md-9">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="Bạn muốn tìm khóa học nào?" value="@ViewData["Q"]">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary-res w-100 rounded-pill">Tìm kiếm</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <h2 class="res-section-title center">CÁC KHÓA HỌC NỔI BẬT</h2>
        
        <div class="row mt-4">
            @if (Model.Courses != null && Model.Courses.Any())
            {
                @foreach (var course in Model.Courses)
                {
                    <div class="col-md-4 mb-4">
                        <div class="res-card course-card">
                            @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                            {
                                <img src="@course.ThumbnailUrl" class="card-img-top" alt="@course.Name">
                            }
                            else
                            {
                                <img src="https://via.placeholder.com/400x250?text=English+Course" class="card-img-top" alt="Default Thumbnail">
                            }
                            <div class="card-body">
                                <span class="badge-res bg-res-red text-white mb-2 d-inline-block">LEVEL: @course.Level</span>
                                <h5 class="card-title fw-bold">@course.Name</h5>
                                <p class="card-text text-muted small">@course.Description</p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="text-res-red fw-bold h5 mb-0">@course.TuitionFee.ToString("N0") <small>VNĐ</small></span>
                                    <a href="/Course/Detail/@course.Id" class="btn btn-outline-res btn-sm rounded-pill px-3">Chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Không tìm thấy khóa học phù hợp.</p>
                </div>
            }
        </div>
    </div>
</div>
