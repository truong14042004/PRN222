@using StudentManagementApp.BLL.DTOs
@model IEnumerable<EnrollmentDto>

@{
    ViewData["Title"] = "Điểm danh";
    var cls = ViewBag.Class as ClassDto;
    var date = (DateOnly)ViewBag.Date;
    var hasSession = (bool)ViewBag.HasSession;
    var existing = ViewBag.Existing as Dictionary<int, AttendanceDto> ?? new();
    string[] dayNames = { "", "CN", "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "CN" };
    var scheduleDays = cls?.Schedules.Select(s => dayNames[s.DayOfWeek]).ToList() ?? new();
    int dow = (int)date.DayOfWeek;
    int appDow = dow == 0 ? 8 : dow + 1;
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Điểm danh — @cls?.ClassName</h4>
            <p class="text-muted mb-0">
                Lịch học: @(scheduleDays.Any() ? string.Join(", ", scheduleDays) : "—")
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">Quay lại</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- Today banner -->
    <div class="alert alert-primary d-flex align-items-center mb-4">
        <i class="fa fa-calendar-day fs-4 me-3"></i>
        <div>
            <div class="fw-bold">Điểm danh ngày hôm nay</div>
            <div class="fs-5">@dayNames[appDow] — @date.ToString("dd/MM/yyyy")</div>
        </div>
    </div>

    @if (!hasSession)
    {
        <div class="alert alert-warning">
            <i class="fa fa-exclamation-triangle me-1"></i>
            Hôm nay không có tiết học của lớp này.
            Các buổi học trong tuần: <strong>@string.Join(", ", scheduleDays)</strong>.
        </div>
    }
    else if (!Model.Any())
    {
        <div class="alert alert-info">Lớp này chưa có học viên được xác nhận.</div>
    }
    else
    {
        <form asp-action="SaveAttendance" method="post">
            <input type="hidden" name="ClassId" value="@cls?.Id" />
            <input type="hidden" name="Date" value="@date.ToString("yyyy-MM-dd")" />

            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Học viên</th>
                                <th class="text-center">Có mặt</th>
                                <th>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int i = 0; }
                            @foreach (var e in Model)
                            {
                                var att = existing.GetValueOrDefault(e.StudentId);
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td class="fw-semibold">@e.StudentName</td>
                                    <td class="text-center">
                                        <input type="hidden" name="Items[@i].StudentId" value="@e.StudentId" />
                                        <input type="checkbox" name="Items[@i].IsPresent" value="true"
                                               class="form-check-input fs-5"
                                               @(att?.IsPresent == true ? "checked" : "") />
                                    </td>
                                    <td>
                                        <input type="text" name="Items[@i].Note" class="form-control form-control-sm"
                                               value="@(att?.Note ?? "")" placeholder="Ghi chú..." />
                                    </td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">Lưu điểm danh</button>
            </div>
        </form>
    }
</div>
