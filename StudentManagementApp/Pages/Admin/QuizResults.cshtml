@page
@model StudentManagementApp.Pages.Admin.QuizResultsModel
@{
    ViewData["Title"] = "Kết quả quiz";
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                font-family: "Be Vietnam Pro", sans-serif;
                background: #f5f7fb;
                margin: 0;
            }

            /* SIDEBAR */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                background: #0f172a;
                color: white;
                padding: 20px;
            }

                .sidebar h4 {
                    font-weight: 700;
                    margin-bottom: 30px;
                }

                .sidebar a {
                    display: block;
                    color: #cbd5f1;
                    padding: 10px 12px;
                    border-radius: 10px;
                    text-decoration: none;
                    margin-bottom: 8px;
                }

                    .sidebar a:hover,
                    .sidebar a.active {
                        background: #1e293b;
                        color: white;
                    }

            /* MAIN */
            .main {
                margin-left: 250px;
                padding: 20px 30px;
            }

            /* CARDS */
            .card-dashboard {
                border-radius: 16px;
                padding: 20px;
                color: white;
                box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            }

            .bg-primary-grad {
                background: linear-gradient(135deg, #3b82f6, #6366f1);
            }

            .bg-success-grad {
                background: linear-gradient(135deg, #22c55e, #16a34a);
            }

            .bg-info-grad {
                background: linear-gradient(135deg, #06b6d4, #0ea5e9);
            }

            /* TABLE */
            .table-box {
                background: white;
                border-radius: 16px;
                overflow: hidden;
                box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            }

            .table th {
                background: #f1f5f9;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>🎓 Admin</h4>

        <a href="/Admin">Dashboard</a>
        <a href="/Admin/Users">Người dùng</a>
        <a href="/Admin/Courses">Khóa học</a>
        <a href="/Admin/Classes">Lớp học</a>
        <a href="/Admin/Enrollments">Đăng ký</a>
        <a class="active" href="/Admin/Quizzes">Quiz</a>

        <hr style="border-color:#334155">

        <a href="/Auth/Logout">🚪 Đăng xuất</a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOP -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="mb-0">Kết quả Quiz</h3>
                <small class="text-muted">Xin chào, @userName</small>
            </div>

            <a href="/Admin/Quizzes" class="btn btn-outline-secondary">← Quay lại</a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <!-- FILTER -->
        <div class="card mb-4">
            <div class="card-body">

                <form method="get" class="row g-2 align-items-end">

                    <div class="col-md-9">
                        <label class="form-label">Chọn quiz</label>
                        <select name="quizId" class="form-select">
                            <option value="">-- Chọn quiz --</option>
                            @foreach (var quiz in Model.AvailableQuizzes)
                            {
                                <option value="@quiz.Id" selected="@(Model.QuizId == quiz.Id)">
                                    @quiz.CourseName - @quiz.Title
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button class="btn btn-primary w-100">Xem</button>
                    </div>

                </form>

            </div>
        </div>

        @if (Model.SelectedQuiz != null)
        {
            <!-- STATS -->
            <div class="row g-4 mb-4">

                <div class="col-md-4">
                    <div class="card-dashboard bg-primary-grad text-center">
                        <h2>@Model.TotalAttempts</h2>
                        <p>Lượt làm</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-dashboard bg-success-grad text-center">
                        <h2>@Model.PassedCount</h2>
                        <p>Đạt</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card-dashboard bg-info-grad text-center">
                        <h2>@Model.AveragePercent.ToString("F1")%</h2>
                        <p>Điểm trung bình</p>
                    </div>
                </div>

            </div>

            <!-- TABLE -->
            @if (Model.Results.Any())
            {
                <div class="table-box">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Học viên</th>
                                <th>Điểm</th>
                                <th>%</th>
                                <th>Đúng</th>
                                <th>Thời gian</th>
                                <th>Nộp lúc</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var r in Model.Results)
                            {
                                <tr>
                                    <td class="fw-semibold">@r.StudentName</td>
                                    <td>@r.Score / @r.TotalPoints</td>
                                    <td>@r.PercentageScore</td>
                                    <td>@r.CorrectCount / @r.TotalQuestions</td>
                                    <td>@r.TimeTaken.ToString(@"hh\:mm\:ss")</td>
                                    <td>@r.CompletedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge bg-@(r.Passed ? "success" : "danger")">
                                            @(r.Passed ? "Đạt" : "Rớt")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">Chưa có kết quả nào.</div>
            }
        }

    </div>

</body>
</html>