@page
@model StudentManagementApp.Pages.Home.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
    var userName = HttpContext.Session.GetString("UserName");
    var userRole = HttpContext.Session.GetString("UserRole");
    var userId = HttpContext.Session.GetString("UserId");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">English Center</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Course">Khóa học</a></li>
                    @if (userRole == "Student" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Student">Học viên</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Student/Schedule">Lịch học</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Student/AttendanceReport">Điểm danh</a></li>
                    }
                    @if (userRole == "Teacher" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Teacher">Lớp dạy</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Teacher/Schedule">Lịch dạy</a></li>
                    }
                    @if (userRole == "Admin" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Admin">Quản trị</a></li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (userId != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                Xin chào, @userName
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Auth/Logout">Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Auth/Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Auth/Register">Đăng ký</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="jumbotron bg-light p-5 rounded">
            <h1 class="display-4">Chào mừng đến với English Center</h1>
            <p class="lead">Nền tảng quản lý trung tâm Anh ngữ hiện đại</p>
            <hr class="my-4">
            @if (userId == null)
            {
                <p>Đăng ký ngay để tham gia các khóa học tiếng Anh chất lượng cao.</p>
                <a class="btn btn-primary btn-lg" href="/Auth/Register">Đăng ký ngay</a>
            }
        </div>

        <div class="row mt-5">
            <div class="col-md-12">
                <h2>Danh sách khóa học</h2>
                
                <form method="get" class="mb-4">
                    <div class="row">
                        <div class="col-md-6">
                            <input type="text" name="q" class="form-control" placeholder="Tìm kiếm khóa học..." value="@ViewData["Q"]">
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-secondary">Tìm kiếm</button>
                        </div>
                    </div>
                </form>

                <div class="row">
                    @if (Model.Courses != null && Model.Courses.Any())
                    {
                        @foreach (var course in Model.Courses)
                        {
                            <div class="col-md-4 mb-4">
                                <div class="card h-100">
                                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                                    {
                                        <img src="@course.ThumbnailUrl" class="card-img-top" alt="@course.Name">
                                    }
                                    <div class="card-body">
                                        <h5 class="card-title">@course.Name</h5>
                                        <span class="badge bg-info">@course.Level</span>
                                        <p class="card-text">@course.Description</p>
                                        <p class="card-text"><strong>Học phí:</strong> @course.TuitionFee.ToString("N0") VNĐ</p>
                                    </div>
                                    <div class="card-footer">
                                        <a href="/Course/Detail/@course.Id" class="btn btn-primary">Xem chi tiết</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <p class="text-muted">Không có khóa học nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-dark text-white mt-5 py-3">
        <div class="container text-center">
            <p>&copy; 2026 English Center. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
