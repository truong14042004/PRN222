@page
@model StudentManagementApp.Pages.Student.QuizResultModel
@{
    ViewData["Title"] = "Kết quả quiz";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            :root {
                --bg: #f4f7fd;
                --ink: #0f172a;
                --muted: #64748b;
                --line: #dbe4f1;
                --success: #22c55e;
                --danger: #ef4444;
            }

            body {
                font-family: "Be Vietnam Pro", sans-serif;
                background: radial-gradient(760px 380px at 0% 0%, #dbeafe 0%, transparent 70%), radial-gradient(760px 380px at 100% 100%, #dcfce7 0%, transparent 70%), var(--bg);
            }

            .shell {
                max-width: 900px;
                margin: auto;
                padding: 30px 15px;
            }

            .panel {
                background: #fff;
                border-radius: 20px;
                padding: 24px;
                box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            }

            .muted {
                color: var(--muted);
            }

            .kpi {
                border-radius: 14px;
                padding: 14px;
                text-align: center;
                background: #f8fbff;
                transition: 0.2s;
            }

                .kpi:hover {
                    transform: translateY(-3px);
                }

            .kpi-value {
                font-size: 1.4rem;
                font-weight: 800;
            }

            .progress {
                height: 10px;
                border-radius: 10px;
            }

            .review-item {
                border-radius: 14px;
                padding: 14px;
                transition: 0.2s;
            }

                .review-item.correct {
                    border-left: 5px solid var(--success);
                    background: #f0fdf4;
                }

                .review-item.wrong {
                    border-left: 5px solid var(--danger);
                    background: #fef2f2;
                }

                .review-item:hover {
                    transform: translateY(-2px);
                }

            .result-badge {
                font-size: 1.1rem;
                padding: 8px 14px;
            }
    </style>
</head>

<body>
    <div class="shell">

        @if (Model.Result is null)
        {
            <div class="alert alert-warning">Không tìm thấy kết quả bài làm.</div>
            <a class="btn btn-outline-secondary" href="/Student/Quizzes">Quay lại</a>
        }
        else
        {
            <section class="panel">

                <!-- HEADER -->
                <h2 class="fw-bold">@Model.Result.QuizTitle</h2>
                <div class="muted mb-3">
                    Nộp bài lúc @Model.Result.CompletedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </div>

                <!-- KPI -->
                <div class="row g-3 mb-3">
                    <div class="col-md-3 col-6">
                        <div class="kpi">
                            <div class="muted">Điểm</div>
                            <div class="kpi-value">@Model.Result.Score / @Model.Result.TotalPoints</div>
                        </div>
                    </div>

                    <div class="col-md-3 col-6">
                        <div class="kpi">
                            <div class="muted">Tỷ lệ</div>
                            <div class="kpi-value">@Model.Result.PercentageScore</div>
                        </div>
                    </div>

                    <div class="col-md-3 col-6">
                        <div class="kpi">
                            <div class="muted">Đúng</div>
                            <div class="kpi-value">@Model.Result.CorrectCount / @Model.Result.TotalQuestions</div>
                        </div>
                    </div>

                    <div class="col-md-3 col-6">
                        <div class="kpi">
                            <div class="muted">Thời gian</div>
                            <div class="kpi-value">@Model.Result.TimeTaken.ToString(@"hh\:mm\:ss")</div>
                        </div>
                    </div>
                </div>

                <!-- PROGRESS BAR -->
                <div class="mb-3">
                    <div class="progress">
                        <div class="progress-bar bg-success"
                             style="width:@Model.Result.PercentageScore.Replace("%", "")%">
                        </div>
                    </div>
                </div>

                <!-- PASS / FAIL -->
                <div class="mb-3">
                    <span class="badge result-badge bg-@(Model.Result.Passed ? "success" : "danger")">
                        @(Model.Result.Passed ? "🎉 Đạt" : "❌ Chưa đạt")
                    </span>
                </div>

                <!-- REVIEW -->
                @if (Model.Result.AnswerReviews.Any())
                {
                    <h5 class="mb-3">Chi tiết bài làm</h5>

                    <div class="d-grid gap-2">
                        @foreach (var review in Model.Result.AnswerReviews)
                        {
                            <div class="review-item @(review.IsCorrect ? "correct" : "wrong")">

                                <div class="d-flex justify-content-between">
                                    <div>
                                        <strong>Câu @review.SortOrder:</strong>
                                        @review.QuestionText
                                    </div>

                                    <span class="badge bg-@(review.IsCorrect ? "success" : "danger")">
                                        @(review.IsCorrect ? "Đúng" : "Sai")
                                    </span>
                                </div>

                                <div class="mt-2 small text-muted">
                                    Bạn chọn:
                                    @(string.IsNullOrWhiteSpace(review.StudentAnswer)
                                        ? "(Không trả lời)"
                                        : review.StudentAnswer)
                                </div>

                                <div class="small">
                                    Đáp án đúng: <strong>@review.CorrectAnswer</strong>
                                </div>

                                <div class="small text-muted">
                                    Điểm: @review.PointsEarned / @review.Point
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- ACTION -->
                <div class="mt-4 d-flex gap-2">
                    <a class="btn btn-primary" href="/Student/Quizzes">Làm bài khác</a>
                    <a class="btn btn-outline-secondary" href="/Student">Trang học viên</a>
                </div>

            </section>
        }

    </div>
</body>
</html>