@page "{id:int}"
@model StudentManagementApp.Pages.Admin.Classes.EditModel
@{
    ViewData["Title"] = "Sửa lớp học";
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                font-family: "Be Vietnam Pro", sans-serif;
                background: #f5f7fb;
                margin: 0;
            }

            /* SIDEBAR */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                background: #0f172a;
                color: white;
                padding: 20px;
            }

                .sidebar h4 {
                    font-weight: 700;
                    margin-bottom: 30px;
                }

                .sidebar a {
                    display: block;
                    color: #cbd5f1;
                    padding: 10px 12px;
                    border-radius: 10px;
                    text-decoration: none;
                    margin-bottom: 8px;
                    transition: 0.2s;
                }

                    .sidebar a:hover,
                    .sidebar a.active {
                        background: #1e293b;
                        color: white;
                    }

            /* MAIN */
            .main {
                margin-left: 250px;
                padding: 20px 30px;
            }

            /* TOPBAR */
            .topbar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 25px;
            }

            /* CARD */
            .card-box {
                background: white;
                border-radius: 16px;
                padding: 24px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            }

            /* BUTTON */
            .btn {
                border-radius: 10px;
            }

            /* SCHEDULE ROW */
            .schedule-row {
                background: #f8fafc;
                padding: 10px;
                border-radius: 12px;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>🎓 Admin</h4>

        <a href="/Admin">Dashboard</a>
        <a href="/Admin/Users">Người dùng</a>
        <a href="/Admin/Courses">Khóa học</a>
        <a class="active" href="/Admin/Classes">Lớp học</a>
        <a href="/Admin/Enrollments">Đăng ký</a>
        <a href="/Admin/Quizzes">Quiz</a>

        <hr style="border-color:#334155">
        <a href="/Auth/Logout">🚪 Đăng xuất</a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOPBAR -->
        <div class="topbar">
            <h3>Sửa lớp học</h3>
            <div>Xin chào, <strong>@userName</strong></div>
        </div>

        <!-- FORM CARD -->
        <div class="card-box">

            <form method="post">
                <input asp-for="Input.Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Tên lớp học</label>
                        <input asp-for="Input.ClassName" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Ngày bắt đầu</label>
                        <input asp-for="Input.StartDate" type="date" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Ngày kết thúc</label>
                        <input asp-for="Input.EndDate" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Khóa học</label>
                        <input asp-for="Input.CourseName" class="form-control" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Giáo viên</label>
                        <select asp-for="Input.TeacherId" class="form-select">
                            <option value="">-- Chưa phân công --</option>
                            @foreach (var t in Model.Teachers)
                            {
                                <option value="@t.Id">@t.FullName (@t.Email)</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- SCHEDULE -->
                <hr class="my-4" />
                <h5 class="mb-3">📅 Lịch học</h5>

                <div id="scheduleRows">
                    @for (var i = 0; i < Model.Input.Schedules.Count; i++)
                    {
                        <div class="row g-2 align-items-end mb-2 schedule-row">
                            <div class="col-md-4">
                                <label class="form-label">Thứ</label>
                                <select asp-for="Input.Schedules[i].DayOfWeek" class="form-select">
                                    <option value="">-- Chọn thứ --</option>
                                    <option value="2">Thứ Hai</option>
                                    <option value="3">Thứ Ba</option>
                                    <option value="4">Thứ Tư</option>
                                    <option value="5">Thứ Năm</option>
                                    <option value="6">Thứ Sáu</option>
                                    <option value="7">Thứ Bảy</option>
                                    <option value="8">Chủ Nhật</option>
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Bắt đầu</label>
                                <input asp-for="Input.Schedules[i].StartTime" type="time" class="form-control" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Kết thúc</label>
                                <input asp-for="Input.Schedules[i].EndTime" type="time" class="form-control" />
                            </div>

                            <div class="col-md-2">
                                <button type="button" class="btn btn-outline-danger w-100 btn-remove">Xóa</button>
                            </div>
                        </div>
                    }
                </div>

                <button type="button" id="btnAddSchedule" class="btn btn-outline-primary btn-sm mt-2">
                    + Thêm lịch
                </button>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Lưu</button>
                    <a href="/Admin/Classes" class="btn btn-secondary">Hủy</a>
                </div>

            </form>
        </div>
    </div>

    <script>
            (function () {
                const container = document.getElementById('scheduleRows');
                const addBtn = document.getElementById('btnAddSchedule');

                function attachRemoveHandlers() {
                    container.querySelectorAll('.btn-remove').forEach(btn => {
                        btn.onclick = function () {
                            if (container.children.length <= 1) return;
                            btn.closest('.schedule-row').remove();
                            reindexRows();
                        };
                    });
                }

                function reindexRows() {
                    const rows = container.querySelectorAll('.schedule-row');
                    rows.forEach((row, idx) => {
                        row.querySelectorAll('[name]').forEach(input => {
                            input.name = input.name.replace(/Input\.Schedules\[\d+\]/, `Input.Schedules[${idx}]`);
                        });
                    });
                }

                addBtn.onclick = function () {
                    const idx = container.querySelectorAll('.schedule-row').length;
                    const html = `
                    <div class="row g-2 align-items-end mb-2 schedule-row">
                        <div class="col-md-4">
                            <select name="Input.Schedules[${idx}].DayOfWeek" class="form-select">
                                <option value="">-- Chọn thứ --</option>
                                <option value="2">Thứ Hai</option>
                                <option value="3">Thứ Ba</option>
                                <option value="4">Thứ Tư</option>
                                <option value="5">Thứ Năm</option>
                                <option value="6">Thứ Sáu</option>
                                <option value="7">Thứ Bảy</option>
                                <option value="8">Chủ Nhật</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <input name="Input.Schedules[${idx}].StartTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <input name="Input.Schedules[${idx}].EndTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-danger w-100 btn-remove">Xóa</button>
                        </div>
                    </div>`;
                    container.insertAdjacentHTML('beforeend', html);
                    attachRemoveHandlers();
                };

                attachRemoveHandlers();
            })();
    </script>

</body>
</html>