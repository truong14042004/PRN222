@page
@model StudentManagementApp.Pages.Admin.ClassesModel
@{
    ViewData["Title"] = "Quản lý lớp học";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/Admin">English Center - Admin</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/Admin">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Users">Người dùng</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Courses">Khóa học</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Admin/Classes">Lớp học</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Enrollments">Đăng ký</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Quizzes">Quiz</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Xin chào, @Model.UserName</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Auth/Logout">Đăng xuất</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center">
            <h1 class="mb-0">Quản lý lớp học</h1>
            <a href="/Admin/Classes/Create" class="btn btn-primary">+ Thêm lớp học</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mt-3">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mt-3">@TempData["Error"]</div>
        }

        @if (Model.Classes.Any())
        {
            <table class="table table-striped mt-3">
                <thead>
                    <tr>
                        <th>Tên lớp</th>
                        <th>Khóa học</th>
                        <th>Giáo viên</th>
                        <th>Bắt đầu</th>
                        <th>Kết thúc</th>
                        <th>Lịch học</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cls in Model.Classes)
                    {
                        var scheduleText = cls.Schedules.Any()
                            ? string.Join(", ", cls.Schedules.Select(s => $"T{s.DayOfWeek} {s.StartTime:HH\\:mm}-{s.EndTime:HH\\:mm}"))
                            : "Chưa có lịch";
                        <tr>
                            <td>@cls.ClassName</td>
                            <td>@cls.CourseName</td>
                            <td>@(string.IsNullOrWhiteSpace(cls.TeacherName) ? "Chưa phân công" : cls.TeacherName)</td>
                            <td>@cls.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@cls.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>@scheduleText</td>
                            <td>
                                <span class="badge bg-@(cls.Status == "Upcoming" ? "success" : cls.Status == "Ongoing" ? "primary" : "secondary")">
                                    @cls.Status
                                </span>
                            </td>
                            <td class="text-end">
                                <a href="/Admin/Classes/Edit/@cls.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                                <form method="post" asp-page="/Admin/Classes/Delete" style="display:inline;">
                                    <input type="hidden" name="id" value="@cls.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn xóa lớp này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted mt-3">Chưa có lớp học nào.</p>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
