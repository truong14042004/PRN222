@page
@model StudentManagementApp.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="min-vh-100 d-flex align-items-center bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                <div class="res-card shadow-lg border-0">
                    <div class="p-5">
                        <div class="text-center mb-5">
                            <img src="/images/logo.jpg" alt="Logo" class="mb-4" style="height: 60px;">
                            <h3 class="fw-bold text-res-red">CHÀO MỪNG QUAY LẠI</h3>
                            <p class="text-muted">Vui lòng đăng nhập vào tài khoản của bạn</p>
                        </div>

                        <form method="post" class="form-res">
                            <div class="mb-4">
                                <label class="form-label">TÊN ĐĂNG NHẬP HOẶC EMAIL</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-muted"></i></span>
                                    <input asp-for="Username" class="form-control border-start-0" placeholder="Nhập identifier của bạn" required />
                                </div>
                            </div>
                            
                            <div class="mb-4">
                                <div class="d-flex justify-content-between">
                                    <label class="form-label">MẬT KHẨU</label>
                                    <a href="#" class="small text-res-red text-decoration-none fw-bold">Quên mật khẩu?</a>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-lock text-muted"></i></span>
                                    <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="Nhập mật khẩu" required />
                                </div>
                            </div>

                            <div class="mb-4 form-check">
                                <input type="checkbox" class="form-check-input" id="rememberMe">
                                <label class="form-check-label small text-muted fw-bold" for="rememberMe">DUY TRÌ ĐĂNG NHẬP</label>
                            </div>

                            <div class="d-grid mb-4">
                                <button type="submit" class="btn btn-primary-res btn-lg py-3">ĐĂNG NHẬP NGAY</button>
                            </div>

                            <div class="text-center">
                                <p class="text-muted small">Chưa có tài khoản? <a href="/Auth/Register" class="text-res-red fw-bold text-decoration-none">Đăng ký thành viên mới</a></p>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
