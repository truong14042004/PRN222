@page
@model StudentManagementApp.Pages.Admin.QuizzesModel
@{
    ViewData["Title"] = "Quản lý quiz";
    var userName = HttpContext.Session.GetString("UserName");

    var total = Model.Quizzes.Count();
    var active = Model.Quizzes.Count(q => q.IsActive);
    var totalQuestions = Model.Quizzes.Sum(q => q.QuestionCount);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                font-family: "Be Vietnam Pro", sans-serif;
                background: #f5f7fb;
                margin: 0;
            }

            /* SIDEBAR */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                background: #0f172a;
                color: white;
                padding: 20px;
            }

                .sidebar h4 {
                    font-weight: 700;
                    margin-bottom: 30px;
                }

                .sidebar a {
                    display: block;
                    color: #cbd5f1;
                    padding: 10px 12px;
                    border-radius: 10px;
                    text-decoration: none;
                    margin-bottom: 8px;
                    transition: 0.2s;
                }

                    .sidebar a:hover,
                    .sidebar a.active {
                        background: #1e293b;
                        color: white;
                    }

            /* MAIN */
            .main {
                margin-left: 250px;
                padding: 20px 30px;
            }

            /* CARD */
            .card-dashboard {
                border-radius: 16px;
                padding: 20px;
                color: white;
                box-shadow: 0 10px 25px rgba(0,0,0,0.08);
                transition: 0.2s;
            }

                .card-dashboard:hover {
                    transform: translateY(-5px);
                }

            .bg-gradient-primary {
                background: linear-gradient(135deg, #3b82f6, #6366f1);
            }

            .bg-gradient-success {
                background: linear-gradient(135deg, #22c55e, #16a34a);
            }

            .bg-gradient-info {
                background: linear-gradient(135deg, #06b6d4, #0ea5e9);
            }

            /* TABLE */
            .table-box {
                background: #fff;
                border-radius: 16px;
                overflow: hidden;
                box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            }

            .table th {
                background: #f1f5f9;
                font-size: 13px;
            }

            .badge-soft {
                padding: 6px 10px;
                border-radius: 999px;
                font-size: 12px;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>🎓 Admin</h4>

        <a href="/Admin">Dashboard</a>
        <a href="/Admin/Users">Người dùng</a>
        <a href="/Admin/Courses">Khóa học</a>
        <a href="/Admin/Classes">Lớp học</a>
        <a href="/Admin/Enrollments">Đăng ký</a>
        <a class="active" href="/Admin/Quizzes">Quiz</a>

        <hr style="border-color:#334155">

        <a href="/Auth/Logout">🚪 Đăng xuất</a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOP -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="mb-0">Quản lý Quiz</h3>
                <small class="text-muted">Xin chào, @userName</small>
            </div>

            <a href="/Admin/QuizEdit" class="btn btn-primary">+ Tạo quiz</a>
        </div>

        <!-- STATS -->
        <div class="row g-4 mb-4">

            <div class="col-md-4">
                <div class="card-dashboard bg-gradient-primary">
                    <h2>@total</h2>
                    <p>Tổng quiz</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-dashboard bg-gradient-success">
                    <h2>@active</h2>
                    <p>Đang hoạt động</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-dashboard bg-gradient-info">
                    <h2>@totalQuestions</h2>
                    <p>Tổng câu hỏi</p>
                </div>
            </div>

        </div>

        <!-- TABLE -->
        @if (Model.Quizzes.Any())
        {
            <div class="table-box">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Quiz</th>
                            <th>Khóa học</th>
                            <th class="text-center">Câu hỏi</th>
                            <th class="text-center">Điểm</th>
                            <th class="text-center">Thời gian</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var quiz in Model.Quizzes)
                        {
                            <tr>

                                <td>
                                    <div class="fw-bold">@quiz.Title</div>
                                    <small class="text-muted">@quiz.Description</small>
                                </td>

                                <td>@quiz.CourseName</td>

                                <td class="text-center">@quiz.QuestionCount</td>

                                <td class="text-center">@quiz.TotalPoints</td>

                                <td class="text-center">@quiz.TimeLimitMinutes phút</td>

                                <td>
                                    <span class="badge @(quiz.IsActive ? "bg-success" : "bg-secondary")">
                                        @(quiz.IsActive ? "Đang mở" : "Tạm khóa")
                                    </span>
                                </td>

                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="/Admin/QuizEdit?id=@quiz.Id">Sửa</a>
                                    <a class="btn btn-sm btn-outline-dark" href="/Admin/QuizQuestions?quizId=@quiz.Id">Câu hỏi</a>
                                    <a class="btn btn-sm btn-outline-success" href="/Admin/QuizResults?quizId=@quiz.Id">Kết quả</a>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">Chưa có quiz nào trong hệ thống.</div>
        }

    </div>

</body>
</html>