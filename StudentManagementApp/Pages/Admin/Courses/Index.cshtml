@page
@model StudentManagementApp.Pages.Admin.Courses.IndexModel
@{
    ViewData["Title"] = "Quản lý khóa học";
    ViewData["ActivePage"] = "Courses";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var userName = HttpContext.Session.GetString("UserName");
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Chương trình đào tạo</h6>
        <h2 class="fw-bold mb-0">Quản lý khóa học</h2>
    </div>
    <a href="/Admin/Courses/Create" class="btn btn-primary-res px-4">
        <i class="bi bi-plus-circle me-2"></i>Thêm khóa học
    </a>
</div>

<div id="courseRealtimeBanner" class="alert alert-info border-0 shadow-sm rounded-4 mb-4" role="alert" style="display:none; background: #e0f2fe; color: #0369a1;">
    <i class="bi bi-info-circle-fill me-2"></i>
    <span id="bannerText"></span>
</div>

<div class="admin-card">
    @if (Model.Courses.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Tên khóa học</th>
                        <th>Cấp độ</th>
                        <th>Học phí</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model.Courses)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@course.Name</div>
                                <div class="text-muted small">Mã: #C@(course.Id)</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@course.Level</span>
                            </td>
                            <td>
                                <div class="fw-bold text-res-red">@course.TuitionFee.ToString("N0") <small>VNĐ</small></div>
                            </td>
                            <td>
                                @if (course.IsActive)
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success px-3">
                                        <i class="bi bi-eye-fill me-1"></i>Đang mở
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary-subtle text-muted px-3">
                                        <i class="bi bi-eye-slash-fill me-1"></i>Đã ẩn
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/Admin/Courses/Edit/@course.Id" class="btn btn-sm btn-light border fw-bold text-muted px-3">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <form method="post" asp-page="/Admin/Courses/ToggleActive" class="d-inline">
                                        <input type="hidden" name="id" value="@course.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-dark fw-bold px-3">
                                            @(course.IsActive ? "Ẩn" : "Mở")
                                        </button>
                                    </form>

                                    <form method="post" asp-page="/Admin/Courses/Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@course.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger fw-bold px-3"
                                                onclick="return confirm('Bạn có chắc muốn xóa khóa học này?');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-x text-muted opacity-25 display-1"></i>
            <p class="mt-3 text-muted fw-bold">Hiện chưa có khóa học nào trong danh sách.</p>
        </div>
    }
</div>

<style>
    .bg-success-subtle { background: #ecfdf5 !important; }
    .bg-secondary-subtle { background: #f8fafc !important; }
    .custom-table thead th {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.5px; color: #64748b; padding-top: 15px; padding-bottom: 15px;
    }
    .custom-table tbody td { padding-top: 15px; padding-bottom: 15px; }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
        (() => {
            const banner = document.getElementById("courseRealtimeBanner");
            const bannerText = document.getElementById("bannerText");
            if (!banner || typeof signalR === "undefined") return;

            let reloadTimer;
            const showRealtimeUpdate = (notification) => {
                const message = (notification && notification.message) ? notification.message : "Dữ liệu khóa học vừa được cập nhật.";
                bannerText.textContent = `${message} Đang tải lại...`;
                banner.style.display = "block";
                window.clearTimeout(reloadTimer);
                reloadTimer = window.setTimeout(() => window.location.reload(), 1500);
            };

            const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/notifications").withAutomaticReconnect().build();
            connection.on("CourseChanged", showRealtimeUpdate);
            connection.start().catch(e => console.error("SignalR failed", e));
        })();
    </script>
}
