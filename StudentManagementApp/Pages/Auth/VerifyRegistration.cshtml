@page
@model StudentManagementApp.Pages.Auth.VerifyRegistrationModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác thực đăng ký - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container">
        <div class="row justify-content-center mt-5">
            <div class="col-md-5">
                <div class="card shadow">
                    <div class="card-body">
                        <h3 class="text-center mb-4">Xác thực đăng ký</h3>

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success">@TempData["Success"]</div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger">@TempData["Error"]</div>
                        }

                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                        {
                            <div class="alert alert-danger">
                                @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            </div>
                        }

                        <div class="alert alert-info">
                            Mã OTP đã được gửi tới <strong>@Model.Email</strong>. Nhập mã để hoàn tất tạo tài khoản cho <strong>@Model.FullName</strong>.
                        </div>

                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label">Mã OTP</label>
                                <input type="text" class="form-control" asp-for="OtpCode" maxlength="6" autocomplete="one-time-code" />
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Xác thực và tạo tài khoản</button>
                        </form>

                        <form method="post" asp-page-handler="Resend" class="mt-3">
                            <button type="submit" class="btn btn-outline-secondary w-100">Gửi lại mã OTP</button>
                        </form>

                        <div class="text-center mt-3">
                            <a href="/Auth/Register">Quay lại đăng ký</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
