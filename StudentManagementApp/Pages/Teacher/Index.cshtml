@page
@model StudentManagementApp.Pages.Teacher.IndexModel
@{
    ViewData["Title"] = "Giáo viên";
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">English Center</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link active" href="/Teacher">Lớp dạy</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Teacher/Schedule">Lịch dạy</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Quizzes">Quiz</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Xin chào, @userName</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/Auth/Logout">Đăng xuất</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center">
            <h1 class="mb-0">Danh sách lớp dạy</h1>
            <a href="/Admin/Quizzes" class="btn btn-outline-primary">Quản lý Quiz</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (Model.Classes.Any())
        {
            <table class="table table-striped mt-3">
                <thead>
                    <tr>
                        <th>Lớp</th>
                        <th>Khóa học</th>
                        <th>Ngày bắt đầu</th>
                        <th>Ngày kết thúc</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cls in Model.Classes)
                    {
                        <tr>
                            <td>@cls.ClassName</td>
                            <td>@cls.CourseName</td>
                            <td>@cls.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@cls.EndDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge bg-@(cls.Status == "Ongoing" ? "success" : cls.Status == "Upcoming" ? "info" : "secondary")">@cls.Status</span></td>
                            <td>
                                <a href="/Teacher/Attendance/@cls.Id" class="btn btn-sm btn-primary">Điểm danh</a>
                                <a href="/Teacher/AttendanceReport/@cls.Id" class="btn btn-sm btn-secondary">Báo cáo</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Bạn chưa có lớp dạy nào.</p>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
