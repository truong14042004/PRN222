@using StudentManagementApp.BLL.DTOs
@model IEnumerable<ClassDto>

@{
    ViewData["Title"] = "Lịch dạy";
    string[] dayNames = { "", "CN", "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "CN" };
    // weekDays: Mon=2, Tue=3, Wed=4, Thu=5, Fri=6, Sat=7, Sun=8
    int[] weekDays = { 2, 3, 4, 5, 6, 7, 8 };
    var weekStart = (DateOnly)ViewBag.WeekStart;
    var weekEnd = (DateOnly)ViewBag.WeekEnd;
    var selectedDate = (DateOnly)ViewBag.SelectedDate;
    var today = DateOnly.FromDateTime(DateTime.Today);
    var prevWeek = weekStart.AddDays(-7).ToString("yyyy-MM-dd");
    var nextWeek = weekStart.AddDays(7).ToString("yyyy-MM-dd");
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Lịch dạy</h4>
            <p class="text-muted mb-0">Các lớp đang được phân công</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="fa fa-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <!-- Week navigation -->
    <div class="d-flex align-items-center gap-2 mb-3">
        <a href="?date=@prevWeek" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="fa fa-chevron-left"></i>
        </a>
        <span class="fw-semibold">
            @weekStart.ToString("dd/MM/yyyy") — @weekEnd.ToString("dd/MM/yyyy")
        </span>
        <a href="?date=@nextWeek" class="btn btn-outline-secondary btn-sm rounded-pill">
            <i class="fa fa-chevron-right"></i>
        </a>
        @if (selectedDate != today)
        {
            <a href="?date=@today.ToString("yyyy-MM-dd")" class="btn btn-outline-primary btn-sm rounded-pill ms-2">Hôm nay</a>
        }
        <form method="get" class="ms-auto d-flex align-items-center gap-2">
            <label class="text-muted small mb-0">Đến ngày:</label>
            <input type="date" name="date" value="@selectedDate.ToString("yyyy-MM-dd")" class="form-control form-control-sm" style="width:auto" onchange="this.form.submit()" />
        </form>
    </div>

    <div class="d-flex gap-3 mb-3 small">
        <span><span class="badge bg-success">■</span> Đang học</span>
        <span><span class="badge bg-primary">■</span> Sắp khai giảng</span>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Không có lớp nào đang hoạt động trong tuần này.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        @for (int i = 0; i < weekDays.Length; i++)
                        {
                            var colDate = weekStart.AddDays(i);
                            bool isToday = colDate == today;
                            <th class="@(isToday ? "table-warning text-dark" : "")">
                                @dayNames[weekDays[i]]
                                <div class="fw-normal small">@colDate.ToString("dd/MM")</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        @for (int i = 0; i < weekDays.Length; i++)
                        {
                            int d = weekDays[i];
                            var colDate = weekStart.AddDays(i);
                            bool isToday = colDate == today;
                            <td class="p-2 @(isToday ? "table-warning" : "")" style="min-width:130px; vertical-align:top">
                                @foreach (var cls in Model)
                                {
                                    foreach (var s in cls.Schedules)
                                    {
                                        if (s.DayOfWeek == d)
                                        {
                                            string bg = cls.Status == "Ongoing" ? "bg-success" : "bg-primary";
                                            <div class="@bg text-white rounded p-2 mb-1 small">
                                                <div class="fw-bold">@cls.ClassName</div>
                                                <div>@s.StartTime.ToString(@"hh\:mm") - @s.EndTime.ToString(@"hh\:mm")</div>
                                            </div>
                                        }
                                    }
                                }
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>
