@page "{id:int?}"
@model StudentManagementApp.Pages.Course.DetailModel
@{
    ViewData["Title"] = "Chi tiết khóa học";
    var userId = HttpContext.Session.GetString("UserId");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">English Center</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/Auth/Login">Đăng nhập</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @if (Model.Course != null)
        {
            <div class="card">
                <div class="card-body">
                    <h1>@Model.Course.Name</h1>
                    <span class="badge bg-info">@Model.Course.Level</span>
                    <p class="mt-3">@Model.Course.Description</p>
                    <p><strong>Học phí:</strong> @Model.Course.TuitionFee.ToString("N0") VNĐ</p>
                </div>
            </div>

            <h3 class="mt-4">Lớp học đang mở</h3>
            @if (Model.Classes != null && Model.Classes.Any())
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Tên lớp</th>
                            <th>Ngày bắt đầu</th>
                            <th>Ngày kết thúc</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cls in Model.Classes)
                        {
                            <tr>
                                <td>@cls.ClassName</td>
                                <td>@cls.StartDate.ToString("dd/MM/yyyy")</td>
                                <td>@cls.EndDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge bg-@(cls.Status == "Upcoming" ? "success" : cls.Status == "Ongoing" ? "primary" : "secondary")">@cls.Status</span>
                                </td>
                                <td>
                                    @if (userId != null && cls.Status == "Upcoming")
                                    {
                                        <form method="post" asp-page-handler="Enroll" asp-route-id="@Model.Course.Id">
                                            <input type="hidden" name="classId" value="@cls.Id" />
                                            <button type="submit" class="btn btn-sm btn-success">Đăng ký</button>
                                        </form>
                                    }
                                    else if (userId == null)
                                    {
                                        <a href="/Auth/Login" class="btn btn-sm btn-primary">Đăng nhập để đăng ký</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Hiện chưa có lớp học nào cho khóa học này.</p>
            }
        }
        else
        {
            <div class="alert alert-danger">Không tìm thấy khóa học.</div>
        }

        <a href="/Course" class="btn btn-secondary mt-3">Quay lại</a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
