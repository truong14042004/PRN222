@page
@model StudentManagementApp.Pages.Student.TakeQuizModel
@{
    ViewData["Title"] = "Làm bài quiz";
}

<style>
    .quiz-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 25px;
        align-items: start;
    }

    .q-map-card {
        position: sticky;
        top: 100px;
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .q-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .q-dot {
        aspect-ratio: 1;
        border-radius: 10px;
        border: 2px solid #eee;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        background: white;
        color: #777;
    }

    .q-dot:hover {
        border-color: var(--res-red);
        color: var(--res-red);
    }

    .q-dot.current {
        background: var(--res-red);
        border-color: var(--res-red);
        color: white;
        box-shadow: 0 4px 10px rgba(220, 52, 59, 0.3);
    }

    .q-dot.answered {
        background: #ecfdf5;
        border-color: #10b981;
        color: #059669;
    }

    .q-dot.answered.current {
        background: var(--res-red);
        border-color: var(--res-red);
        color: white;
    }

    .question-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: none;
        min-height: 500px;
    }

    .option-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 18px 25px;
        border: 2px solid #f0f0f0;
        border-radius: 15px;
        margin-bottom: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .option-item:hover {
        border-color: #e0e0e0;
        background: #fcfcfc;
    }

    .option-item.selected {
        border-color: var(--res-red);
        background: var(--res-red-light);
    }

    .option-item input {
        display: none;
    }

    .option-indicator {
        width: 24px;
        height: 24px;
        border: 2px solid #ddd;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .option-item.selected .option-indicator {
        border-color: var(--res-red);
        background: var(--res-red);
    }

    .option-item.selected .option-indicator::after {
        content: "";
        width: 8px;
        height: 8px;
        background: white;
        border-radius: 50%;
    }

    .timer-pill {
        background: white;
        padding: 8px 20px;
        border-radius: 50px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        color: var(--res-red);
        font-size: 1.1rem;
    }

    .timer-pill.warn {
        background: var(--res-red);
        color: white;
        animation: pulse-red 1s infinite;
    }

    @@keyframes pulse-red {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }

    /* AI Hint Panel */
    .ai-bubble {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        background: var(--res-red);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(220, 52, 59, 0.4);
        z-index: 1000;
        transition: transform 0.2s;
    }

    .ai-bubble:hover {
        transform: scale(1.1);
    }

    .ai-panel {
        position: fixed;
        bottom: 100px;
        right: 30px;
        width: 380px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 50px rgba(0,0,0,0.15);
        display: none;
        flex-direction: column;
        overflow: hidden;
        z-index: 1000;
        border: 1px solid #eee;
    }

    .ai-panel.show { display: flex; }

    .ai-header {
        background: var(--res-red);
        color: white;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .ai-messages {
        height: 350px;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: #f8f9fa;
    }

    .ai-msg {
        max-width: 85%;
        padding: 12px 16px;
        border-radius: 15px;
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .ai-msg.bot { background: white; align-self: flex-start; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
    .ai-msg.user { background: var(--res-red); color: white; align-self: flex-end; }

    .ai-input-area {
        padding: 15px;
        border-top: 1px solid #eee;
        display: flex;
        gap: 10px;
    }
</style>

<section class="py-5 bg-light min-vh-100">
    <div class="container py-4">
        @if (Model.Quiz is null)
        {
            <div class="text-center py-5">
                <i class="bi bi-exclamation-octagon display-1 text-muted opacity-25"></i>
                <h3 class="mt-4 fw-bold">Không thể tải bài thi</h3>
                <a href="/Student" class="btn btn-primary-res mt-3 px-5">QUAY LẠI DASHBOARD</a>
            </div>
        }
        else
        {
            var totalQ = Model.Quiz.Questions.Count;

            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <h6 class="text-res-red fw-bold text-uppercase mb-1">Đang làm bài thi</h6>
                    <h2 class="fw-bold mb-0">@Model.Quiz.Title</h2>
                    <p class="text-muted mb-0">@Model.Quiz.CourseName</p>
                </div>
                <div class="d-flex align-items-center gap-4">
                    @if (Model.Quiz.TimeLimitMinutes > 0)
                    {
                        <div class="timer-pill" id="timerBox">
                            <i class="bi bi-stopwatch"></i>
                            <span id="timerDisplay">--:--</span>
                        </div>
                    }
                    <div class="dropdown">
                        <button class="btn btn-outline-res px-4" type="button" data-bs-toggle="dropdown">
                            TÙY CHỌN <i class="bi bi-chevron-down ms-2"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            <li><a class="dropdown-item text-danger" href="/Student"><i class="bi bi-x-circle me-2"></i>Thoát & Hủy bài</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="quiz-container">
                <!-- Question Navigation -->
                <div class="q-map-card">
                    <h6 class="fw-bold text-uppercase small text-muted mb-4">Danh sách câu hỏi</h6>
                    <div class="q-grid" id="qMap">
                        @for (int i = 0; i < totalQ; i++)
                        {
                            <div class="q-dot @(i == 0 ? "current" : "")" data-idx="@i" onclick="goToQuestion(@i)">@(i + 1)</div>
                        }
                    </div>
                    
                    <div class="mt-4 pt-4 border-top">
                        <div class="d-flex align-items-center gap-2 small text-muted mb-2">
                            <div class="q-dot current" style="width: 12px; height: 12px;"></div> Đang chọn
                        </div>
                        <div class="d-flex align-items-center gap-2 small text-muted mb-2">
                            <div class="q-dot answered" style="width: 12px; height: 12px;"></div> Đã trả lời
                        </div>
                        <div class="d-flex align-items-center gap-2 small text-muted">
                            <div class="q-dot" style="width: 12px; height: 12px;"></div> Chưa làm
                        </div>
                    </div>

                    <div class="mt-4">
                        <div class="small fw-bold text-muted mb-2">TIẾN ĐỘ: <span id="topProgressText">0/@totalQ</span></div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" id="topProgressFill" style="width: 0%"></div>
                        </div>
                    </div>
                </div>

                <!-- Main Question Area -->
                <div class="question-area">
                    <form method="post" id="quizForm">
                        <input type="hidden" asp-for="QuizId" />
                        
                        @for (int i = 0; i < totalQ; i++)
                        {
                            var q = Model.Quiz.Questions[i];
                            <input type="hidden" name="Answers[@i].QuestionId" value="@q.Id" />
                            <input type="hidden" name="Answers[@i].SelectedOptionId" id="hiddenOption_@i" value="" />
                            <input type="hidden" name="Answers[@i].FillInAnswer" id="hiddenFill_@i" value="" />
                        }

                        @for (int i = 0; i < totalQ; i++)
                        {
                            var q = Model.Quiz.Questions[i];
                            var letters = new[] { "A", "B", "C", "D", "E", "F" };
                            <div class="question-slide" id="slide_@i" style="display:@(i == 0 ? "block" : "none")">
                                <div class="question-card">
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <span class="badge bg-light text-dark px-3 py-2 border">CÂU HỎI @(i + 1)</span>
                                        <span class="text-muted fw-bold small">ĐIỂM: @q.Point</span>
                                    </div>
                                    
                                    <h4 class="fw-bold mb-5" style="line-height: 1.5;">@q.QuestionText</h4>

                                    @if (q.QuestionType == "MultipleChoice")
                                    {
                                        <div class="options-list" id="options_@i">
                                            @for (int oi = 0; oi < q.Options.Count; oi++)
                                            {
                                                var opt = q.Options[oi];
                                                <label class="option-item" id="optLabel_@(i)_@oi" onclick="selectOption(@i, '@opt.Id', this)">
                                                    <input type="radio" name="radio_q@i" value="@opt.Id" />
                                                    <div class="option-indicator"></div>
                                                    <span class="fw-bold text-muted me-2">@(oi < letters.Length ? letters[oi] : (oi + 1).ToString()).</span>
                                                    <span class="flex-grow-1">@opt.OptionText</span>
                                                </label>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mb-5">
                                            <label class="form-label fw-bold text-muted small text-uppercase">Nhập đáp án của bạn</label>
                                            <input class="form-control form-control-lg border-2 bg-light" 
                                                   type="text" id="fill_@i" placeholder="Gõ câu trả lời tại đây..." 
                                                   oninput="syncFill(@i, this.value)" />
                                        </div>
                                    }

                                    <div class="d-flex justify-content-between mt-5 pt-4 border-top">
                                        <button type="button" class="btn btn-light px-4 fw-bold text-muted border" 
                                                onclick="goToQuestion(@(i - 1))" @(i == 0 ? "disabled" : "")>
                                            <i class="bi bi-arrow-left me-2"></i> CÂU TRƯỚC
                                        </button>
                                        
                                        @if (i < totalQ - 1)
                                        {
                                            <button type="button" class="btn btn-primary-res px-5" onclick="goToQuestion(@(i + 1))">
                                                CÂU TIẾP THEO <i class="bi bi-arrow-right ms-2"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-success px-5 fw-bold shadow" onclick="openSubmitModal()">
                                                <i class="bi bi-check-circle me-2"></i> NỘP BÀI THI
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </form>
                </div>
            </div>
        }
    </div>
</section>

<!-- Submit Modal -->
<div class="modal fade" id="submitModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 20px;">
            <div class="modal-body p-5 text-center">
                <div class="mb-4">
                    <i class="bi bi-send-check text-success display-1"></i>
                </div>
                <h3 class="fw-bold mb-3">Xác nhận nộp bài?</h3>
                <p class="text-muted mb-4">Bạn đã hoàn thành <strong id="modalAnsweredVal">0</strong>/@(Model.Quiz?.Questions.Count ?? 0) câu hỏi. Bạn chắc chắn muốn nộp bài ngay bây giờ chứ?</p>
                
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-primary-res py-3 fw-bold" onclick="submitQuiz()">XÁC NHẬN NỘP BÀI</button>
                    <button type="button" class="btn btn-light py-3 fw-bold text-muted" data-bs-dismiss="modal">TIẾP TỤC LÀM BÀI</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- AI Tool -->
<div class="ai-bubble" onclick="toggleAiPanel()">
    <i class="bi bi-robot"></i>
</div>

<div class="ai-panel" id="aiPanel">
    <div class="ai-header">
        <div class="fw-bold small"><i class="bi bi-stars me-2"></i>TRỢ LÝ AI (GỢI Ý)</div>
        <button class="btn btn-sm text-white border-0" onclick="toggleAiPanel()"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="ai-messages" id="aiChat">
        <div class="ai-msg bot">Chào bạn! Mình có thể gợi ý hướng làm bài cho câu hiện tại mà không tiết lộ đáp án. Bạn cần trợ giúp gì không?</div>
    </div>
    <div class="ai-input-area">
        <input type="text" class="form-control border-0 bg-light" id="aiInput" placeholder="Hỏi AI về câu này..." />
        <button class="btn btn-primary-res px-3" onclick="sendAiHint()"><i class="bi bi-send"></i></button>
    </div>
</div>

@section Scripts {
<script>
(function(){
    const totalQ = @((Model.Quiz?.Questions.Count ?? 0).ToString());
    const quizId = @((Model.Quiz?.Id ?? 0).ToString());
    let currentIdx = 0;
    const answered = new Array(totalQ).fill(false);
    const submitModal = new bootstrap.Modal(document.getElementById('submitModal'));

    // --- NAVIGATION ---
    window.goToQuestion = function(idx) {
        if (idx < 0 || idx >= totalQ) return;
        document.getElementById('slide_' + currentIdx).style.display = 'none';
        updateDot(currentIdx);
        currentIdx = idx;
        document.getElementById('slide_' + currentIdx).style.display = 'block';
        updateDot(currentIdx);
        updateProgress();
    };

    function updateDot(idx) {
        const dot = document.querySelector('.q-dot[data-idx="' + idx + '"]');
        if (!dot) return;
        dot.classList.toggle('current', idx === currentIdx);
        dot.classList.toggle('answered', answered[idx]);
    }

    function updateProgress() {
        const count = answered.filter(Boolean).length;
        const pct = totalQ > 0 ? Math.round(count * 100 / totalQ) : 0;
        const fill = document.getElementById('topProgressFill');
        const text = document.getElementById('topProgressText');
        if (fill) fill.style.width = pct + '%';
        if (text) text.textContent = count + '/' + totalQ;
    }

    // --- ANSWERS ---
    window.selectOption = function(qIdx, optionId, labelEl) {
        const allLabels = document.querySelectorAll('#options_' + qIdx + ' .option-item');
        allLabels.forEach(l => l.classList.remove('selected'));
        labelEl.classList.add('selected');
        document.getElementById('hiddenOption_' + qIdx).value = optionId;
        answered[qIdx] = true;
        updateProgress();
    };

    window.syncFill = function(qIdx, val) {
        document.getElementById('hiddenFill_' + qIdx).value = val;
        answered[qIdx] = val.trim().length > 0;
        updateProgress();
    };

    // --- SUBMISSION ---
    window.openSubmitModal = function() {
        const count = answered.filter(Boolean).length;
        document.getElementById('modalAnsweredVal').textContent = count;
        submitModal.show();
    };

    window.submitQuiz = function() {
        document.getElementById('quizForm').submit();
    };

    // --- TIMER ---
    const timeLimitMinutes = @((Model.Quiz?.TimeLimitMinutes ?? 0).ToString());
    if (timeLimitMinutes > 0) {
        let remaining = timeLimitMinutes * 60;
        const timerDisplay = document.getElementById('timerDisplay');
        const timerBox = document.getElementById('timerBox');

        function fmt(s) {
            const m = Math.floor(s/60).toString().padStart(2,'0');
            const sec = (s%60).toString().padStart(2,'0');
            return m + ':' + sec;
        }

        const interval = setInterval(() => {
            remaining--;
            if (timerDisplay) timerDisplay.textContent = fmt(remaining);
            if (remaining <= 60 && timerBox) timerBox.classList.add('warn');
            if (remaining <= 0) {
                clearInterval(interval);
                submitQuiz();
            }
        }, 1000);
        if (timerDisplay) timerDisplay.textContent = fmt(remaining);
    }

    // --- AI HINT ---
    window.toggleAiPanel = function() {
        document.getElementById('aiPanel').classList.toggle('show');
    };

    window.sendAiHint = async function() {
        const input = document.getElementById('aiInput');
        const text = input.value.trim();
        if (!text) return;

        addAiMessage('user', text);
        input.value = '';
        
        // Simple mock response
        setTimeout(() => {
            addAiMessage('bot', "Hãy tập trung vào các từ khóa chính và loại trừ phương án sai nhé!");
        }, 800);
    };

    function addAiMessage(role, text) {
        const chat = document.getElementById('aiChat');
        if (!chat) return;
        const div = document.createElement('div');
        div.className = 'ai-msg ' + role;
        div.textContent = text;
        chat.appendChild(div);
        chat.scrollTop = chat.scrollHeight;
    }

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
        if (e.target.tagName === 'INPUT') return;
        if (e.key === 'ArrowLeft') goToQuestion(currentIdx - 1);
        if (e.key === 'ArrowRight') goToQuestion(currentIdx + 1);
    });

    // Handle initial map update
    updateProgress();
})();
</script>
}
