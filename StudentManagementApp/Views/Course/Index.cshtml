@using StudentManagementApp.BLL.DTOs
@model IEnumerable<CourseDto>

@{
    ViewData["Title"] = "Khóa học";
}

<div class="container py-5">
    <h2 class="fw-bold mb-1">Khóa học</h2>
    <p class="text-muted mb-4">Chương trình học theo chuẩn CEFR từ A1 đến C2</p>

    <div class="row g-4">
        @foreach (var course in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0">
                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                    {
                        <img src="@course.ThumbnailUrl" class="card-img-top" style="height:180px;object-fit:cover" alt="@course.Name" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-primary text-white" style="height:180px;font-size:3rem;font-weight:800;">
                            @course.Level
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-warning text-dark mb-2" style="width:fit-content">@course.Level</span>
                        <h5 class="card-title fw-bold">@course.Name</h5>
                        <p class="card-text text-muted small flex-grow-1">@course.Description</p>
                        <div class="mt-3 d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-primary fs-5">@course.TuitionFee.ToString("N0") ₫</span>
                            <a asp-action="Detail" asp-route-id="@course.Id" class="btn btn-primary btn-sm rounded-pill px-3">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
