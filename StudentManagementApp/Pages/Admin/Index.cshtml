@page
@model StudentManagementApp.Pages.Admin.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Quản trị";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "_AdminLayout";
    var userName = HttpContext.Session.GetString("UserName");
}

<style>
    .admin-stat-card {
        padding: 24px;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        transition: transform 0.2s;
    }
    .admin-stat-card:hover { transform: translateY(-5px); }
    .stat-icon-box {
        width: 48px; height: 48px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 15px; font-size: 1.5rem;
    }
    .icon-revenue { background: #ecfdf5; color: #10b981; }
    .icon-student { background: #eff6ff; color: #3b82f6; }
    .icon-teacher { background: #fdf2f8; color: #db2777; }
    .icon-course { background: #fff7ed; color: #f59e0b; }
    .stat-label { color: #64748b; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px; }
    .stat-value { font-size: 1.75rem; font-weight: 800; color: #1e293b; }
    .quick-action-card { padding: 20px; border-radius: 15px; text-align: center; text-decoration: none; display: flex; flex-direction: column; align-items: center; gap: 10px; transition: all 0.2s; }
    .quick-action-card:hover { transform: scale(1.05); }
    .chart-container { background: white; padding: 30px; border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); margin-bottom: 30px; }
</style>

<div class="admin-header d-flex justify-content-between align-items-center">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Tổng quan hệ thống</h6>
        <h2 class="fw-bold mb-0">Dashboard</h2>
    </div>
    <div class="text-end">
        <div class="fw-bold">@userName</div>
        <div class="text-muted small">Quyền: Quản trị hệ thống</div>
    </div>
</div>

<!-- STATS GRID -->
<div class="row g-4 mb-5">
    <div class="col-xl-3 col-md-6">
        <div class="admin-stat-card h-100">
            <div class="stat-icon-box icon-revenue"><i class="bi bi-currency-dollar"></i></div>
            <div class="stat-label">Tổng doanh thu</div>
            <div class="stat-value text-success">@Model.TotalRevenue.ToString("N0") <small style="font-size: 0.6em;">đ</small></div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="admin-stat-card h-100">
            <div class="stat-icon-box icon-student"><i class="bi bi-person-badge"></i></div>
            <div class="stat-label">Học viên</div>
            <div class="stat-value">@Model.StudentCount</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="admin-stat-card h-100">
            <div class="stat-icon-box icon-teacher"><i class="bi bi-person-workspace"></i></div>
            <div class="stat-label">Giáo viên</div>
            <div class="stat-value">@Model.TeacherCount</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="admin-stat-card h-100">
            <div class="stat-icon-box icon-course"><i class="bi bi-book"></i></div>
            <div class="stat-label">Khóa học</div>
            <div class="stat-value">@Model.CourseCount</div>
        </div>
    </div>
</div>

<!-- QUICK ACTIONS -->
<div class="mb-5">
    <h5 class="fw-bold mb-4"><i class="bi bi-lightning-charge-fill text-res-red me-2"></i>Thao tác nhanh</h5>
    <div class="row g-4">
        <div class="col-md-3">
            <a href="/Admin/Users/Create" class="res-card quick-action-card border-0 bg-white shadow-sm">
                <i class="bi bi-person-plus fs-2 text-primary"></i>
                <span class="fw-bold">Học viên mới</span>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/Courses/Create" class="res-card quick-action-card border-0 bg-white shadow-sm">
                <i class="bi bi-journal-plus fs-2 text-success"></i>
                <span class="fw-bold">Khóa học mới</span>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/Classes/Create" class="res-card quick-action-card border-0 bg-white shadow-sm">
                <i class="bi bi-building-add fs-2 text-warning"></i>
                <span class="fw-bold">Lớp học mới</span>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Admin/PurchasableItems/Create" class="res-card quick-action-card border-0 bg-white shadow-sm">
                <i class="bi bi-cart-plus fs-2 text-danger"></i>
                <span class="fw-bold">Thêm vật phẩm</span>
            </a>
        </div>
    </div>
</div>

<!-- REVENUE CHART -->
<div class="chart-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">Biểu đồ tăng trưởng doanh thu</h5>
        <div class="dropdown">
            <button class="btn btn-light btn-sm fw-bold border" type="button">6 tháng gần nhất</button>
        </div>
    </div>
    <div style="height: 350px;">
        <canvas id="revenueChart"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            const labels = @Html.Raw(JsonSerializer.Serialize(Model.RevenueMonthLabels));
            const data = @Html.Raw(JsonSerializer.Serialize(Model.RevenueMonthValues));
            const canvas = document.getElementById("revenueChart");
            if (!canvas || !window.Chart) return;
            const ctx = canvas.getContext("2d");
            const gradient = ctx.createLinearGradient(0, 0, 0, 350);
            gradient.addColorStop(0, 'rgba(220, 38, 38, 0.2)');
            gradient.addColorStop(1, 'rgba(220, 38, 38, 0)');
            new Chart(ctx, {
                type: "line",
                data: {
                    labels: labels,
                    datasets: [{
                        label: "Doanh thu (VNĐ)",
                        data: data,
                        borderColor: "#dc2626",
                        borderWidth: 3,
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: "#fff",
                        pointBorderColor: "#dc2626",
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            callbacks: {
                                label: function (ctx) {
                                    const value = Number(ctx.raw || 0);
                                    return " " + value.toLocaleString("vi-VN") + " đ";
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#f1f5f9' },
                            ticks: {
                                callback: function (value) {
                                    if (value >= 1000000) return (value / 1000000) + "M";
                                    return value.toLocaleString("vi-VN");
                                }
                            }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });
        })();
    </script>
}
