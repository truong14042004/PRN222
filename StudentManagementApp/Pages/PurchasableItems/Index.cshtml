@page
@model StudentManagementApp.Pages.PurchasableItems.IndexModel
@{
    ViewData["Title"] = "Cửa hàng giáo trình";
}

<div class="hero-section-res py-5 mb-5">
    <div class="container text-center py-4">
        <h1 class="display-4 fw-bold text-black mb-3">MESH SHOP</h1>
        <p class="lead text-black-50 mb-0">Giáo trình & Vật phẩm giáo dục độc quyền</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        @if (Model.Items != null && Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm res-card overflow-hidden">
                        <div class="bg-light d-flex align-items-center justify-content-center p-3" style="height: 220px;">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="img-fluid" alt="@item.Name" style="max-height: 100%; object-fit: contain;">
                            }
                            else
                            {
                                <i class="bi bi-book text-secondary opacity-25" style="font-size: 5rem;"></i>
                            }
                        </div>
                        <div class="card-body p-4 text-center">
                            <h5 class="fw-bold mb-2 line-clamp-2" style="height: 3rem;">@item.Name</h5>
                            <p class="text-muted small mb-3 line-clamp-2">@item.Description</p>
                            <div class="h4 fw-bold text-res-red mb-4">@item.Price.ToString("N0") VNĐ</div>
                            
                            <form method="post" asp-page-handler="AddToCart">
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button type="submit" class="btn btn-primary-res w-100 rounded-pill py-2 shadow-sm">
                                    <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="py-5 bg-light rounded-4 border-2 border-dashed">
                    <i class="bi bi-inbox text-muted display-1 mb-3"></i>
                    <h4 class="text-muted">Tính năng đang cập nhật sản phẩm.</h4>
                    <p class="text-muted mb-0">Vui lòng quay lại sau ít phút!</p>
                </div>
            </div>
        }
    </div>
</div>
