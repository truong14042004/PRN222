@page
@model StudentManagementApp.Pages.Admin.QuizEditModel
@{
    ViewData["Title"] = Model.IsEdit ? "Sửa quiz" : "Tạo quiz";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg: #edf3fb;
            --ink: #0f172a;
            --muted: #64748b;
            --line: #d9e2ef;
            --card: #fff;
            --brand: #1d4ed8;
            --green: #119c6a;
        }

        body {
            margin: 0;
            font-family: "Manrope", "Segoe UI", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(720px 360px at 3% -8%, #dbeafe 0%, transparent 70%),
                var(--bg);
            min-height: 100vh;
        }

        .shell {
            width: min(940px, 94vw);
            margin: 0 auto;
            padding: 26px 0 48px;
        }

        .hero {
            border-radius: 22px;
            padding: 22px;
            color: #fff;
            background: linear-gradient(126deg, #0f4c81 0%, #1d4ed8 55%, #2563eb 100%);
            box-shadow: 0 22px 42px rgba(37, 99, 235, .24);
            animation: rise .4s ease-out;
        }

        .hero h1 {
            margin: 0;
            font-size: clamp(1.4rem, 2.5vw, 2rem);
            font-weight: 800;
        }

        .hero p {
            margin: 6px 0 0;
            color: rgba(255,255,255,.9);
        }

        .panel {
            margin-top: 16px;
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: 18px;
            box-shadow: 0 18px 34px rgba(15, 23, 42, .08);
            animation: rise .45s ease-out .08s both;
        }

        .panel-head {
            padding: 14px 16px;
            border-bottom: 1px solid var(--line);
        }

        .panel-body {
            padding: 18px;
        }

        .panel-head strong {
            font-size: 1.02rem;
        }

        .panel-head .muted {
            color: var(--muted);
            font-size: .9rem;
        }

        .form-label {
            font-weight: 700;
            font-size: .92rem;
        }

        .hint {
            color: var(--muted);
            font-size: .85rem;
            margin-top: 4px;
        }

        .chips {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 10px;
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            border: 1px solid #d7e3f7;
            background: #f4f8ff;
            color: #23436f;
            padding: 5px 10px;
            font-size: .8rem;
            font-weight: 700;
        }

        .btn-green {
            background: var(--green);
            border-color: var(--green);
            color: #fff;
            font-weight: 700;
        }

        .btn-green:hover {
            background: #0f875c;
            border-color: #0f875c;
            color: #fff;
        }

        @@keyframes rise {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <div class="shell">
        <section class="hero">
            <h1>@(Model.IsEdit ? "Cập nhật quiz" : "Tạo quiz mới")</h1>
            <p>Vai trò: @Model.CurrentRole</p>
        </section>

        <section class="panel">
            <header class="panel-head">
                <strong>Thiết lập quiz</strong>
                <div class="muted">Chỉ dùng trắc nghiệm và điền đáp án.</div>
            </header>

            <div class="panel-body">
                <div class="chips">
                    <span class="chip">Hỗ trợ trắc nghiệm</span>
                    <span class="chip">Hỗ trợ điền đáp án</span>
                    <span class="chip">Có giới hạn thời gian</span>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Input.Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.CourseId" class="form-label">Khóa học</label>
                            <select asp-for="Input.CourseId" class="form-select">
                                @foreach (var course in Model.AvailableCourses)
                                {
                                    <option value="@course.Id">@course.Name (@course.Level)</option>
                                }
                            </select>
                            <span asp-validation-for="Input.CourseId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.TimeLimitMinutes" class="form-label">Thời gian làm bài (phút)</label>
                            <input asp-for="Input.TimeLimitMinutes" class="form-control" type="number" min="1" max="300" />
                            <span asp-validation-for="Input.TimeLimitMinutes" class="text-danger small"></span>
                            <div class="hint">Khuyến nghị: 20 - 60 phút.</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.StartAt" class="form-label">Thời gian bắt đầu</label>
                            <input asp-for="Input.StartAt" class="form-control" type="datetime-local" />
                            <span asp-validation-for="Input.StartAt" class="text-danger small"></span>
                            <div class="hint">Để trống nếu mở ngay.</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Input.EndAt" class="form-label">Thời gian kết thúc</label>
                            <input asp-for="Input.EndAt" class="form-control" type="datetime-local" />
                            <span asp-validation-for="Input.EndAt" class="text-danger small"></span>
                            <div class="hint">Để trống nếu không giới hạn thời gian đóng.</div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Input.Title" class="form-label">Tiêu đề quiz</label>
                            <input asp-for="Input.Title" class="form-control" placeholder="Ví dụ: Kiểm tra ngữ pháp 01" />
                            <span asp-validation-for="Input.Title" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Input.Description" class="form-label">Mô tả / hướng dẫn</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="Nhập hướng dẫn ngắn cho học viên trước khi bắt đầu."></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="Input.IsActive" class="form-check-input" />
                                <label asp-for="Input.IsActive" class="form-check-label">Mở quiz ngay</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-secondary" href="/Admin/Quizzes">Hủy</a>
                        <button type="submit" class="btn btn-green">@(Model.IsEdit ? "Lưu thay đổi" : "Tạo quiz")</button>
                    </div>
                </form>
            </div>
        </section>
    </div>
</body>
</html>
