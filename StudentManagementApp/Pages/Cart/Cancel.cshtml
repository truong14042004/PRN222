@page
@model StudentManagementApp.Pages.Cart.CancelModel
@{
    ViewData["Title"] = "Thanh toán bị hủy";
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm border-0 py-5">
        <div class="card-body">
            <div class="mb-4">
                <i class="bi bi-x-circle-fill text-danger" style="font-size: 5rem;"></i>
            </div>
            <h2 class="text-danger mb-3">Thanh toán không thành công</h2>
            <p class="lead mb-4">Giao dịch đã bị hủy hoặc gặp sự cố. Bạn có thể thử lại hoặc chọn phương thức thanh toán khác.</p>
            <div class="d-grid gap-2 d-md-block">
                <a href="/Cart" class="btn btn-primary px-4 me-md-2">Quay lại giỏ hàng</a>
                <a href="/PurchasableItems" class="btn btn-outline-secondary px-4">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</div>
