@page
@model StudentManagementApp.Pages.Student.QuizzesModel
@{
    ViewData["Title"] = "Bài quiz của bạn";
}

<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiz - English Center</title>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d0f14;
  --surface: #13161d;
  --surface-2: #1a1e28;
  --border: rgba(255,255,255,0.07);
  --accent: #e8412a;
  --blue: #4a9eff;
  --green: #22c55e;
  --amber: #f5a623;
  --purple: #a78bfa;
  --text: #f0f2f5;
  --text-muted: #6b7280;
  --text-soft: #9ca3af;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Be Vietnam Pro', sans-serif;
  min-height: 100vh;
}
body::before {
  content:'';
  position:fixed; bottom:-150px; left:-100px;
  width:600px; height:600px;
  background: radial-gradient(circle, rgba(167,139,250,0.06) 0%, transparent 70%);
  pointer-events:none; z-index:0;
}
body::after {
  content:'';
  position:fixed; top:-100px; right:-100px;
  width:500px; height:500px;
  background: radial-gradient(circle, rgba(232,65,42,0.06) 0%, transparent 70%);
  pointer-events:none; z-index:0;
}

/* ── Navbar ── */
.navbar {
  background: rgba(13,15,20,0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  padding: 0 24px; height: 60px;
  display:flex; align-items:center; justify-content:space-between;
  position:sticky; top:0; z-index:100;
}
.nav-brand {
  font-family:'Playfair Display', serif;
  font-size:17px; color:var(--text);
  text-decoration:none; letter-spacing:-0.3px;
}
.nav-brand span { color:var(--accent); }
.nav-links { display:flex; align-items:center; gap:4px; list-style:none; }
.nav-links a {
  color:var(--text-muted); text-decoration:none;
  font-size:13px; font-weight:500;
  padding:6px 14px; border-radius:8px; transition:all 0.2s;
}
.nav-links a:hover { color:var(--text); background:var(--surface-2); }
.nav-links a.active { color:var(--text); background:var(--surface-2); }
.user-chip {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--surface-2); border:1px solid var(--border);
  border-radius:100px; padding:5px 14px 5px 8px;
  font-size:13px; font-weight:500; color:var(--text-soft);
  position:relative; cursor:pointer;
}
.user-avatar {
  width:26px; height:26px; border-radius:50%;
  background:linear-gradient(135deg, var(--accent), var(--amber));
  display:flex; align-items:center; justify-content:center;
  font-size:11px; font-weight:700; color:#fff;
}
.dropdown-menu {
  display:none; position:absolute; top:calc(100% + 8px); right:0;
  background:var(--surface-2); border:1px solid var(--border);
  border-radius:12px; min-width:160px; overflow:hidden;
  z-index:200; box-shadow:0 16px 40px rgba(0,0,0,0.4);
}
.user-chip:hover .dropdown-menu { display:block; }
.dropdown-menu a {
  display:block; padding:10px 16px;
  color:var(--text-soft); text-decoration:none;
  font-size:13px; transition:background 0.15s;
}
.dropdown-menu a:hover { background:rgba(255,255,255,0.05); color:var(--text); }

/* ── Layout ── */
.wrap {
  max-width:1100px; margin:0 auto;
  padding:40px 24px 80px;
  position:relative; z-index:1;
}

/* ── Hero ── */
.hero {
  background: linear-gradient(130deg, rgba(167,139,250,0.15) 0%, rgba(74,158,255,0.1) 100%);
  border: 1px solid rgba(167,139,250,0.2);
  border-radius: 20px;
  padding: 28px 32px;
  margin-bottom: 32px;
  display:flex; align-items:center; justify-content:space-between; gap:20px;
  animation: fadeDown 0.5s ease both;
}
.hero-text h1 {
  font-family:'Playfair Display', serif;
  font-size:26px; letter-spacing:-0.5px;
}
.hero-text h1 span { color:var(--purple); }
.hero-text p { color:var(--text-soft); font-size:13.5px; margin-top:6px; }
.hero-badge {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12);
  border-radius:100px; padding:8px 18px;
  font-size:13px; font-weight:600; color:var(--text-soft);
  white-space:nowrap;
}

/* ── Flash error ── */
.flash-error {
  background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.25);
  color:#f87171; border-radius:12px; padding:12px 18px;
  font-size:13.5px; margin-bottom:20px;
  animation:fadeUp 0.4s ease both;
}

/* ── Section card ── */
.section-card {
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:20px; overflow:hidden;
  margin-bottom:24px;
  animation: fadeUp 0.5s ease both;
}
.section-card:nth-child(3) { animation-delay:0.1s; }
.section-card:nth-child(4) { animation-delay:0.2s; }
.section-card:nth-child(5) { animation-delay:0.3s; }

.section-head {
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 24px; border-bottom:1px solid var(--border);
  background:var(--surface-2);
}
.section-head-left h3 {
  font-size:14px; font-weight:700;
  text-transform:uppercase; letter-spacing:1.5px;
  color:var(--text-soft);
}
.section-head-left p { font-size:12px; color:var(--text-muted); margin-top:2px; }

/* ── Progress list ── */
.progress-list { padding:20px 24px; display:grid; gap:14px; }
.progress-item {}
.progress-item-head {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:8px;
}
.progress-item-head strong { font-size:14px; font-weight:600; }
.progress-frac { font-size:12px; color:var(--text-muted); }
.progress-track {
  background:var(--surface-2);
  border-radius:100px; height:5px; overflow:hidden;
}
.progress-fill {
  height:100%; border-radius:100px;
  background:linear-gradient(90deg, var(--green), var(--blue));
  transition: width 1.2s cubic-bezier(0.22,1,0.36,1);
}

/* ── Quiz grid ── */
.quiz-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));
  gap:14px; padding:20px;
}
.quiz-card {
  background:var(--surface-2);
  border:1px solid var(--border);
  border-radius:16px; padding:18px;
  display:flex; flex-direction:column; gap:6px;
  transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
}
.quiz-card:hover {
  transform:translateY(-3px);
  border-color:rgba(255,255,255,0.12);
  box-shadow:0 10px 30px rgba(0,0,0,0.3);
}
.quiz-title { font-weight:700; font-size:15px; }
.quiz-course { font-size:12px; color:var(--purple); font-weight:600; }
.quiz-desc { font-size:13px; color:var(--text-muted); flex:1; line-height:1.5; }
.quiz-timing { font-size:11.5px; color:var(--text-muted); }
.quiz-footer {
  display:flex; align-items:center; justify-content:space-between;
  margin-top:8px; padding-top:12px;
  border-top:1px solid var(--border);
}
.quiz-meta-pill {
  font-size:11.5px; color:var(--text-muted);
  background:var(--surface); border:1px solid var(--border);
  border-radius:100px; padding:3px 10px;
}
.btn-start {
  background:var(--accent); color:#fff;
  border:none; border-radius:8px;
  padding:7px 18px; font-family:inherit;
  font-size:12.5px; font-weight:700;
  cursor:pointer; text-decoration:none;
  transition:all 0.2s;
  box-shadow:0 0 16px rgba(232,65,42,0.3);
  display:inline-block;
}
.btn-start:hover { background:#ff5740; color:#fff; transform:translateY(-1px); }
.badge-closed, .badge-soon {
  font-size:11.5px; font-weight:600;
  padding:5px 12px; border-radius:100px;
}
.badge-closed { background:rgba(156,163,175,0.1); color:#9ca3af; border:1px solid rgba(156,163,175,0.2); }
.badge-soon { background:rgba(245,166,35,0.1); color:#fbbf24; border:1px solid rgba(245,166,35,0.2); }

/* ── Results table ── */
.table-wrap { overflow-x:auto; }
table { width:100%; border-collapse:collapse; }
thead th {
  padding:12px 22px;
  text-align:left; font-size:11px;
  text-transform:uppercase; letter-spacing:1px;
  color:var(--text-muted); font-weight:600;
  border-bottom:1px solid var(--border);
  background:rgba(255,255,255,0.02); white-space:nowrap;
}
tbody tr { border-bottom:1px solid var(--border); transition:background 0.15s; }
tbody tr:last-child { border-bottom:none; }
tbody tr:hover { background:rgba(255,255,255,0.03); }
tbody td { padding:13px 22px; font-size:13.5px; vertical-align:middle; }
.score-cell { font-weight:700; color:var(--text); }
.pct-pill {
  display:inline-block;
  font-size:12px; font-weight:700;
  padding:3px 10px; border-radius:100px;
}
.btn-detail {
  display:inline-flex; align-items:center; gap:4px;
  border:1px solid var(--border);
  color:var(--text-soft); text-decoration:none;
  font-size:12px; font-weight:600;
  padding:5px 14px; border-radius:8px;
  transition:all 0.2s;
}
.btn-detail:hover { border-color:rgba(255,255,255,0.18); color:var(--text); background:var(--surface-2); }
.btn-back {
  display:inline-flex; align-items:center; gap:6px;
  border:1px solid var(--border); color:var(--text-soft);
  text-decoration:none; font-size:12.5px; font-weight:600;
  padding:6px 14px; border-radius:8px; transition:all 0.2s;
}
.btn-back:hover { color:var(--text); background:var(--surface-2); }

/* Empty */
.empty-hint { padding:28px 24px; color:var(--text-muted); font-size:13.5px; }

@@keyframes fadeDown {
  from { opacity:0; transform:translateY(-14px); }
  to   { opacity:1; transform:translateY(0); }
}
@@keyframes fadeUp {
  from { opacity:0; transform:translateY(18px); }
  to   { opacity:1; transform:translateY(0); }
}
@@media(max-width:640px) {
  .hero { flex-direction:column; padding:20px; }
  .quiz-grid { grid-template-columns:1fr; }
  .nav-links { display:none; }
}
</style>
</head>
<body>

<nav class="navbar">
  <a href="/" class="nav-brand">English <span>Center</span></a>
  <ul class="nav-links">
    <li><a href="/Student">Học viên</a></li>
    <li><a href="/Student/Schedule">Lịch học</a></li>
    <li><a href="/Student/AttendanceReport">Điểm danh</a></li>
    <li><a href="/Student/Quizzes" class="active">Quiz</a></li>
  </ul>
  <div class="user-chip">
    <div class="user-avatar">@(Model.UserName?.Substring(0,1).ToUpper() ?? "U")</div>
    @Model.UserName
    <div class="dropdown-menu">
      <a href="/Auth/Logout">🚪 Đăng xuất</a>
    </div>
  </div>
</nav>

<div class="wrap">

  <!-- Hero -->
  <div class="hero">
    <div class="hero-text">
      <h1>Quiz luyện tập <span>tiếng Anh</span></h1>
      <p>Dạng IELTS: trắc nghiệm và điền đáp án, theo khóa học đã xác nhận.</p>
    </div>
    <a href="/Student" class="btn-back">← Về trang học viên</a>
  </div>

  @if (!string.IsNullOrWhiteSpace(Model.FlashError))
  {
    <div class="flash-error">⚠️ @Model.FlashError</div>
  }

  <!-- Progress by course -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-head-left">
        <h3>📊 Tiến độ quiz theo khóa học</h3>
        <p>Số quiz đã hoàn thành trên tổng quiz của từng khóa</p>
      </div>
    </div>
    @if (Model.CourseQuizProgresses.Any())
    {
      <div class="progress-list">
        @foreach (var progress in Model.CourseQuizProgresses)
        {
          <div class="progress-item">
            <div class="progress-item-head">
              <strong>@progress.CourseName</strong>
              <span class="progress-frac">@progress.CompletedQuizCount/@progress.TotalQuizCount quiz • @progress.Percentage%</span>
            </div>
            <div class="progress-track">
              <div class="progress-fill" style="width:@progress.Percentage%"></div>
            </div>
          </div>
        }
      </div>
    }
    else
    {
      <div class="empty-hint">Chưa có dữ liệu tiến độ quiz.</div>
    }
  </div>

  <!-- Available quizzes -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-head-left">
        <h3>✏️ Bài quiz có thể làm</h3>
        <p>Chọn bài để bắt đầu làm ngay</p>
      </div>
    </div>
    @if (Model.Quizzes.Any())
    {
      <div class="quiz-grid">
        @foreach (var quiz in Model.Quizzes)
        {
          var isNotStarted = quiz.StartAt.HasValue && DateTime.Now < quiz.StartAt.Value;
          var isEnded = quiz.EndAt.HasValue && DateTime.Now > quiz.EndAt.Value;
          var canTake = !isNotStarted && !isEnded;
          <div class="quiz-card">
            <div class="quiz-title">@quiz.Title</div>
            <div class="quiz-course">@quiz.CourseName</div>
            <div class="quiz-desc">@(!string.IsNullOrWhiteSpace(quiz.Description) ? quiz.Description : "Không có mô tả.")</div>
            <div class="quiz-timing">🕐 Bắt đầu: @(quiz.StartAt.HasValue ? quiz.StartAt.Value.ToString("dd/MM/yyyy HH:mm") : "Ngay khi mở")</div>
            <div class="quiz-timing">🏁 Kết thúc: @(quiz.EndAt.HasValue ? quiz.EndAt.Value.ToString("dd/MM/yyyy HH:mm") : "Không giới hạn")</div>
            <div class="quiz-footer">
              <span class="quiz-meta-pill">@quiz.QuestionCount câu • @quiz.TimeLimitMinutes phút</span>
              @if (canTake)
              {
                <a class="btn-start" href="/Student/TakeQuiz?quizId=@quiz.Id">Làm bài →</a>
              }
              else if (isNotStarted)
              {
                <span class="badge-soon">⏳ Chưa mở</span>
              }
              else
              {
                <span class="badge-closed">🔒 Đã đóng</span>
              }
            </div>
          </div>
        }
      </div>
    }
    else
    {
      <div class="empty-hint">Bạn chưa có bài quiz nào khả dụng.</div>
    }
  </div>

  <!-- Recent results -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-head-left">
        <h3>🏆 Kết quả gần đây</h3>
        <p>Lịch sử làm bài gần nhất của bạn</p>
      </div>
    </div>
    @if (Model.Results.Any())
    {
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Bài quiz</th>
              <th>Điểm</th>
              <th>Tỷ lệ</th>
              <th>Thời gian làm</th>
              <th>Hoàn thành</th>
              <th style="text-align:right">Chi tiết</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var result in Model.Results.Take(10))
            {
              double pct = 0;
              double.TryParse(result.PercentageScore?.Replace("%",""), out pct);
              var pctColor = pct >= 80 ? "#22c55e" : pct >= 60 ? "#f5a623" : "#f87171";
              <tr>
                <td style="font-weight:600">@result.QuizTitle</td>
                <td class="score-cell">@result.Score / @result.TotalPoints</td>
                <td>
                  <span class="pct-pill" style="background:@(pctColor)22; color:@pctColor; border:1px solid @(pctColor)44">
                    @result.PercentageScore
                  </span>
                </td>
                <td style="color:var(--text-muted); font-variant-numeric:tabular-nums">@result.TimeTaken.ToString(@"hh\:mm\:ss")</td>
                <td style="color:var(--text-muted)">@result.CompletedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                <td style="text-align:right">
                  <a class="btn-detail" href="/Student/QuizResult?id=@result.Id">Xem →</a>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
    else
    {
      <div class="empty-hint">Bạn chưa nộp bài quiz nào.</div>
    }
  </div>

</div>
</body>
</html>
