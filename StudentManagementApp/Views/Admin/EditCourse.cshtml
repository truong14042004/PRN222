@using StudentManagementApp.BLL.DTOs
@model UpdateCourseDto

@{
    ViewData["Title"] = "Sửa khóa học";
    string[] levels = { "A1", "A2", "B1", "B2", "C1", "C2" };
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0">Sửa khóa học</h4>
                <a asp-action="Courses" class="btn btn-outline-secondary rounded-pill">Quay lại</a>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <form asp-action="EditCourse" method="post" enctype="multipart/form-data">
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="ThumbnailUrl" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên khóa học</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Cấp độ</label>
                        <select asp-for="Level" class="form-select">
                            @foreach (var l in levels)
                            {
                                <option value="@l" selected="@(Model.Level == l)">@l</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Học phí (₫)</label>
                        <input asp-for="TuitionFee" type="number" class="form-control" />
                        <span asp-validation-for="TuitionFee" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ảnh thumbnail</label>
                        @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                        {
                            <div class="mb-2"><img src="@Model.ThumbnailUrl" style="height:80px;border-radius:8px" /></div>
                        }
                        <input type="file" name="thumbnail" class="form-control" accept="image/*" />
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Đang mở</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">Lưu thay đổi</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}