@page
@model StudentManagementApp.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - English Center</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --ink: #0f172a;
            --muted: #64748b;
            --line: #d9e4f2;
            --brand: #1d4ed8;
            --brand-2: #0f766e;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(900px 440px at 0% 0%, #dbeafe 0%, transparent 70%),
                radial-gradient(900px 440px at 100% 100%, #dcfce7 0%, transparent 70%),
                #f3f7ff;
            display: grid;
            place-items: center;
            padding: 18px;
        }

        .auth-shell {
            width: min(980px, 100%);
            border: 1px solid var(--line);
            border-radius: 22px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 26px 52px rgba(15, 23, 42, .15);
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .intro {
            padding: 28px;
            color: #fff;
            background: linear-gradient(135deg, var(--brand) 0%, var(--brand-2) 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 16px;
        }

        .intro h1 {
            margin: 0;
            font-size: clamp(1.5rem, 2.5vw, 2.1rem);
            font-weight: 800;
        }

        .intro p {
            margin: 8px 0 0;
            color: rgba(255,255,255,.9);
            line-height: 1.6;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            padding: 7px 12px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,.35);
            background: rgba(255,255,255,.08);
            font-size: .85rem;
            font-weight: 600;
        }

        .form-side {
            padding: 26px 22px;
        }

        .form-title {
            margin: 0;
            font-size: 1.45rem;
            font-weight: 800;
        }

        .form-sub {
            margin-top: 6px;
            color: var(--muted);
            font-size: .92rem;
        }

        .form-label {
            font-weight: 600;
            font-size: .92rem;
        }

        .form-control {
            border-radius: 10px;
            border-color: #cfdbee;
            padding: .62rem .78rem;
        }

        .form-control:focus {
            border-color: #6ea1ff;
            box-shadow: 0 0 0 .2rem rgba(59, 130, 246, .15);
        }

        .btn-auth {
            border: 0;
            border-radius: 10px;
            background: linear-gradient(135deg, #1d4ed8 0%, #0f766e 100%);
            color: #fff;
            font-weight: 700;
            width: 100%;
            padding: .72rem;
        }

        .btn-auth:hover {
            color: #fff;
            filter: brightness(.96);
        }

        .foot-note {
            color: var(--muted);
            font-size: .9rem;
        }

        @@media (max-width: 900px) {
            .auth-shell {
                grid-template-columns: 1fr;
            }

            .intro {
                padding: 20px;
            }

            .form-side {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="auth-shell">
        <section class="intro">
            <div>
                <span class="tag">English Center</span>
                <h1 class="mt-3">Học thông minh, tiến bộ từng ngày</h1>
                <p>Đăng nhập để truy cập lớp học, lịch học, điểm danh và bài quiz luyện tập.</p>
            </div>
            <a href="/" class="btn btn-light btn-sm align-self-start px-3">Về trang chủ</a>
        </section>

        <section class="form-side">
            <h2 class="form-title">Đăng nhập</h2>
            <p class="form-sub">Sử dụng username hoặc email để tiếp tục.</p>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger">@ViewData["Error"]</div>
            }

            <form method="post" class="mt-3">
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập hoặc email</label>
                    <input type="text" class="form-control" asp-for="Username" autocomplete="username" required>
                </div>
                <div class="mb-2">
                    <label class="form-label">Mật khẩu</label>
                    <input type="password" class="form-control" asp-for="Password" autocomplete="current-password" required>
                </div>

                <div class="text-end mb-3">
                    <a href="/Auth/ForgotPassword" class="small text-decoration-none">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn-auth">Đăng nhập</button>
            </form>

            <div class="mt-3 foot-note">
                Chưa có tài khoản?
                <a href="/Auth/Register" class="fw-semibold text-decoration-none">Đăng ký ngay</a>
            </div>
        </section>
    </div>
</body>
</html>
