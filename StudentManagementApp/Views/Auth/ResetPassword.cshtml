@using StudentManagementApp.BLL.DTOs
@model ResetPasswordDto

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu - DOL English</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #0a2d6e, #1a5fba);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .card { border: none; border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.2); }
        .brand { color: #0a2d6e; font-weight: 800; font-size: 1.8rem; }
        .brand span { color: #f0c040; }
        .btn-primary { background: #0a2d6e; border: none; }
        .btn-primary:hover { background: #1a5fba; }
        .otp-demo { background: #fff8e1; border-left: 4px solid #f0c040; padding: 10px 14px; border-radius: 6px; font-size: 0.9rem; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card p-4">
                    <div class="text-center mb-4">
                        <a href="/" class="text-decoration-none brand">DOL <span>English</span></a>
                        <p class="text-muted mt-1 mb-0">Đặt lại mật khẩu</p>
                    </div>

                    @if (ViewBag.OtpDemo != null)
                    {
                        <div class="otp-demo mb-3">
                            <strong>Demo:</strong> @ViewBag.OtpDemo
                        </div>
                    }

                    <form asp-action="ResetPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                        <input asp-for="Email" type="hidden" value="@ViewBag.Email" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input class="form-control" value="@ViewBag.Email" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="OtpCode" class="form-label fw-semibold">Mã OTP</label>
                            <input asp-for="OtpCode" class="form-control" placeholder="Nhập mã 6 số" />
                            <span asp-validation-for="OtpCode" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold">Mật khẩu mới</label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Đặt lại mật khẩu</button>
                    </form>

                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Login" class="fw-bold text-decoration-none small">Quay lại đăng nhập</a>
                        <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill">Trang chủ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
