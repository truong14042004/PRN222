@page
@model StudentManagementApp.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    var userRole = HttpContext.Session.GetString("UserRole");
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">English Center</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Course">Khóa học</a></li>
                    <li class="nav-item"><a class="nav-link" href="/PurchasableItems">Cửa hàng</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="row">
            <div class="col-md-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h4 class="mb-0">Sản phẩm trong giỏ</h4>
                    </div>
                    <div class="card-body">
                        @if (Model.Cart.Items != null && Model.Cart.Items.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var item in Model.Cart.Items)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded p-2 me-3">
                                                <i class="bi bi-box-seam text-primary" style="font-size: 1.5rem;"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0">@item.Name</h6>
                                                <small class="text-muted">@item.ItemType</small>
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-bold text-danger mb-1">@item.Price.ToString("N0") VNĐ</div>
                                            <form method="post" asp-page-handler="Remove">
                                                <input type="hidden" name="cartItemId" value="@item.ItemId" />
                                                <button type="submit" class="btn btn-sm text-muted">Xóa</button>
                                            </form>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-cart-x text-muted" style="font-size: 3rem;"></i>
                                <p class="mt-3">Giỏ hàng đang trống.</p>
                                <a href="/PurchasableItems" class="btn btn-primary">Đi mua sắm ngay</a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Tóm tắt đơn hàng</h4>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-3">
                            <span>Tạm tính:</span>
                            <span class="fw-bold">@Model.Cart.TotalAmount.ToString("N0") VNĐ</span>
                        </div>
                        
                        <div class="bg-light p-3 rounded mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Số dư ví:</span>
                                <span>@Model.WalletBalance.ToString("N0") VNĐ</span>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="useBalanceCheck" name="useBalance" value="true" checked>
                                <label class="form-check-label" for="useBalanceCheck">Sử dụng số dư ví</label>
                            </div>
                        </div>

                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="h5">Cần thanh toán:</span>
                            <span class="h5 text-danger" id="finalPrice">@Model.Cart.TotalAmount.ToString("N0") VNĐ</span>
                        </div>

                        <form method="post" asp-page-handler="Checkout">
                            <input type="hidden" name="useBalance" id="useBalanceHidden" value="true" />
                            <button type="submit" class="btn btn-danger btn-lg w-100 py-3 mb-2 shadow" @(Model.Cart.Items.Any() ? "" : "disabled")>
                                THANH TOÁN NGAY
                            </button>
                        </form>
                        <p class="text-center small text-muted">Hỗ trợ bởi PayOS</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const totalAmount = @Model.Cart.TotalAmount;
        const walletBalance = @Model.WalletBalance;
        const useBalanceCheck = document.getElementById('useBalanceCheck');
        const finalPriceLabel = document.getElementById('finalPrice');
        const useBalanceHidden = document.getElementById('useBalanceHidden');

        function updatePrice() {
            let finalPrice = totalAmount;
            if (useBalanceCheck.checked) {
                finalPrice = Math.max(0, totalAmount - walletBalance);
            }
            finalPriceLabel.innerText = finalPrice.toLocaleString('vi-VN') + ' VNĐ';
            useBalanceHidden.value = useBalanceCheck.checked;
        }

        useBalanceCheck.addEventListener('change', updatePrice);
        updatePrice();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
