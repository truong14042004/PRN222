@page
@model StudentManagementApp.Pages.Student.IndexModel
@{
    ViewData["Title"] = "Bảng điều khiển học viên";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="res-section-title">CHÀO MỪNG QUAY TRỞ LẠI!</h2>
        <a href="/PurchasableItems" class="btn btn-primary-res rounded-pill shadow-sm">🛒 Mở cửa hàng vật phẩm</a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="res-card p-3 border-start border-primary border-4">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-book text-primary h4 mb-0"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Khóa học</h6>
                        <a href="/Course" class="text-decoration-none fw-bold">Xem tất cả</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="res-card p-3 border-start border-success border-4">
                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-calendar-event text-success h4 mb-0"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Lịch học</h6>
                        <a href="/Student/Schedule" class="text-decoration-none fw-bold">Xem lịch tuần</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="res-card p-3 border-start border-info border-4">
                <div class="d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-pencil-square text-info h4 mb-0"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Làm Quiz</h6>
                        <a href="/Student/Quizzes" class="text-decoration-none fw-bold">Bắt đầu ngay</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="res-card p-3 border-start border-warning border-4">
                <div class="d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-graph-up-arrow text-warning h4 mb-0"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1">Tiến độ</h6>
                        <a href="/Student/Progress" class="text-decoration-none fw-bold">Theo dõi ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="res-card overflow-hidden">
        <div class="res-card-header d-flex justify-content-between align-items-center">
            <span>📚 LỚP HỌC ĐÃ ĐĂNG KÝ</span>
            <span class="badge bg-res-red">@Model.Enrollments.Count() Lớp</span>
        </div>
        <div class="card-body p-0">
            @if (!Model.Enrollments.Any())
            {
                <div class="p-5 text-center">
                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" style="width: 80px; opacity: 0.3;" alt="No data">
                    <p class="text-muted mt-3">Bạn chưa đăng ký lớp học nào.</p>
                    <a href="/Course" class="btn btn-outline-res rounded-pill">Đăng ký ngay</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table res-table mb-0">
                        <thead>
                            <tr>
                                <th>Khóa học</th>
                                <th>Lớp học</th>
                                <th>Ngày đăng ký</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var enrollment in Model.Enrollments)
                            {
                                <tr>
                                    <td class="fw-bold">@enrollment.CourseName</td>
                                    <td><span class="badge bg-light text-dark border">@enrollment.ClassName</span></td>
                                    <td class="text-muted">@enrollment.EnrolledAt.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @{
                                            var badgeClass = enrollment.Status switch
                                            {
                                                "Confirmed" => "bg-success",
                                                "Registered" => "bg-warning text-dark",
                                                "Cancelled" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass px-3 py-2 rounded-pill">@enrollment.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
