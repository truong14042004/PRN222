@page
@model StudentManagementApp.Pages.Admin.PurchasableItems.CreateModel
@{
    ViewData["Title"] = "Thêm vật phẩm mới";
    ViewData["ActivePage"] = "PurchasableItems";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Cửa hàng học liệu</h6>
        <h2 class="fw-bold mb-0">Thêm vật phẩm mới</h2>
    </div>
    <a asp-page="./Index" class="btn btn-light border fw-bold px-4">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="admin-card">
            <form method="post">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-4 text-center">
                            <label class="form-label fw-bold small text-muted text-uppercase d-block mb-3">Ảnh minh họa</label>
                            <div id="imagePlaceholder" class="rounded-3 shadow-sm mb-3 d-flex flex-column align-items-center justify-content-center bg-white border-dashed" style="aspect-ratio: 1;">
                                <i class="bi bi-image fs-1 text-muted opacity-50"></i>
                                <span class="small text-muted fw-bold">Chưa có ảnh</span>
                            </div>
                            <img id="itemPreview" class="img-fluid rounded-3 shadow-sm mb-3 d-none" style="aspect-ratio: 1; object-fit: cover;">
                            
                            <input asp-for="Input.ImageUrl" id="imageUrlInput" class="form-control form-control-sm" placeholder="Dán link ảnh..." 
                                   oninput="updatePreview(this.value)">
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Tên vật phẩm</label>
                            <input asp-for="Input.Name" class="form-control fw-bold fs-5" placeholder="Ví dụ: Sách IELTS Cambridge 18..." required>
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Mô tả sản phẩm</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết về học liệu..."></textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Giá niêm yết (VNĐ)</label>
                                <div class="input-group">
                                    <input asp-for="Input.Price" type="number" class="form-control fw-bold text-primary" placeholder="0" required>
                                    <span class="input-group-text bg-white">đ</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Số lượng nhập kho</label>
                                <input asp-for="Input.Quantity" type="number" class="form-control fw-bold" placeholder="0" required>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-5 opacity-50">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary-res px-5 py-3 fw-bold shadow-sm">
                        <i class="bi bi-plus-circle me-2"></i>Thêm vào kho hàng
                    </button>
                    <a asp-page="./Index" class="btn btn-light border px-5 py-3 fw-bold">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control {
        padding: 0.75rem 1rem;
        border-radius: 12px !important;
        border: 1px solid #e2e8f0;
    }
    .form-control:focus {
        border-color: var(--res-red);
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }
    .border-dashed { border: 2px dashed #cbd5e1 !important; }
</style>

@section Scripts {
    <script>
        function updatePreview(url) {
            const preview = document.getElementById('itemPreview');
            const placeholder = document.getElementById('imagePlaceholder');
            if (url) {
                preview.src = url;
                preview.classList.remove('d-none');
                placeholder.classList.add('d-none');
            } else {
                preview.classList.add('d-none');
                placeholder.classList.remove('d-none');
            }
        }
    </script>
}
