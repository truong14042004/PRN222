@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/res-style.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var userName = Context.Session.GetString("UserName");
        var userRole = Context.Session.GetString("UserRole");
        var userId = Context.Session.GetString("UserId");
    }

    <nav class="navbar navbar-expand-lg navbar-res sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img src="/images/logo.jpg" alt="English Center Logo">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Course">Khóa học</a></li>
                    @if (userRole == "Student" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Student">Học viên</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Student/Schedule">Lịch học</a></li>
                        <li class="nav-item"><a class="nav-link text-res-red" href="/PurchasableItems">🛒 Cửa hàng</a></li>
                    }
                    @if (userRole == "Teacher" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Teacher">Lớp dạy</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Teacher/Schedule">Lịch dạy</a></li>
                    }
                    @if (userRole == "Admin" && userId != null)
                    {
                        <li class="nav-item"><a class="nav-link text-primary" href="/Admin">Quản trị</a></li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (userId != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle btn btn-outline-res px-3 rounded-pill" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                @if (userRole == "Student") {
                                    <li><a class="dropdown-item" href="/Student"><i class="bi bi-person-workspace me-2"></i> Dashboard</a></li>
                                    <li><a class="dropdown-item" href="/Student/Orders"><i class="bi bi-journal-text me-2"></i> Lịch sử đơn hàng</a></li>
                                }
                                <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person-lines-fill me-2"></i> Hồ sơ cá nhân</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2"><a class="nav-link" href="/Auth/Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="btn btn-primary-res px-4 rounded-pill" href="/Auth/Register">Tham gia ngay</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0 border-start border-success border-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0 border-start border-danger border-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @RenderBody()
    </main>

