@page
@model StudentManagementApp.Pages.Admin.QuizQuestionsModel
@{
    ViewData["Title"] = "Quản lý câu hỏi quiz";
    var quiz = Model.Quiz;
    var userName = HttpContext.Session.GetString("UserName");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                font-family: "Be Vietnam Pro", sans-serif;
                background: #f5f7fb;
                margin: 0;
            }

            /* SIDEBAR */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                background: #0f172a;
                color: white;
                padding: 20px;
            }

                .sidebar h4 {
                    font-weight: 700;
                    margin-bottom: 30px;
                }

                .sidebar a {
                    display: block;
                    color: #cbd5f1;
                    padding: 10px 12px;
                    border-radius: 10px;
                    text-decoration: none;
                    margin-bottom: 8px;
                }

                    .sidebar a:hover,
                    .sidebar a.active {
                        background: #1e293b;
                        color: white;
                    }

            /* MAIN */
            .main {
                margin-left: 250px;
                padding: 20px 30px;
            }

            /* CARD */
            .card-box {
                background: white;
                border-radius: 16px;
                padding: 18px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            }

            /* HERO */
            .hero {
                border-radius: 16px;
                padding: 18px;
                color: #fff;
                background: linear-gradient(135deg, #3b82f6, #6366f1);
                margin-bottom: 20px;
            }

            /* QUESTION */
            .q-item {
                padding: 14px;
                border-bottom: 1px solid #e2e8f0;
            }

                .q-item:last-child {
                    border-bottom: none;
                }

            .answer {
                display: inline-block;
                padding: 6px 12px;
                border-radius: 999px;
                margin: 4px 4px 0 0;
                background: #f1f5f9;
                font-size: 13px;
            }

                .answer.correct {
                    background: #dcfce7;
                    color: #166534;
                    font-weight: 600;
                }

            /* FORM */
            .form-control, select {
                border-radius: 10px !important;
            }

            .hidden {
                display: none;
            }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>🎓 Admin</h4>

        <a href="/Admin">Dashboard</a>
        <a href="/Admin/Users">Người dùng</a>
        <a href="/Admin/Courses">Khóa học</a>
        <a href="/Admin/Classes">Lớp học</a>
        <a href="/Admin/Enrollments">Đăng ký</a>
        <a class="active" href="/Admin/Quizzes">Quiz</a>

        <hr style="border-color:#334155">

        <a href="/Auth/Logout">🚪 Đăng xuất</a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <!-- TOP -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h3 class="mb-0">Câu hỏi Quiz</h3>
                <small class="text-muted">Xin chào, @userName</small>
            </div>

            <a href="/Admin/Quizzes" class="btn btn-outline-secondary">← Quay lại</a>
        </div>

        <!-- HERO -->
        <div class="hero">
            <h2>@(quiz?.Title ?? "Quiz")</h2>
            <div>
                Khóa học: @quiz?.CourseName |
                Tổng câu hỏi: @(quiz?.QuestionCount ?? 0)
            </div>
        </div>

        <div class="row g-3">

            <!-- LIST -->
            <div class="col-md-7">
                <div class="card-box">

                    <h5 class="mb-3">Danh sách câu hỏi</h5>

                    @if (quiz?.Questions?.Any() == true)
                    {
                        @foreach (var q in quiz.Questions)
                        {
                            <div class="q-item">
                                <div class="fw-bold">
                                    #@q.SortOrder - @q.QuestionText
                                </div>

                                <div class="mt-2">
                                    @foreach (var o in q.Options)
                                    {
                                        <span class="answer @(o.IsCorrect ? "correct" : "")">
                                            @o.OptionText
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Chưa có câu hỏi</p>
                    }

                </div>
            </div>

            <!-- FORM -->
            <div class="col-md-5">
                <div class="card-box">

                    <h5 class="mb-3">Thêm / Sửa câu hỏi</h5>

                    <form method="post" asp-page-handler="Save" asp-route-quizId="@Model.QuizId">

                        <input type="hidden" asp-for="Input.QuestionId" />

                        <label class="form-label">Nội dung câu hỏi</label>
                        <textarea asp-for="Input.QuestionText" class="form-control"></textarea>

                        <label class="form-label mt-2">Loại câu hỏi</label>
                        <select asp-for="Input.QuestionType" id="type" class="form-select">
                            <option value="MultipleChoice">Trắc nghiệm</option>
                            <option value="FillInBlank">Điền đáp án</option>
                        </select>

                        <!-- MCQ -->
                        <div id="mcq">
                            <input asp-for="Input.OptionA" class="form-control mt-2" placeholder="Đáp án A">
                            <input asp-for="Input.OptionB" class="form-control mt-2" placeholder="Đáp án B">
                            <input asp-for="Input.OptionC" class="form-control mt-2" placeholder="Đáp án C">
                            <input asp-for="Input.OptionD" class="form-control mt-2" placeholder="Đáp án D">
                        </div>

                        <!-- FILL -->
                        <div id="fill" class="hidden mt-2">
                            <input asp-for="Input.FillInAnswer" class="form-control" placeholder="Đáp án đúng">
                        </div>

                        <button class="btn btn-primary w-100 mt-3">
                            Lưu câu hỏi
                        </button>

                    </form>

                </div>
            </div>

        </div>

    </div>

    <script>
            const type = document.getElementById("type");
            const mcq = document.getElementById("mcq");
            const fill = document.getElementById("fill");

            function toggle(){
                if(type.value === "FillInBlank"){
                    mcq.classList.add("hidden");
                    fill.classList.remove("hidden");
                } else {
                    mcq.classList.remove("hidden");
                    fill.classList.add("hidden");
                }
            }

            type.addEventListener("change", toggle);
            toggle();
    </script>

</body>
</html>