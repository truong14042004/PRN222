@using StudentManagementApp.BLL.DTOs
@model IEnumerable<EnrollmentDto>

@{
    ViewData["Title"] = "Xác nhận đăng ký";
}

<div class="container py-5">
    <h4 class="fw-bold mb-4">Xác nhận đăng ký học</h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3 pb-2 px-3">
            <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
                <input type="text" name="q" value="@ViewBag.Q" class="form-control" style="max-width:320px" placeholder="Tìm theo học viên, lớp học, khóa học..." />
                <div class="form-check mb-0 ms-1">
                    <input type="checkbox" name="pending" value="true" id="chkPending" class="form-check-input"
                           @(ViewBag.Pending == true ? "checked" : "") onchange="this.form.submit()" />
                    <label for="chkPending" class="form-check-label fw-semibold text-warning">Chờ xác nhận</label>
                </div>
                <button type="submit" class="btn btn-outline-primary rounded-pill px-3"><i class="fa fa-search"></i></button>
                @if (!string.IsNullOrEmpty(ViewBag.Q as string) || ViewBag.Pending == true)
                {
                    <a asp-action="Enrollments" class="btn btn-outline-secondary rounded-pill px-3">Xóa</a>
                }
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Học viên</th>
                        <th>Lớp học</th>
                        <th>Khóa học</th>
                        <th>Ngày đăng ký</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@e.StudentName</td>
                            <td>@e.ClassName</td>
                            <td>@e.CourseName</td>
                            <td>@e.EnrolledAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge @(e.Status == "Confirmed" ? "bg-success" : "bg-warning text-dark")">
                                    @(e.Status == "Confirmed" ? "Đã xác nhận" : "Chờ xác nhận")
                                </span>
                            </td>
                            <td>
                                @if (e.Status == "Registered")
                                {
                                    <form asp-action="ConfirmEnrollment" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">Xác nhận</button>
                                    </form>
                                    <form asp-action="CancelEnrollment" method="post" class="d-inline ms-1"
                                          onsubmit="return confirm('Hủy đăng ký của @e.StudentName?')">
                                        <input type="hidden" name="id" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Hủy</button>
                                    </form>
                                }
                                else if (e.Status == "Confirmed")
                                {
                                    <form asp-action="CancelEnrollment" method="post" class="d-inline"
                                          onsubmit="return confirm('Hủy đăng ký đã xác nhận của @e.StudentName?')">
                                        <input type="hidden" name="id" value="@e.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Hủy</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if ((int)ViewBag.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                        <a class="page-link" asp-action="Enrollments" asp-route-q="@ViewBag.Q" asp-route-pending="@ViewBag.Pending" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
        <p class="text-center text-muted small">Tổng: @ViewBag.TotalCount đăng ký</p>
    }
</div>
