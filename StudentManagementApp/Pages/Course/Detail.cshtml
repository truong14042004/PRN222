@page "{id:int?}"
@model StudentManagementApp.Pages.Course.DetailModel
@{
    ViewData["Title"] = Model.Course?.Name ?? "Chi tiết khóa học";
    var userId = HttpContext.Session.GetString("UserId");
}

<div class="container py-5">
    @if (Model.Course != null)
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="res-card mb-4">
                    <div class="res-card-header bg-white">
                        <h2 class="mb-0 fw-bold">@Model.Course.Name</h2>
                    </div>
                    <div class="card-body">
                        <span class="badge-res bg-res-red text-white mb-3">LEVEL: @Model.Course.Level</span>
                        <div class="mt-2 h5 fw-normal text-muted" style="line-height: 1.8;">
                            @Model.Course.Description
                        </div>
                        
                        <div class="mt-4 p-4 bg-light rounded-3 d-flex align-items-center">
                            <i class="bi bi-wallet2 text-res-red h3 mb-0 me-3"></i>
                            <div>
                                <div class="small text-muted fw-bold text-uppercase">Học phí trọn khóa</div>
                                <div class="h4 mb-0 fw-bold text-res-red">@Model.Course.TuitionFee.ToString("N0") VNĐ</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="res-card overflow-hidden">
                    <div class="res-card-header d-flex justify-content-between align-items-center">
                        <span>🗓️ LỚP HỌC ĐANG MỞ</span>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Classes != null && Model.Classes.Any())
                        {
                            <div class="table-responsive">
                                <table class="table res-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Tên lớp</th>
                                            <th>Khai giảng</th>
                                            <th>Kết thúc</th>
                                            <th>Trạng thái</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cls in Model.Classes)
                                        {
                                            <tr>
                                                <td class="fw-bold">@cls.ClassName</td>
                                                <td>@cls.StartDate.ToString("dd/MM/yyyy")</td>
                                                <td>@cls.EndDate.ToString("dd/MM/yyyy")</td>
                                                <td>
                                                    @{
                                                        var badgeClass = cls.Status switch
                                                        {
                                                            "Upcoming" => "bg-success",
                                                            "Ongoing" => "bg-primary",
                                                            _ => "bg-secondary"
                                                        };
                                                    }
                                                    <span class="badge @badgeClass px-3 py-2 rounded-pill">@cls.Status</span>
                                                </td>
                                                <td class="text-end">
                                                    @if (userId != null && cls.Status == "Upcoming")
                                                    {
                                                        <form method="post" asp-page-handler="Enroll" asp-route-id="@Model.Course.Id">
                                                            <input type="hidden" name="classId" value="@cls.Id" />
                                                            <button type="submit" class="btn btn-primary-res btn-sm rounded-pill px-3">Đăng ký lớp</button>
                                                        </form>
                                                    }
                                                    else if (userId == null)
                                                    {
                                                        <a href="/Auth/Login" class="btn btn-outline-res btn-sm rounded-pill px-3">Đăng nhập</a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="p-5 text-center">
                                <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                                <p class="text-muted mt-3">Hiện chưa có lớp học nào khả dụng cho khóa học này.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="res-card sticky-top" style="top: 100px; z-index: 100;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Tại sao chọn chúng tôi?</h5>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-3 d-flex align-items-start">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span>Giảng viên bản ngữ giàu kinh nghiệm.</span>
                            </li>
                            <li class="mb-3 d-flex align-items-start">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span>Giáo trình chuẩn quốc tế.</span>
                            </li>
                            <li class="mb-3 d-flex align-items-start">
                                <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
                                <span>Môi trường học tập hiện đại.</span>
                            </li>
                        </ul>
                        <div class="d-grid gap-2">
                            <a href="/Course" class="btn btn-outline-res rounded-pill">Xem khóa học khác</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h2 class="text-danger">Không tìm thấy khóa học</h2>
            <a href="/Course" class="btn btn-primary-res rounded-pill px-4 mt-3">Quay lại danh sách</a>
        </div>
    }
</div>
