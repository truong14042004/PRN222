@page
@model StudentManagementApp.Pages.Admin.ClassesModel
@{
    ViewData["Title"] = "Quản lý lớp học";
    ViewData["ActivePage"] = "Classes";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Quản lý đào tạo</h6>
        <h2 class="fw-bold mb-0">Danh sách lớp học</h2>
    </div>
    <a href="/Admin/Classes/Create" class="btn btn-primary-res px-4">
        <i class="bi bi-building-add me-2"></i>Thêm lớp học
    </a>
</div>

<div class="admin-card">
    @if (Model.Classes.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Thông tin lớp</th>
                        <th>Giáo viên</th>
                        <th>Thời gian</th>
                        <th>Lịch học</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cls in Model.Classes)
                    {
                        var scheduleText = cls.Schedules.Any()
                            ? string.Join(", ", cls.Schedules.Select(s => $"T{s.DayOfWeek} {s.StartTime:HH\\:mm}-{s.EndTime:HH\\:mm}"))
                            : "Chưa có lịch";

                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@cls.ClassName</div>
                                <div class="text-muted small">Khóa: @cls.CourseName</div>
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(cls.TeacherName))
                                {
                                    <span class="text-muted small italic">Chưa phân công</span>
                                }
                                else
                                {
                                    <div class="small fw-bold">@cls.TeacherName</div>
                                }
                            </td>
                            <td>
                                <div class="small">Bắt đầu: @cls.StartDate.ToString("dd/MM/yyyy")</div>
                                <div class="small">Kết thúc: @cls.EndDate.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td>
                                <div class="small text-muted" style="max-width: 200px;">@scheduleText</div>
                            </td>
                            <td>
                                @{
                                    var badgeClass = cls.Status switch
                                    {
                                        "Upcoming" => "bg-success-subtle text-success",
                                        "Ongoing" => "bg-primary-subtle text-primary",
                                        _ => "bg-secondary-subtle text-muted"
                                    };
                                }
                                <span class="badge rounded-pill @badgeClass px-3">@cls.Status</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/Admin/Classes/Edit/@cls.Id" class="btn btn-sm btn-light border fw-bold text-muted px-3">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <form method="post" asp-page="/Admin/Classes/Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@cls.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger fw-bold px-3"
                                                onclick="return confirm('Xóa lớp này?');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-building-exclamation text-muted opacity-25 display-1"></i>
            <p class="mt-3 text-muted fw-bold">Hiện chưa có lớp học nào.</p>
        </div>
    }
</div>

<style>
    .bg-success-subtle { background: #ecfdf5 !important; }
    .bg-primary-subtle { background: #eff6ff !important; }
    .bg-secondary-subtle { background: #f8fafc !important; }
    .custom-table thead th {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.5px; color: #64748b; padding-top: 15px; padding-bottom: 15px;
    }
    .custom-table tbody td { padding-top: 15px; padding-bottom: 15px; }
</style>