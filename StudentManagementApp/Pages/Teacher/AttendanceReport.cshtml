@page "{classId:int}"
@model StudentManagementApp.Pages.Teacher.AttendanceReportModel
@{
    ViewData["Title"] = "Báo cáo điểm danh";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        @if (Model.Class is null)
        {
            <div class="alert alert-danger">Không tìm thấy lớp học.</div>
            <a href="/Teacher" class="btn btn-secondary">Quay lại</a>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="mb-1">Báo cáo điểm danh: @Model.Class.ClassName</h2>
                    <div class="text-muted">@Model.Class.CourseName</div>
                </div>
                <div class="d-flex gap-2">
                    <a href="/Admin/Quizzes" class="btn btn-outline-secondary">Quiz</a>
                    <a href="/Teacher/Attendance/@Model.Class.Id" class="btn btn-outline-primary">Điểm danh</a>
                </div>
            </div>

            <form method="get" class="row g-2 align-items-end mb-3">
                <input type="hidden" name="classId" value="@Model.Class.Id" />
                <div class="col-md-3">
                    <label class="form-label">Ngày xem</label>
                    <input type="date" name="date" class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary">Xem</button>
                </div>
            </form>

            @if (Model.Attendances.Any())
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Học viên</th>
                            <th>Ngày</th>
                            <th>Trạng thái</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Attendances)
                        {
                            <tr>
                                <td>@item.StudentName</td>
                                <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge bg-@(item.IsPresent ? "success" : "danger")">
                                        @(item.IsPresent ? "Có mặt" : "Vắng")
                                    </span>
                                </td>
                                <td>@item.Note</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Chưa có dữ liệu điểm danh cho ngày đã chọn.</p>
            }

            <a href="/Teacher" class="btn btn-secondary">Quay lại danh sách lớp</a>
        }
    </div>
</body>
</html>
