@page
@model StudentManagementApp.Pages.Admin.Classes.CreateModel
@{
    ViewData["Title"] = "Tạo lớp học";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="mb-0">Tạo lớp học</h1>
            <a href="/Admin/Classes" class="btn btn-outline-secondary">Quay lại</a>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Tên lớp học</label>
                    <input asp-for="Input.ClassName" class="form-control" placeholder="Ví dụ: IELTS Foundation - T7CN" />
                    <span asp-validation-for="Input.ClassName" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ngày bắt đầu</label>
                    <input asp-for="Input.StartDate" type="date" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ngày kết thúc</label>
                    <input asp-for="Input.EndDate" type="date" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Khóa học</label>
                    <select asp-for="Input.CourseId" class="form-select">
                        <option value="0">-- Chọn khóa học --</option>
                        @foreach (var course in Model.Courses)
                        {
                            <option value="@course.Id">@course.Name (@course.Level)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Giáo viên phụ trách</label>
                    <select asp-for="Input.TeacherId" class="form-select">
                        <option value="">-- Chưa phân công --</option>
                        @foreach (var teacher in Model.Teachers)
                        {
                            <option value="@teacher.Id">@teacher.FullName (@teacher.Email)</option>
                        }
                    </select>
                </div>
            </div>

            <hr class="my-4" />
            <h5>Lịch học</h5>
            <p class="text-muted">Bạn có thể nhập nhiều buổi/tuần.</p>

            <div id="scheduleRows">
                @for (var i = 0; i < Model.Input.Schedules.Count; i++)
                {
                    <div class="row g-2 align-items-end mb-2 schedule-row">
                        <div class="col-md-4">
                            <label class="form-label">Thứ</label>
                            <select asp-for="Input.Schedules[i].DayOfWeek" class="form-select">
                                <option value="">-- Chọn thứ --</option>
                                <option value="2">Thứ Hai</option>
                                <option value="3">Thứ Ba</option>
                                <option value="4">Thứ Tư</option>
                                <option value="5">Thứ Năm</option>
                                <option value="6">Thứ Sáu</option>
                                <option value="7">Thứ Bảy</option>
                                <option value="8">Chủ Nhật</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Bắt đầu</label>
                            <input asp-for="Input.Schedules[i].StartTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Kết thúc</label>
                            <input asp-for="Input.Schedules[i].EndTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-danger w-100 btn-remove">Xóa dòng</button>
                        </div>
                    </div>
                }
            </div>

            <button type="button" id="btnAddSchedule" class="btn btn-outline-primary btn-sm mt-2">+ Thêm dòng lịch</button>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Lưu lớp học</button>
                <a href="/Admin/Classes" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>

    <script>
        (function () {
            const container = document.getElementById('scheduleRows');
            const addBtn = document.getElementById('btnAddSchedule');

            function attachRemoveHandlers() {
                container.querySelectorAll('.btn-remove').forEach(btn => {
                    btn.onclick = function () {
                        const rows = container.querySelectorAll('.schedule-row');
                        if (rows.length <= 1) return;
                        btn.closest('.schedule-row').remove();
                        reindexRows();
                    };
                });
            }

            function reindexRows() {
                const rows = container.querySelectorAll('.schedule-row');
                rows.forEach((row, idx) => {
                    row.querySelectorAll('[name]').forEach(input => {
                        input.name = input.name.replace(/Input\.Schedules\[\d+\]/, `Input.Schedules[${idx}]`);
                    });
                    row.querySelectorAll('[id]').forEach(input => {
                        input.id = input.id.replace(/Input_Schedules_\d+__/, `Input_Schedules_${idx}__`);
                    });
                });
            }

            addBtn.onclick = function () {
                const idx = container.querySelectorAll('.schedule-row').length;
                const html = `
                    <div class="row g-2 align-items-end mb-2 schedule-row">
                        <div class="col-md-4">
                            <label class="form-label">Thứ</label>
                            <select name="Input.Schedules[${idx}].DayOfWeek" class="form-select">
                                <option value="">-- Chọn thứ --</option>
                                <option value="2">Thứ Hai</option>
                                <option value="3">Thứ Ba</option>
                                <option value="4">Thứ Tư</option>
                                <option value="5">Thứ Năm</option>
                                <option value="6">Thứ Sáu</option>
                                <option value="7">Thứ Bảy</option>
                                <option value="8">Chủ Nhật</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Bắt đầu</label>
                            <input name="Input.Schedules[${idx}].StartTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Kết thúc</label>
                            <input name="Input.Schedules[${idx}].EndTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-danger w-100 btn-remove">Xóa dòng</button>
                        </div>
                    </div>`;
                container.insertAdjacentHTML('beforeend', html);
                attachRemoveHandlers();
            };

            attachRemoveHandlers();
        })();
    </script>
</body>
</html>
