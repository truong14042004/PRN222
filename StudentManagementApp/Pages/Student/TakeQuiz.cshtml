@page
@model StudentManagementApp.Pages.Student.TakeQuizModel
@{
    ViewData["Title"] = "Làm bài quiz";
}

<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Làm bài Quiz - English Center</title>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d0f14;
  --surface: #13161d;
  --surface-2: #1a1e28;
  --surface-3: #20252f;
  --border: rgba(255,255,255,0.07);
  --accent: #e8412a;
  --blue: #4a9eff;
  --green: #22c55e;
  --amber: #f5a623;
  --purple: #a78bfa;
  --text: #f0f2f5;
  --text-muted: #6b7280;
  --text-soft: #9ca3af;
}
* { margin:0; padding:0; box-sizing:border-box; }
html, body { height:100%; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Be Vietnam Pro', sans-serif;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
body::before {
  content:'';
  position:fixed; top:-150px; right:-150px;
  width:500px; height:500px;
  background: radial-gradient(circle, rgba(167,139,250,0.07) 0%, transparent 70%);
  pointer-events:none; z-index:0;
}

/* ── Top bar ── */
.topbar {
  position: sticky; top:0; z-index:100;
  background: rgba(13,15,20,0.95);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  padding: 14px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}
.topbar-left {}
.quiz-title {
  font-family: 'Playfair Display', serif;
  font-size: 17px;
  letter-spacing: -0.3px;
  line-height: 1.2;
}
.quiz-course { font-size:12px; color:var(--text-muted); margin-top:2px; }

.topbar-right { display:flex; align-items:center; gap:12px; }

.progress-pill {
  display:flex; align-items:center; gap:10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 7px 16px;
  font-size:13px; font-weight:600;
  white-space:nowrap;
}
.progress-track {
  width: 80px; height:4px;
  background: var(--surface-2);
  border-radius:100px; overflow:hidden;
}
.progress-fill {
  height:100%; border-radius:100px;
  background: linear-gradient(90deg, var(--purple), var(--blue));
  transition: width 0.4s ease;
}

.timer-box {
  display:flex; align-items:center; gap:8px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 7px 16px;
  font-size:14px; font-weight:700;
  font-variant-numeric: tabular-nums;
  color: var(--blue);
  min-width: 90px;
  justify-content: center;
}
.timer-box.warn {
  border-color: rgba(232,65,42,0.4);
  color: var(--accent);
  background: rgba(232,65,42,0.08);
  animation: pulse 1s ease infinite;
}
@@keyframes pulse {
  0%,100% { opacity:1; }
  50% { opacity:0.7; }
}

.btn-cancel {
  display:inline-flex; align-items:center; gap:5px;
  border: 1px solid var(--border);
  color: var(--text-muted); text-decoration:none;
  padding:7px 14px; border-radius:8px;
  font-size:12.5px; font-weight:600;
  transition:all 0.2s;
}
.btn-cancel:hover { color:var(--text); background:var(--surface-2); }

/* ── Main layout ── */
.main {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 0;
  flex: 1;
  position: relative; z-index:1;
}

/* ── Question map sidebar ── */
.sidebar {
  border-right: 1px solid var(--border);
  padding: 24px 16px;
  background: var(--surface);
  position: sticky;
  top: 69px; /* topbar height */
  height: calc(100vh - 69px);
  overflow-y: auto;
}
.sidebar h4 {
  font-size:11px; text-transform:uppercase;
  letter-spacing:1px; color:var(--text-muted);
  font-weight:700; margin-bottom:14px; padding:0 4px;
}
.q-map {
  display:grid; grid-template-columns: repeat(5, 1fr); gap:6px;
}
.q-dot {
  aspect-ratio:1;
  border-radius:8px;
  border: 1.5px solid var(--border);
  background: var(--surface-2);
  display:flex; align-items:center; justify-content:center;
  font-size:12px; font-weight:700; color:var(--text-muted);
  cursor:pointer; transition:all 0.15s;
  user-select:none;
}
.q-dot:hover { border-color:rgba(255,255,255,0.2); color:var(--text); }
.q-dot.answered {
  background:rgba(34,197,94,0.15);
  border-color:rgba(34,197,94,0.35);
  color:#4ade80;
}
.q-dot.current {
  background:rgba(74,158,255,0.2);
  border-color:rgba(74,158,255,0.5);
  color:var(--blue);
  box-shadow:0 0 10px rgba(74,158,255,0.25);
}
.q-dot.answered.current {
  background:rgba(74,158,255,0.2);
  border-color:rgba(74,158,255,0.5);
  color:var(--blue);
}

.sidebar-legend {
  margin-top:18px; padding-top:16px;
  border-top:1px solid var(--border);
  display:flex; flex-direction:column; gap:8px;
}
.legend-item {
  display:flex; align-items:center; gap:8px;
  font-size:12px; color:var(--text-muted);
}
.legend-dot {
  width:12px; height:12px; border-radius:4px; flex-shrink:0;
}
.legend-dot.answered { background:rgba(34,197,94,0.4); border:1px solid rgba(34,197,94,0.5); }
.legend-dot.current { background:rgba(74,158,255,0.4); border:1px solid rgba(74,158,255,0.5); }
.legend-dot.unanswered { background:var(--surface-2); border:1px solid var(--border); }

/* ── Question area ── */
.q-area {
  padding: 32px 40px 60px;
  max-width: 760px;
}

.q-counter {
  font-size:12px; text-transform:uppercase; letter-spacing:1px;
  color:var(--text-muted); font-weight:700; margin-bottom:8px;
}
.q-counter span { color:var(--purple); }

.q-text {
  font-size:18px; font-weight:600; line-height:1.6;
  margin-bottom:28px; color:var(--text);
}

/* Radio options */
.options-list { display:flex; flex-direction:column; gap:10px; margin-bottom:32px; }
.option-item {
  display:flex; align-items:center; gap:14px;
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius:14px; padding:14px 18px;
  cursor:pointer; transition:all 0.2s;
  user-select:none;
}
.option-item:hover {
  border-color:rgba(74,158,255,0.3);
  background:var(--surface-2);
}
.option-item.selected {
  border-color:rgba(74,158,255,0.6);
  background:rgba(74,158,255,0.1);
}
.option-item input[type="radio"] { display:none; }
.option-circle {
  width:22px; height:22px; border-radius:50%;
  border:2px solid var(--border);
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; transition:all 0.2s;
}
.option-item.selected .option-circle {
  border-color:var(--blue);
  background:var(--blue);
}
.option-item.selected .option-circle::after {
  content:'';
  width:8px; height:8px; border-radius:50%;
  background:#fff;
}
.option-letter {
  font-size:12px; font-weight:700; color:var(--text-muted);
  min-width:18px;
}
.option-item.selected .option-letter { color:var(--blue); }
.option-text { font-size:14.5px; font-weight:500; flex:1; }

/* Fill input */
.fill-wrap { margin-bottom:32px; }
.fill-label { font-size:12px; color:var(--text-muted); margin-bottom:8px; }
.fill-input {
  width:100%;
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius:12px; color:var(--text);
  font-family:inherit; font-size:15px;
  padding:12px 16px;
  transition: border-color 0.2s;
}
.fill-input:focus {
  outline:none; border-color:rgba(74,158,255,0.5);
  background:var(--surface-2);
}
.fill-input::placeholder { color:var(--text-muted); }

/* Navigation buttons */
.nav-btns {
  display:flex; align-items:center; gap:12px;
}
.btn-prev, .btn-next {
  display:inline-flex; align-items:center; gap:8px;
  padding:11px 24px; border-radius:12px;
  font-family:inherit; font-size:14px; font-weight:700;
  cursor:pointer; border:none; transition:all 0.2s;
}
.btn-prev {
  background:var(--surface);
  border:1.5px solid var(--border);
  color:var(--text-soft);
}
.btn-prev:hover:not(:disabled) {
  background:var(--surface-2); color:var(--text);
  border-color:rgba(255,255,255,0.15);
}
.btn-prev:disabled { opacity:0.35; cursor:not-allowed; }
.btn-next {
  background:var(--blue); color:#fff;
  box-shadow:0 0 20px rgba(74,158,255,0.3);
}
.btn-next:hover { background:#68b0ff; transform:translateY(-1px); }
.btn-submit {
  background: var(--green); color:#fff;
  box-shadow:0 0 20px rgba(34,197,94,0.3);
}
.btn-submit:hover { background:#34d96a; transform:translateY(-1px); }

/* ── Submit modal ── */
.modal-overlay {
  display:none; position:fixed; inset:0; z-index:500;
  background:rgba(0,0,0,0.7);
  backdrop-filter:blur(6px);
  align-items:center; justify-content:center;
}
.modal-overlay.show { display:flex; }
.modal-box {
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:20px; padding:32px;
  max-width:400px; width:90%;
  text-align:center;
  animation: popIn 0.3s cubic-bezier(0.34,1.56,0.64,1) both;
}
@@keyframes popIn {
  from { opacity:0; transform:scale(0.85); }
  to   { opacity:1; transform:scale(1); }
}
.modal-box h3 {
  font-family:'Playfair Display',serif;
  font-size:22px; margin-bottom:10px;
}
.modal-box p { color:var(--text-muted); font-size:14px; margin-bottom:24px; line-height:1.6; }
.modal-stats {
  display:grid; grid-template-columns:1fr 1fr;
  gap:10px; margin-bottom:24px;
}
.modal-stat {
  background:var(--surface-2); border:1px solid var(--border);
  border-radius:12px; padding:12px;
}
.modal-stat-label { font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.8px; }
.modal-stat-value { font-size:20px; font-weight:800; margin-top:4px; }
.modal-btns { display:flex; gap:10px; }
.modal-btn-cancel {
  flex:1; background:var(--surface-2); border:1px solid var(--border);
  color:var(--text-soft); padding:11px; border-radius:10px;
  font-family:inherit; font-size:14px; font-weight:600;
  cursor:pointer; transition:all 0.2s;
}
.modal-btn-cancel:hover { color:var(--text); }
.modal-btn-confirm {
  flex:1; background:var(--green); border:none;
  color:#fff; padding:11px; border-radius:10px;
  font-family:inherit; font-size:14px; font-weight:700;
  cursor:pointer; transition:all 0.2s;
  box-shadow:0 0 18px rgba(34,197,94,0.3);
}
.modal-btn-confirm:hover { background:#34d96a; }

/* Error */
.error-box {
  background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.25);
  color:#f87171; border-radius:12px; padding:16px 20px;
  margin:24px; font-size:14px;
}

/* Scrollbar */
.sidebar::-webkit-scrollbar { width:4px; }
.sidebar::-webkit-scrollbar-track { background:transparent; }
.sidebar::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }

@@media(max-width:768px) {
  .main { grid-template-columns:1fr; }
  .sidebar {
    position:static; height:auto;
    border-right:none; border-bottom:1px solid var(--border);
    padding:16px;
  }
  .q-area { padding:24px 20px 48px; }
  .topbar { padding:12px 16px; }
  .quiz-title { font-size:14px; }
}
</style>
</head>
<body>

@if (Model.Quiz is null)
{
  <div style="padding:40px; text-align:center; position:relative; z-index:1;">
    <div style="color:#f87171; font-size:16px; margin-bottom:16px;">Không thể tải bài quiz.</div>
    <a href="/Student/Quizzes" style="color:var(--blue);">← Quay lại danh sách quiz</a>
  </div>
}
else
{
  var totalQ = Model.Quiz.Questions.Count;

  <!-- Topbar -->
  <div class="topbar">
    <div class="topbar-left">
      <div class="quiz-title">@Model.Quiz.Title</div>
      <div class="quiz-course">@Model.Quiz.CourseName</div>
    </div>
    <div class="topbar-right">
      <div class="progress-pill">
        <div class="progress-track">
          <div class="progress-fill" id="topProgressFill" style="width:0%"></div>
        </div>
        <span id="topProgressText">0/@totalQ</span>
      </div>
      @if (Model.Quiz.TimeLimitMinutes > 0)
      {
        <div class="timer-box" id="timerBox">
          <span>⏱</span>
          <span id="timerDisplay">--:--</span>
        </div>
      }
      <a href="/Student/Quizzes" class="btn-cancel">✕ Hủy</a>
    </div>
  </div>

  <div class="main">

    <!-- Sidebar map -->
    <div class="sidebar">
      <h4>Danh sách câu</h4>
      <div class="q-map" id="qMap">
        @for (int i = 0; i < totalQ; i++)
        {
          <div class="q-dot @(i == 0 ? "current" : "")" data-idx="@i" onclick="goToQuestion(@i)">@(i+1)</div>
        }
      </div>
      <div class="sidebar-legend">
        <div class="legend-item"><div class="legend-dot current"></div> Đang làm</div>
        <div class="legend-item"><div class="legend-dot answered"></div> Đã trả lời</div>
        <div class="legend-item"><div class="legend-dot unanswered"></div> Chưa làm</div>
      </div>
    </div>

    <!-- Question area -->
    <div class="q-area">
      @if (!string.IsNullOrWhiteSpace(Model.Error))
      {
        <div class="error-box">⚠️ @Model.Error</div>
      }

      <form method="post" id="quizForm">
        <input type="hidden" asp-for="QuizId" />

        <!-- Hidden inputs for all answers (submitted together) -->
        @for (int i = 0; i < totalQ; i++)
        {
          var q = Model.Quiz.Questions[i];
          <input type="hidden" name="Answers[@i].QuestionId" value="@q.Id" id="hiddenQId_@i" />
          <input type="hidden" name="Answers[@i].SelectedOptionId" id="hiddenOption_@i" value="" />
          <input type="hidden" name="Answers[@i].FillInAnswer" id="hiddenFill_@i" value="" />
        }

        <!-- Question cards (only one shown at a time) -->
        @for (int i = 0; i < totalQ; i++)
        {
          var q = Model.Quiz.Questions[i];
          var letters = new[] {"A","B","C","D","E","F"};
          <div class="question-slide" id="slide_@i" style="display:@(i == 0 ? "block" : "none")">

            <div class="q-counter">Câu <span>@(i+1)</span> / @totalQ &nbsp;·&nbsp; @q.Point điểm</div>
            <div class="q-text">@q.QuestionText</div>

            @if (q.QuestionType == "MultipleChoice")
            {
              <div class="options-list" id="options_@i">
                @for (int oi = 0; oi < q.Options.Count; oi++)
                {
                  var opt = q.Options[oi];
                  <label class="option-item" id="optLabel_@(i)_@oi" onclick="selectOption(@i, '@opt.Id', this)">
                    <input type="radio" name="radio_q@i" value="@opt.Id" id="radio_@(i)_@oi" />
                    <div class="option-circle"></div>
                    <span class="option-letter">@(oi < letters.Length ? letters[oi] : (oi+1).ToString())</span>
                    <span class="option-text">@opt.OptionText</span>
                  </label>
                }
              </div>
            }
            else
            {
              <div class="fill-wrap">
                <div class="fill-label">Nhập đáp án của bạn</div>
                <input class="fill-input"
                       type="text"
                       id="fill_@i"
                       placeholder="Điền vào đây..."
                       oninput="syncFill(@i, this.value)" />
              </div>
            }

            <div class="nav-btns">
              <button type="button" class="btn-prev" id="btnPrev_@i"
                      onclick="goToQuestion(@(i-1))" @(i == 0 ? "disabled" : "")>
                ← Câu trước
              </button>
              @if (i < totalQ - 1)
              {
                <button type="button" class="btn-next" onclick="goToQuestion(@(i+1))">
                  Câu tiếp →
                </button>
              }
              else
              {
                <button type="button" class="btn-next btn-submit" onclick="openSubmitModal()">
                  ✓ Nộp bài
                </button>
              }
            </div>

          </div>
        }
      </form>
    </div>
  </div>

  <!-- Submit confirmation modal -->
  <div class="modal-overlay" id="submitModal">
    <div class="modal-box">
      <div style="font-size:36px; margin-bottom:12px;">📝</div>
      <h3>Xác nhận nộp bài?</h3>
      <p id="modalDesc">Bạn đã trả lời <strong id="modalAnswered">0</strong>/<strong>@totalQ</strong> câu.<br>Sau khi nộp bạn không thể chỉnh sửa.</p>
      <div class="modal-stats">
        <div class="modal-stat">
          <div class="modal-stat-label">Đã trả lời</div>
          <div class="modal-stat-value" id="modalAnsweredVal" style="color:var(--green)">0</div>
        </div>
        <div class="modal-stat">
          <div class="modal-stat-label">Chưa làm</div>
          <div class="modal-stat-value" id="modalUnansweredVal" style="color:var(--amber)">@totalQ</div>
        </div>
      </div>
      <div class="modal-btns">
        <button class="modal-btn-cancel" onclick="closeSubmitModal()">Làm tiếp</button>
        <button class="modal-btn-confirm" onclick="submitQuiz()">Nộp bài</button>
      </div>
    </div>
  </div>
}

<script>
(function(){
  const totalQ = @((Model.Quiz?.Questions.Count ?? 0).ToString());
  let currentIdx = 0;
  // answered[i] = true/false
  const answered = new Array(totalQ).fill(false);

  // ── Navigation ──
  window.goToQuestion = function(idx) {
    if (idx < 0 || idx >= totalQ) return;
    // hide current
    document.getElementById('slide_' + currentIdx).style.display = 'none';
    updateDot(currentIdx);
    // show new
    currentIdx = idx;
    document.getElementById('slide_' + currentIdx).style.display = 'block';
    updateDot(currentIdx);
    updateProgress();
  };

  function updateDot(idx) {
    const dot = document.querySelector('.q-dot[data-idx="' + idx + '"]');
    if (!dot) return;
    dot.classList.toggle('current', idx === currentIdx);
    dot.classList.toggle('answered', answered[idx]);
  }

  function updateProgress() {
    const count = answered.filter(Boolean).length;
    const pct = totalQ > 0 ? Math.round(count * 100 / totalQ) : 0;
    const fill = document.getElementById('topProgressFill');
    const text = document.getElementById('topProgressText');
    if (fill) fill.style.width = pct + '%';
    if (text) text.textContent = count + '/' + totalQ;
    // update all dots
    for (let i = 0; i < totalQ; i++) updateDot(i);
  }

  // ── Radio select ──
  window.selectOption = function(qIdx, optionId, labelEl) {
    // deselect all in this question
    const allLabels = document.querySelectorAll('#options_' + qIdx + ' .option-item');
    allLabels.forEach(l => l.classList.remove('selected'));
    // select clicked
    labelEl.classList.add('selected');
    // sync hidden input
    document.getElementById('hiddenOption_' + qIdx).value = optionId;
    answered[qIdx] = true;
    updateDot(qIdx);
    updateProgress();
  };

  // ── Fill sync ──
  window.syncFill = function(qIdx, val) {
    document.getElementById('hiddenFill_' + qIdx).value = val;
    answered[qIdx] = val.trim().length > 0;
    updateDot(qIdx);
    updateProgress();
  };

  // ── Submit modal ──
  window.openSubmitModal = function() {
    const count = answered.filter(Boolean).length;
    const unanswered = totalQ - count;
    const el1 = document.getElementById('modalAnswered');
    const el2 = document.getElementById('modalAnsweredVal');
    const el3 = document.getElementById('modalUnansweredVal');
    if (el1) el1.textContent = count;
    if (el2) el2.textContent = count;
    if (el3) el3.textContent = unanswered;
    document.getElementById('submitModal').classList.add('show');
  };
  window.closeSubmitModal = function() {
    document.getElementById('submitModal').classList.remove('show');
  };
  window.submitQuiz = function() {
    document.getElementById('quizForm').submit();
  };
  // close modal on overlay click
  document.getElementById('submitModal')?.addEventListener('click', function(e){
    if (e.target === this) closeSubmitModal();
  });

  // ── Timer ──
  const timeLimitMinutes = @((Model.Quiz?.TimeLimitMinutes ?? 0).ToString());
  if (timeLimitMinutes > 0) {
    let remaining = timeLimitMinutes * 60;
    const timerDisplay = document.getElementById('timerDisplay');
    const timerBox = document.getElementById('timerBox');

    function fmt(s) {
      const m = Math.floor(s/60).toString().padStart(2,'0');
      const sec = (s%60).toString().padStart(2,'0');
      return m + ':' + sec;
    }
    function tick() {
      if (!timerDisplay) return;
      timerDisplay.textContent = fmt(remaining);
      if (remaining <= 300 && timerBox) timerBox.classList.add('warn');
      if (remaining <= 0) {
        document.getElementById('quizForm')?.submit();
        return;
      }
      remaining--;
    }
    tick();
    setInterval(tick, 1000);
  }

  // init
  updateProgress();
})();
</script>
</body>
</html>
