@page "{id:int}"
@model StudentManagementApp.Pages.Admin.PurchasableItems.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa vật phẩm";
    ViewData["ActivePage"] = "PurchasableItems";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Cửa hàng học liệu</h6>
        <h2 class="fw-bold mb-0">Chỉnh sửa vật phẩm</h2>
    </div>
    <a asp-page="./Index" class="btn btn-light border fw-bold px-4">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="admin-card">
            <form method="post">
                <input type="hidden" asp-for="Input.Id" />
                
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-4 text-center">
                            <label class="form-label fw-bold small text-muted text-uppercase d-block mb-3">Ảnh minh họa</label>
                            <img src="@(string.IsNullOrEmpty(Model.Input.ImageUrl) ? "https://res.edu.vn/wp-content/uploads/2021/10/banner-ielts-res.jpg" : Model.Input.ImageUrl)" 
                                 id="itemPreview" class="img-fluid rounded-3 shadow-sm mb-3" style="aspect-ratio: 1; object-fit: cover;">
                            <input asp-for="Input.ImageUrl" class="form-control form-control-sm" placeholder="URL ảnh..." 
                                   oninput="document.getElementById('itemPreview').src = this.value || 'https://res.edu.vn/wp-content/uploads/2021/10/banner-ielts-res.jpg'">
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Tên vật phẩm</label>
                            <input asp-for="Input.Name" class="form-control fw-bold" placeholder="Nhập tên vật phẩm..." required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Mô tả chi tiết</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="Nhập mô tả sản phẩm..."></textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Giá bán (VNĐ)</label>
                                <div class="input-group">
                                    <input asp-for="Input.Price" type="number" class="form-control fw-bold text-primary" required>
                                    <span class="input-group-text bg-white">đ</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Số lượng kho</label>
                                <input asp-for="Input.Quantity" type="number" class="form-control fw-bold" required>
                            </div>
                        </div>

                        <div class="form-check form-switch mt-4 p-0 ms-4">
                            <input asp-for="Input.IsActive" class="form-check-input" style="width: 3em; height: 1.5em; float: none; margin-left: -2.5em;" />
                            <label class="form-check-label ms-2 fw-bold text-dark">Đang kích hoạt kinh doanh</label>
                        </div>
                    </div>
                </div>

                <hr class="my-5 opacity-50">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary-res px-5 py-3 fw-bold shadow-sm">
                        <i class="bi bi-save me-2"></i>Cập nhật vật phẩm
                    </button>
                    <a asp-page="./Index" class="btn btn-light border px-5 py-3 fw-bold">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control {
        padding: 0.75rem 1rem;
        border-radius: 12px !important;
        border: 1px solid #e2e8f0;
    }
    .form-control:focus {
        border-color: var(--res-red);
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }
</style>
