@page
@model StudentManagementApp.Pages.Student.QuizzesModel
@{
    ViewData["Title"] = "Bài quiz của bạn";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - English Center</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg: #f4f7fc;
            --panel: #ffffff;
            --ink: #0f172a;
            --muted: #64748b;
            --line: #dbe3ef;
            --brand: #1d4ed8;
            --accent: #0f766e;
        }

        body {
            margin: 0;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(850px 420px at 0% 0%, #dbeafe 0%, transparent 70%),
                radial-gradient(850px 420px at 100% 100%, #dcfce7 0%, transparent 70%),
                var(--bg);
            min-height: 100vh;
        }

        .shell {
            width: min(1120px, 94vw);
            margin: 0 auto;
            padding: 24px 0 40px;
        }

        .hero {
            background: linear-gradient(130deg, #1d4ed8 0%, #0f766e 100%);
            border-radius: 24px;
            color: #fff;
            padding: 22px;
            box-shadow: 0 22px 44px rgba(30, 64, 175, .28);
        }

        .hero h1 {
            margin: 0;
            font-size: clamp(1.4rem, 2.8vw, 2rem);
            font-weight: 800;
        }

        .hero p {
            margin: 8px 0 0;
            color: rgba(255,255,255,.92);
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid rgba(255,255,255,.35);
            border-radius: 999px;
            padding: 8px 12px;
            font-size: .85rem;
            font-weight: 600;
            background: rgba(255,255,255,.08);
        }

        .panel {
            margin-top: 18px;
            border: 1px solid var(--line);
            border-radius: 20px;
            background: var(--panel);
            box-shadow: 0 16px 32px rgba(15, 23, 42, .08);
            overflow: hidden;
        }

        .panel-head {
            padding: 14px 16px;
            border-bottom: 1px solid var(--line);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .panel-head strong {
            font-size: 1.03rem;
        }

        .muted {
            color: var(--muted);
            font-size: .9rem;
        }

        .quiz-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 14px;
            padding: 16px;
        }

        .quiz-card {
            border: 1px solid #dfe8f3;
            border-radius: 16px;
            padding: 14px;
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        }

        .quiz-title {
            font-weight: 700;
            margin-bottom: 4px;
        }

        .quiz-meta {
            font-size: .85rem;
            color: #334155;
        }

        .quiz-desc {
            margin-top: 8px;
            color: var(--muted);
            min-height: 38px;
            font-size: .9rem;
        }

        .result-table thead th {
            text-transform: uppercase;
            font-size: .73rem;
            letter-spacing: .05em;
            color: #4b5f79;
            background: #f8fbff;
            border-bottom-color: var(--line);
            white-space: nowrap;
        }

        .result-table td {
            vertical-align: middle;
            border-color: #edf2f8;
        }

        .course-progress-list {
            padding: 14px 16px;
            display: grid;
            gap: 12px;
        }

        .course-progress-item {
            border: 1px solid #dfe8f3;
            border-radius: 14px;
            padding: 12px;
            background: #fcfdff;
        }

        .course-progress-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }

        @@media (max-width: 768px) {
            .shell {
                width: min(1120px, 96vw);
            }
        }
    </style>
</head>
<body>
    <div class="shell">
        <section class="hero">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                <div>
                    <h1>Quiz luyện tập tiếng Anh</h1>
                    <p>Dạng IELTS: trắc nghiệm và điền đáp án, hiển thị theo khóa học đã xác nhận.</p>
                </div>
                <span class="chip">Xin chào, @Model.UserName</span>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.FlashError))
        {
            <div class="alert alert-danger mt-3 mb-0">@Model.FlashError</div>
        }

        <section class="panel">
            <div class="panel-head">
                <div>
                    <strong>Tiến độ làm quiz theo khóa học</strong>
                    <div class="muted">Theo dõi số quiz đã hoàn thành trên tổng quiz của từng khóa.</div>
                </div>
            </div>
            @if (Model.CourseQuizProgresses.Any())
            {
                <div class="course-progress-list">
                    @foreach (var progress in Model.CourseQuizProgresses)
                    {
                        <div class="course-progress-item">
                            <div class="course-progress-head">
                                <strong>@progress.CourseName</strong>
                                <span class="muted">@progress.CompletedQuizCount/@progress.TotalQuizCount quiz (@progress.Percentage%)</span>
                            </div>
                            <div class="progress" role="progressbar" aria-valuenow="@progress.Percentage" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar bg-success" style="width:@progress.Percentage%"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="p-4 text-muted">Chưa có dữ liệu tiến độ quiz.</div>
            }
        </section>

        <section class="panel">
            <div class="panel-head">
                <div>
                    <strong>Danh sách bài quiz có thể làm</strong>
                    <div class="muted">Chọn bài để bắt đầu làm ngay.</div>
                </div>
                <a class="btn btn-outline-secondary btn-sm" href="/Student">Về trang học viên</a>
            </div>

            @if (Model.Quizzes.Any())
            {
                <div class="quiz-grid">
                    @foreach (var quiz in Model.Quizzes)
                    {
                        var isNotStarted = quiz.StartAt.HasValue && DateTime.Now < quiz.StartAt.Value;
                        var isEnded = quiz.EndAt.HasValue && DateTime.Now > quiz.EndAt.Value;
                        var canTake = !isNotStarted && !isEnded;
                        <article class="quiz-card">
                            <div class="quiz-title">@quiz.Title</div>
                            <div class="quiz-meta">@quiz.CourseName</div>
                            <div class="quiz-desc">@(!string.IsNullOrWhiteSpace(quiz.Description) ? quiz.Description : "Không có mô tả.")</div>
                            <div class="quiz-meta mt-2">Bắt đầu: @(quiz.StartAt.HasValue ? quiz.StartAt.Value.ToString("dd/MM/yyyy HH:mm") : "Ngay khi mở")</div>
                            <div class="quiz-meta">Kết thúc: @(quiz.EndAt.HasValue ? quiz.EndAt.Value.ToString("dd/MM/yyyy HH:mm") : "Không giới hạn")</div>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <small class="text-muted">@quiz.QuestionCount câu • @quiz.TimeLimitMinutes phút</small>
                                @if (canTake)
                                {
                                    <a class="btn btn-primary btn-sm" href="/Student/TakeQuiz?quizId=@quiz.Id">Làm bài</a>
                                }
                                else if (isNotStarted)
                                {
                                    <span class="badge bg-warning text-dark">Chưa mở</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã đóng</span>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="p-4">
                    <div class="alert alert-info mb-0">Bạn chưa có bài quiz nào khả dụng.</div>
                </div>
            }
        </section>

        <section class="panel mt-3">
            <div class="panel-head">
                <div>
                    <strong>Kết quả gần đây</strong>
                    <div class="muted">Lịch sử làm bài gần nhất của bạn.</div>
                </div>
            </div>

            @if (Model.Results.Any())
            {
                <div class="table-responsive">
                    <table class="table result-table mb-0">
                        <thead>
                            <tr>
                                <th>Bài quiz</th>
                                <th>Điểm</th>
                                <th>Tỷ lệ</th>
                                <th>Thời gian làm</th>
                                <th>Hoàn thành</th>
                                <th class="text-end">Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in Model.Results.Take(10))
                            {
                                <tr>
                                    <td>@result.QuizTitle</td>
                                    <td>@result.Score / @result.TotalPoints</td>
                                    <td>@result.PercentageScore</td>
                                    <td>@result.TimeTaken.ToString(@"hh\:mm\:ss")</td>
                                    <td>@result.CompletedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <a class="btn btn-outline-dark btn-sm" href="/Student/QuizResult?id=@result.Id">Xem</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-muted">Bạn chưa nộp bài quiz nào.</div>
            }
        </section>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
