@page
@model StudentManagementApp.Pages.Admin.Classes.CreateModel
@{
    ViewData["Title"] = "Tạo lớp học mới";
    ViewData["ActivePage"] = "Classes";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    var userName = HttpContext.Session.GetString("UserName");
}

<div class="admin-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h6 class="text-res-red fw-bold text-uppercase mb-1">Quản lý đào tạo</h6>
        <h2 class="fw-bold mb-0">Mở lớp học mới</h2>
    </div>
    <a href="/Admin/Classes" class="btn btn-light border fw-bold px-4">
        <i class="bi bi-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="admin-card">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm rounded-4 mb-4"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Tên lớp học</label>
                        <input asp-for="Input.ClassName" class="form-control fw-bold" placeholder="VD: IELTS Foundation - K24" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Ngày bắt đầu dự kiến</label>
                        <input asp-for="Input.StartDate" type="date" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Ngày kết thúc dự kiến</label>
                        <input asp-for="Input.EndDate" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Khóa học đào tạo</label>
                        <select asp-for="Input.CourseId" class="form-select fw-bold">
                            <option value="0">-- Chọn khóa học --</option>
                            @foreach (var c in Model.Courses)
                            {
                                <option value="@c.Id">@c.Name (@c.Level)</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-muted text-uppercase">Phân công giáo viên</label>
                        <select asp-for="Input.TeacherId" class="form-select">
                            <option value="">-- Chưa phân công --</option>
                            @foreach (var t in Model.Teachers)
                            {
                                <option value="@t.Id">@t.FullName</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- SCHEDULE SECTION -->
                <div class="mt-5 p-4 bg-light rounded-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0"><i class="bi bi-calendar-plus me-2 text-res-red"></i>Thiết lập lịch học</h5>
                        <button type="button" id="btnAddSchedule" class="btn btn-dark btn-sm px-3 fw-bold">
                            <i class="bi bi-plus-lg me-1"></i>Thêm buổi
                        </button>
                    </div>

                    <div id="scheduleRows">
                        @for (var i = 0; i < Model.Input.Schedules.Count; i++)
                        {
                            <div class="row g-3 align-items-end mb-3 schedule-row p-3 bg-white rounded-3 shadow-sm mx-0">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold text-muted">Thứ trong tuần</label>
                                    <select asp-for="Input.Schedules[i].DayOfWeek" class="form-select">
                                        <option value="">-- Chọn thứ --</option>
                                        <option value="2">Thứ Hai</option>
                                        <option value="3">Thứ Ba</option>
                                        <option value="4">Thứ Tư</option>
                                        <option value="5">Thứ Năm</option>
                                        <option value="6">Thứ Sáu</option>
                                        <option value="7">Thứ Bảy</option>
                                        <option value="8">Chủ Nhật</option>
                                    </select>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label small fw-bold text-muted">Giờ bắt đầu</label>
                                    <input asp-for="Input.Schedules[i].StartTime" type="time" class="form-control" />
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label small fw-bold text-muted">Giờ kết thúc</label>
                                    <input asp-for="Input.Schedules[i].EndTime" type="time" class="form-control" />
                                </div>

                                <div class="col-md-2">
                                    <button type="button" class="btn btn-outline-danger w-100 fw-bold btn-remove">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <hr class="my-5 opacity-50">

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary-res px-5 py-3 fw-bold shadow-sm">
                        <i class="bi bi-plus-circle me-2"></i>Khởi tạo lớp học
                    </button>
                    <a href="/Admin/Classes" class="btn btn-light border px-5 py-3 fw-bold">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control, .form-select {
        padding: 0.75rem 1rem;
        border-radius: 12px !important;
        border: 1px solid #e2e8f0;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--res-red);
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }
</style>

@section Scripts {
    <script>
        (function () {
            const container = document.getElementById('scheduleRows');
            const addBtn = document.getElementById('btnAddSchedule');

            function attachRemoveHandlers() {
                container.querySelectorAll('.btn-remove').forEach(btn => {
                    btn.onclick = function () {
                        if (container.querySelectorAll('.schedule-row').length <= 1) {
                            alert("Vui lòng thiết lập ít nhất một buổi học.");
                            return;
                        }
                        btn.closest('.schedule-row').remove();
                        reindexRows();
                    };
                });
            }

            function reindexRows() {
                const rows = container.querySelectorAll('.schedule-row');
                rows.forEach((row, idx) => {
                    row.querySelectorAll('[name]').forEach(input => {
                        input.name = input.name.replace(/Input\.Schedules\[\d+\]/, `Input.Schedules[${idx}]`);
                    });
                });
            }

            addBtn.onclick = function () {
                const idx = container.querySelectorAll('.schedule-row').length;
                const html = `
                <div class="row g-3 align-items-end mb-3 schedule-row p-3 bg-white rounded-3 shadow-sm mx-0">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted">Thứ trong tuần</label>
                        <select name="Input.Schedules[${idx}].DayOfWeek" class="form-select">
                            <option value="">-- Chọn thứ --</option>
                            <option value="2">Thứ Hai</option>
                            <option value="3">Thứ Ba</option>
                            <option value="4">Thứ Tư</option>
                            <option value="5">Thứ Năm</option>
                            <option value="6">Thứ Sáu</option>
                            <option value="7">Thứ Bảy</option>
                            <option value="8">Chủ Nhật</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted">Giờ bắt đầu</label>
                        <input name="Input.Schedules[${idx}].StartTime" type="time" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted">Giờ kết thúc</label>
                        <input name="Input.Schedules[${idx}].EndTime" type="time" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-outline-danger w-100 fw-bold btn-remove">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>`;
                container.insertAdjacentHTML('beforeend', html);
                attachRemoveHandlers();
            };

            attachRemoveHandlers();
        })();
    </script>
}