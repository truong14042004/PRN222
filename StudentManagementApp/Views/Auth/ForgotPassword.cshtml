@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - DOL English</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #0a2d6e, #1a5fba);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .card { border: none; border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.2); }
        .brand { color: #0a2d6e; font-weight: 800; font-size: 1.8rem; }
        .brand span { color: #f0c040; }
        .btn-primary { background: #0a2d6e; border: none; }
        .btn-primary:hover { background: #1a5fba; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card p-4">
                    <div class="text-center mb-4">
                        <a href="/" class="text-decoration-none brand">DOL <span>English</span></a>
                        <p class="text-muted mt-1 mb-0">Nhập email để nhận mã OTP</p>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger mb-3">@ViewBag.Error</div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="email" name="email" class="form-control" placeholder="example@email.com" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Gửi mã OTP</button>
                    </form>

                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Login" class="fw-bold text-decoration-none small">Quay lại đăng nhập</a>
                        <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill">Trang chủ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
