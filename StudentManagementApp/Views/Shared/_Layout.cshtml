<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DOL English Center</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --dol-primary: #0d6efd;
            --dol-dark: #0a2d6e;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background-color: var(--dol-dark) !important;
            padding: 14px 0;
        }

        .navbar-brand {
            font-size: 1.6rem;
            font-weight: 800;
            color: #fff !important;
            letter-spacing: 1px;
        }

        .navbar-brand span {
            color: #f0c040;
        }

        .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            margin: 0 4px;
        }

        .nav-link:hover {
            color: #f0c040 !important;
        }

        .btn-login {
            border: 2px solid #f0c040;
            color: #f0c040 !important;
            border-radius: 20px;
            padding: 4px 18px;
        }

        .btn-login:hover {
            background: #f0c040;
            color: var(--dol-dark) !important;
        }

        footer {
            background-color: var(--dol-dark);
            color: rgba(255,255,255,0.7);
            padding: 24px 0;
            margin-top: 0;
        }

        footer a {
            color: #f0c040;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    DOL <span>English</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Course" asp-action="Index">Khóa học</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (Context.Session.GetString("UserId") != null)
                        {
                            var role = Context.Session.GetString("UserRole");
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="@role" asp-action="Index">
                                    <i class="fa fa-user-circle me-1"></i>@Context.Session.GetString("UserName")
                                </a>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="nav-link btn btn-link p-0" style="color:rgba(255,255,255,0.85)">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn-login" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p class="mb-1">&copy; 2026 <strong>DOL English Center</strong> — Trung tâm tiếng Anh chất lượng cao</p>
            <p class="mb-0"><i class="fa fa-phone me-1"></i>0901 000 001 &nbsp;|&nbsp; <i class="fa fa-envelope me-1"></i>admin@englishcenter.com</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
